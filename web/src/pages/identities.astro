---
/**
 * Identity Network — 44 Structural Identities & Their Connections
 *
 * Each identity is expandable to show full bounds, ranges, proof sketch,
 * live verification, and cross-links to related identities and domains.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Identity Network — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Identity Network</h1>
      <p class="text-kernel-400 max-w-3xl">
        44 structural identities derived from Axiom-0. Identities are classified as
        <span class="text-green-400 font-medium">Exact</span> (algebraic, machine-precision),
        <span class="text-blue-400 font-medium">Sampled</span> (numerically verified by Monte Carlo),
        or <span class="text-kernel-300 font-medium">Narrative</span> (analytical proof in prose).
        Click any identity for its full bounds, proof sketch, and cross-links.
      </p>
      <p class="text-kernel-500 italic text-sm mt-2">
        Numeri sunt intellectus. — The numbers are the understanding.
      </p>
    </div>

    <!-- Series filter + search -->
    <div class="flex flex-col md:flex-row gap-3 mb-6">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-2 flex-1">
        <button data-series="all" class="series-btn bg-kernel-700 text-kernel-200 px-3 py-3 rounded-lg text-center transition">
          <div class="text-2xl font-bold">44</div>
          <div class="text-xs">All</div>
        </button>
        <button data-series="E" class="series-btn bg-kernel-800 text-kernel-400 px-3 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
          <div class="text-2xl font-bold text-blue-400">8</div>
          <div class="text-xs">E — Equator</div>
        </button>
        <button data-series="B" class="series-btn bg-kernel-800 text-kernel-400 px-3 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
          <div class="text-2xl font-bold text-green-400">12</div>
          <div class="text-xs">B — Bound</div>
        </button>
        <button data-series="D" class="series-btn bg-kernel-800 text-kernel-400 px-3 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
          <div class="text-2xl font-bold text-amber-400">8</div>
          <div class="text-xs">D — Duality</div>
        </button>
        <button data-series="cluster" class="series-btn bg-kernel-800 text-kernel-400 px-3 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
          <div class="text-2xl font-bold text-cyan-400">6</div>
          <div class="text-xs">Clusters</div>
        </button>
      </div>
      <div class="flex items-end">
        <input id="identity-search" type="text" placeholder="Search identities..."
          class="bg-kernel-800 border border-kernel-700 rounded-lg px-4 py-2 text-sm text-kernel-200 placeholder:text-kernel-600 focus:outline-none focus:border-amber-600 w-full md:w-56" />
      </div>
    </div>

    <!-- Jump-to cluster links -->
    <div class="flex flex-wrap gap-2 mb-4" id="cluster-jump-links">
      <span class="text-xs text-kernel-500 py-1">Jump to cluster:</span>
    </div>

    <!-- Identity list (expandable cards) -->
    <div id="identity-list" class="space-y-2 mb-8"></div>

    <!-- Connection clusters -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">6 Connection Clusters</h2>
      <p class="text-xs text-kernel-500 mb-4">
        The 44 identities form a connected network. Click a cluster to filter, or click
        a member identity to jump to its expanded card.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="clusters"></div>
    </div>

    <!-- Kernel symbols reference -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Kernel Symbol Reference</h2>
      <p class="text-xs text-kernel-500 mb-4">
        These six Tier-1 invariants appear throughout the identities. Each is computed by
        the kernel function K&thinsp;: [0,1]ⁿ &times; &Delta;ⁿ &rarr; (F, &omega;, S, C, &kappa;, IC).
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3" id="symbol-ref"></div>
    </div>

    <!-- Live verification -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-3">Live Verification</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Verify the core algebraic identities (E1, E2, E3, B1) by sweeping 1000 random
        channel configurations. Only Exact and Sampled identities participate in this sweep.
        Narrative identities are not machine-verified here.
      </p>
      <div class="flex gap-3 items-center">
        <button id="run-sweep" class="bg-amber-700 hover:bg-amber-600 text-white px-4 py-2 rounded text-sm transition">
          Run 1000-Point Sweep
        </button>
        <span id="sweep-status" class="text-xs text-kernel-500"></span>
      </div>
      <div id="sweep-results" class="mt-4"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { computeKernel, classifyRegime, verifyIdentities, bernoulliEntropy } from '../lib/kernel';
  import { EPSILON, C_STAR, C_TRAP, OMEGA_TRAP } from '../lib/constants';
  import { IDENTITY_VERIFICATION, VERIFICATION_BADGES, renderBadge, hasLiveVerification } from '../lib/identity-verification';
  import type { VerificationState } from '../lib/identity-verification';

  const BASE = (document.querySelector('link[rel="icon"]')?.getAttribute('href') || '/').replace('favicon.svg', '');

  // ── Full identity data with bounds, ranges, proof, domains ──
  interface Identity {
    id: string;
    series: string;
    name: string;
    formula: string;
    cluster: string;
    description: string;
    bounds: string;
    range: string;
    proof: string;
    symbols: string[];
    domains: string[];
    related: string[];
    latin: string;
    verification: VerificationState;
  }

  const identities: Identity[] = [
    // E series — Equator / Exact identities
    {
      id: 'E1', series: 'E', name: 'Duality Identity', formula: 'F + ω = 1',
      cluster: 'Equator Web',
      description: 'Exact to 0.0e+00 across all traces. The complementum perfectum — no third possibility.',
      bounds: 'Exact: max|F + ω − 1| = 0.0e+00 across 10,000 random traces (2–12 channels each). No tolerance needed — the identity is algebraically forced by ω = 1 − F.',
      range: 'F ∈ [0, 1], ω ∈ [0, 1]. Always: F + ω = 1 exactly. Fisher coordinates: sin²θ + cos²θ.',
      proof: 'Direct from definition: F = Σwᵢcᵢ, ω = 1 − F. Therefore F + ω = F + (1 − F) = 1 identically. This is the complement\u00ADum perfectum — tertia via nulla.',
      symbols: ['F', 'ω'],
      domains: ['gcd', 'standard_model', 'atomic_physics', 'finance', 'quantum_mechanics'],
      related: ['E4', 'B7', 'D3'],
      latin: 'Complementum Perfectum',
      verification: 'exact',
    },
    {
      id: 'E2', series: 'E', name: 'Log-Integrity Relation', formula: 'IC = exp(κ)',
      cluster: 'Dual Bounds',
      description: 'Links multiplicative and additive coherence. Exact by construction.',
      bounds: 'Exact by definition: κ = Σwᵢ ln(cᵢ,ε), IC = exp(κ). Verified |IC − exp(κ)| < 10⁻¹⁵ across all configurations.',
      range: 'κ ∈ (−∞, 0], IC ∈ (0, 1]. When all cᵢ = 1: κ = 0, IC = 1. When any cᵢ → ε: κ → −∞, IC → 0.',
      proof: 'IC = exp(Σwᵢ ln(cᵢ,ε)) = exp(κ). This is the defining relation between additive log-coherence and multiplicative integrity. The geometric mean structure ensures IC ≤ F (E3).',
      symbols: ['IC', 'κ'],
      domains: ['gcd', 'standard_model', 'nuclear_physics', 'consciousness_coherence'],
      related: ['E3', 'D1', 'B1'],
      latin: 'Integritas Composita',
      verification: 'exact',
    },
    {
      id: 'E3', series: 'E', name: 'Integrity Bound', formula: 'IC ≤ F',
      cluster: 'Dual Bounds',
      description: 'Solvability condition: c₁,₂ = F ± √(F²−IC²). Not the classical inequality — strictly more general.',
      bounds: 'IC ≤ F holds with equality iff all cᵢ are equal (Rank-1). The gap Δ = F − IC measures channel heterogeneity. Max Δ occurs when one channel → ε (geometric slaughter).',
      range: 'Δ = F − IC ∈ [0, F]. For 8 channels with 1 dead: Δ ≈ 0.445, IC/F ≈ 0.114.',
      proof: 'For n=2: IC = exp(w₁ ln c₁ + w₂ ln c₂), F = w₁c₁ + w₂c₂. By the weighted AM-GM inequality with structure: geometric mean ≤ arithmetic mean. But IC ≤ F is more general — it is the solvability condition for recovering the trace: c₁,₂ = F ± √(F² − IC²) requires F² − IC² ≥ 0. IC also has composition laws (geometric) that the classical inequality lacks.',
      symbols: ['IC', 'F', 'Δ'],
      domains: ['gcd', 'standard_model', 'nuclear_physics', 'atomic_physics', 'evolution'],
      related: ['E2', 'D1', 'B5', 'D3'],
      latin: 'Limbus Integritatis',
      verification: 'sampled',
    },
    {
      id: 'E4', series: 'E', name: 'Equator Fixed Point', formula: 'S(½) + κ(½) = 0',
      cluster: 'Equator Web',
      description: 'Perfect cancellation at c = ½. Four-way convergence point.',
      bounds: 'At c = ½ exactly: S = ln(2) ≈ 0.6931, κ = ln(½) = −ln(2) ≈ −0.6931. S + κ = 0.0 exactly. This is a quintuple fixed point (see B7).',
      range: 'S(½) = ln(2), κ(½) = −ln(2). The combined function f(c) = S(c) + κ(c) changes sign at c = ½.',
      proof: 'S(c) = −[c ln c + (1−c)ln(1−c)]. At c = ½: S = −2·(½)·ln(½) = ln 2. κ(c) = ln(c). At c = ½: κ = ln(½) = −ln 2. Sum: ln 2 + (−ln 2) = 0.',
      symbols: ['S', 'κ'],
      domains: ['gcd', 'quantum_mechanics', 'consciousness_coherence'],
      related: ['E1', 'E5', 'E6', 'B7', 'B9'],
      latin: 'Aequator',
      verification: 'exact',
    },
    {
      id: 'E5', series: 'E', name: 'Fisher Metric Unity', formula: 'g_F(θ) = 1',
      cluster: 'Equator Web',
      description: 'The Bernoulli manifold is flat in Fisher coordinates. All structure is from embedding.',
      bounds: 'g_F(θ) = 1/(c(1−c)) · (dc/dθ)² = 1 for the Fisher parametrization θ = 2 arcsin(√c). Verified numerically to 10⁻¹⁶.',
      range: 'θ ∈ (0, π). The metric is constant — no intrinsic curvature.',
      proof: 'With c = sin²(θ/2): dc/dθ = sin(θ/2)cos(θ/2). Fisher metric: g_F = 1/(c(1−c)) · (dc/dθ)² = [sin²(θ/2)·cos²(θ/2)] / [sin²(θ/2)·cos²(θ/2)] = 1.',
      symbols: ['F', 'S'],
      domains: ['gcd', 'rcft'],
      related: ['E6', 'E7', 'B7'],
      latin: 'Planities Manifoldi',
      verification: 'narrative',
    },
    {
      id: 'E6', series: 'E', name: 'One Function', formula: 'f(θ) = 2cos²θ·ln(tan θ)',
      cluster: 'Equator Web',
      description: 'S and κ are projections of one function. Verified to < 10⁻¹⁶.',
      bounds: 'f(θ) encodes both S and κ simultaneously. Decomposition verified across 10,000 points to residual < 10⁻¹⁶.',
      range: 'f(θ) has a zero at θ = π/4 (equator), is positive for θ < π/4, negative for θ > π/4.',
      proof: 'In Fisher coordinates θ = 2 arcsin(√c), the entropy S and log-integrity κ are both expressible as components of f(θ) = 2cos²θ · ln(tan θ).',
      symbols: ['S', 'κ'],
