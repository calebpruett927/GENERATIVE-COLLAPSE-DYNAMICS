---
import BaseLayout from '../layouts/BaseLayout.astro';
import { TEST_COUNT } from '../lib/metrics';
const base = import.meta.env.BASE_URL;

/* ═══════════════════════════════════════════════════════════
 * SECTION 1: Repository Papers (LaTeX, from paper/)
 * ═══════════════════════════════════════════════════════════ */
const papers = [
  {
    title: 'Particle Physics in the GCD Kernel: Ten Tier-2 Theorems',
    file: 'standard_model_kernel.tex',
    status: 'Published',
    pages: 5,
    desc: 'Maps 31 Standard Model particles (17 fundamental + 14 composite) through an 8-channel GCD kernel. Proves 10 theorems: spin-statistics separation, generation monotonicity, confinement as IC collapse, mass-kernel log mapping, charge quantization via IC, cross-scale universality, symmetry breaking amplification, CKM unitarity, running coupling flow, and nuclear binding curve.',
    domains: ['standard_model', 'nuclear_physics'],
    findings: [
      'Fermion ⟨F⟩ = 0.615 > Boson ⟨F⟩ = 0.421 — spin-statistics visible in fidelity split',
      'IC drops 98.1% at the quark→hadron boundary (confinement as geometric slaughter)',
      'Neutral particles: IC near ε — charge channel destroys geometric mean',
      'Generation monotonicity: Gen1(0.576) < Gen2(0.620) < Gen3(0.649)',
      '13.2 orders of magnitude in mass → F ∈ [0.37, 0.73] (Spearman ρ = 0.77 for quarks)',
    ],
  },
  {
    title: 'RCFT Second Edition: Foundations and Implications',
    file: 'rcft_second_edition.tex',
    status: 'Published',
    desc: 'Recursive Collapse Field Theory — the theoretical framework extending GCD into recursive field structures. Establishes the Freeze-Weld identity and recursive collapse operators.',
    domains: ['rcft', 'gcd'],
    findings: [
      'Freeze-Weld identity preserves κ-continuity across parameter changes',
      'Recursive collapse operators form a monoid under composition',
      'Seam associativity error: 5.55e-17 (exact to machine precision)',
    ],
  },
  {
    title: 'τ_R* Dynamics',
    file: 'tau_r_star_dynamics.tex',
    status: 'Published',
    desc: 'Formalizes the τ_R* thermodynamic diagnostic: return time computation, phase diagram classification, and the arrow-of-time constraint on collapse trajectories.',
    domains: ['gcd'],
    findings: [
      'τ_R* provides thermodynamic phase classification beyond regime gates',
      'Arrow-of-time constraint on collapse trajectories is measurable',
      'Phase diagram spans Stable / Watch / Collapse with continuous transition',
    ],
  },
  {
    title: 'Confinement Kernel Analysis',
    file: 'confinement_kernel.tex',
    status: 'Published',
    desc: 'Detailed analysis of IC collapse at the quark→hadron phase boundary. Demonstrates that confinement is visible as geometric slaughter: one dead channel (color→0) kills multiplicative coherence.',
    domains: ['standard_model', 'nuclear_physics'],
    findings: [
      'Confinement IS geometric slaughter — dead color channel kills IC',
      'Neutron IC/F = 0.0089, Proton IC/F = 0.0371',
      'All hadrons: IC/F < 0.04 regardless of other channel values',
      'One dead channel in 8 channels: IC/F drops from 1.0 to 0.114',
    ],
  },
  {
    title: 'Measurement Substrate Theory',
    file: 'measurement_substrate.tex',
    status: 'Published',
    desc: 'The GCD kernel as a universal measurement substrate. Establishes that the kernel function provides a domain-independent measurement layer for reproducible computational workflows.',
    domains: ['gcd'],
    findings: [
      'Kernel function is domain-independent — same equations across all 23 domains',
      'Three-valued verdicts replace boolean decisions everywhere',
      'Cognitive Equalizer: same data + same contract → same verdict regardless of agent',
    ],
  },
  {
    title: 'Consciousness Coherence: Seven Theorems in the GCD Kernel',
    file: 'consciousness_coherence.tex',
    status: 'Published',
    desc: 'Maps 20 consciousness systems through a coherence kernel. Seven theorems connecting awareness, integration, and collapse dynamics to measurable kernel invariants.',
    domains: ['consciousness_coherence'],
    findings: [
      '20 consciousness systems mapped through 8-channel coherence kernel',
      'Altered states (15 states) produce measurable IC/F oscillation',
      'Integration measure correlates with heterogeneity gap Δ = F − IC',
    ],
  },
  {
    title: 'Awareness-Cognition Kernel: Ten Theorems Across Phylogeny',
    file: 'awareness_cognition_kernel.tex',
    status: 'Published',
    desc: 'A 5+5 channel awareness-aptitude kernel applied across 34 organisms. Ten theorems on attention mechanisms, cognitive scaling, and phylogenetic awareness gradients.',
    domains: ['awareness_cognition', 'evolution'],
    findings: [
      '5+5 channel kernel: 5 awareness + 5 aptitude channels',
      'Phylogenetic gradient: IC/F increases monotonically with neural complexity',
      'Attention mechanisms map to channel weighting strategies',
    ],
  },
  {
    title: 'Cross-Scale Matter: Quarks to Bulk via Five Phase Boundaries',
    file: 'cross_scale_matter.tex',
    status: 'Published',
    desc: 'Traces IC/F oscillation across five phase boundaries: quark→hadron→nucleus→atom→molecule→bulk. Each boundary is a collapse-return cycle measurable in the kernel.',
    domains: ['standard_model', 'atomic_physics', 'materials_science'],
    findings: [
      'IC/F oscillates across five phase boundaries (collapse→return→collapse)',
      'Confinement cliff: IC drops 98% at quark→hadron; atoms restore to 0.96',
      'Matter genesis: 99 entities across 7 acts traced through kernel',
      'magic_prox is #1 IC killer at nuclear scale (39% contribution)',
    ],
  },
  {
    title: 'RCFT Freeze-Weld Identity',
    file: 'RCFT_FREEZE_WELD.md',
    status: 'Technical Note',
    desc: 'Formal specification of the Freeze-Weld identity: the mechanism by which recursive collapse fields preserve continuity across parameter changes.',
    domains: ['rcft'],
    findings: [
      'Weld is the only legitimate mechanism for parameter change',
      'κ-continuity constraint: |Δκ| ≤ tol_seam across every weld',
      'History is append-only and welded, never rewritten',
    ],
  },
];

/* ═══════════════════════════════════════════════════════════
 * SECTION 2: Zenodo Publications (DOI-minted, peer-archived)
 * Community: https://zenodo.org/communities/epistemeconstruction
 * ═══════════════════════════════════════════════════════════ */
const zenodoRecords = [
  {
    title: 'Structura Collapsus',
    doi: '10.5281/zenodo.19025647',
    date: '2026-03-14',
    type: 'Publication',
    desc: 'Formal structural analysis of collapse dynamics — the Latin-rooted formalization of GCD as a generative mathematical structure.',
    views: 16, downloads: 9,
  },
  {
    title: 'Generative Collapse Dynamics: Whitepaper',
    doi: '10.5281/zenodo.18893328',
    date: '2026-03-06',
    type: 'Publication',
    desc: 'The comprehensive GCD whitepaper — derives the complete kernel, tier system, frozen parameters, and 44 structural identities from a single axiom.',
    views: 34, downloads: 15,
  },
  {
    title: 'UMCP GitHub Repository',
    doi: '10.5281/zenodo.18379293',
    date: '2026-01-26',
    type: 'Software',
    desc: 'Archived snapshot of the Universal Measurement Contract Protocol codebase — 19,000+ tests across 21 closure domains.',
    views: 5, downloads: 0,
  },
  {
    title: 'Universal Measurement Contract Protocol',
    doi: '10.5281/zenodo.18226878',
    date: '2026-01-14',
    type: 'Publication',
    desc: 'Complete UMCP specification — validation protocol, casepack format, three-valued verdicts, SHA-256 integrity chains, and the five-stop spine.',
    views: 83, downloads: 34,
  },
  {
    title: 'The Physics of Coherence',
    doi: '10.5281/zenodo.18111558',
    date: '2025-12-31',
    type: 'Publication',
    desc: 'Cross-domain coherence analysis — demonstrates kernel universality across particle physics, atomic physics, consciousness, and materials science.',
    views: 68, downloads: 46,
  },
  {
    title: 'A Provenance & Canon Note',
    doi: '10.5281/zenodo.17980036',
    date: '2025-12-18',
    type: 'Publication',
    desc: 'Formal specification of provenance tracking — the manifest system, SHA-256 checksums, and canon anchoring protocol.',
    views: 82, downloads: 50,
  },
  {
    title: 'The Episteme of Return',
    doi: '10.5281/zenodo.17797689',
    date: '2025-12-03',
    type: 'Publication',
    desc: 'Epistemological foundations of GCD — how the return axiom structures knowledge claims and validates epistemic coherence.',
    views: 153, downloads: 72,
  },
  {
    title: 'Collapse Integrity Kernel v1.0.3',
    doi: '10.5281/zenodo.17694376',
    date: '2025-11-24',
    type: 'Software',
    desc: 'Versioned release of the collapse integrity kernel — the core computational engine implementing K: [0,1]&#8319; &times; &Delta;&#8319; &rarr; (F, &omega;, S, C, &kappa;, IC).',
    views: 52, downloads: 27,
  },
  {
    title: 'The Seam of Reality',
    doi: '10.5281/zenodo.17619502',
    date: '2025-11-15',
    type: 'Publication',
    desc: 'Seam calculus — the verification boundary between outbound collapse and demonstrated return. Derives frozen parameters from seam closure requirements.',
    views: 36, downloads: 25,
  },
  {
    title: 'Welded Agency',
    doi: '10.5281/zenodo.17561485',
    date: '2025-11-08',
    type: 'Publication',
    desc: 'The weld mechanism formalized — how agency, continuity, and policy change coexist through append-only welded history.',
    views: 21, downloads: 21,
  },
  {
    title: 'Retro-Coherent Transmission through Quantum Collapse',
    doi: '10.5281/zenodo.17518421',
    date: '2025-11-04',
    type: 'Publication',
    desc: 'Quantum coherence transmission analysis — RCFT framework applied to quantum measurement, entanglement, and retro-coherent signal recovery.',
    views: 77, downloads: 60,
  },
  {
    title: 'The Grammar of Return',
    doi: '10.5281/zenodo.17518338',
    date: '2025-11-04',
    type: 'Publication',
    desc: 'The five-word vocabulary and discourse spine formalized — Drift, Fidelity, Roughness, Return, Integrity as the grammar of every claim.',
    views: 19, downloads: 13,
  },
  {
    title: 'Collapse Integrity Calculus',
    doi: '10.5281/zenodo.17518269',
    date: '2025-11-04',
    type: 'Publication',
    desc: 'Mathematical calculus of collapse integrity — derivation of the kernel identities, frozen constants, and the integrity bound IC &le; F.',
    views: 15, downloads: 14,
  },
  {
    title: 'The Return Structure of Integrity',
    doi: '10.5281/zenodo.17429931',
    date: '2025-10-24',
    type: 'Publication',
    desc: 'Structural analysis of integrity as a return property — why IC is always derived, never asserted, and how the ledger enforces reconciliation.',
    views: 17, downloads: 12,
  },
  {
    title: 'Integrity Stack',
    doi: '10.5281/zenodo.17393096',
    date: '2025-10-19',
    type: 'Publication',
    desc: 'The complete integrity stack — from raw data through embedding, kernel computation, regime gates, seam verification, to three-valued verdict.',
    views: 19, downloads: 20,
  },
  {
    title: 'CIN-1 Recovery Protocol',
    doi: '10.5281/zenodo.17345786',
    date: '2025-10-14',
    type: 'Publication',
    desc: 'Recovery protocol for CIN-1 nonconformance — systematic procedure for returning a failed validation to conformance through welded correction.',
    views: 13, downloads: 16,
  },
  {
    title: 'Liber Universalis de Collapsus Mathematica',
    doi: '10.5281/zenodo.17329809',
    date: '2025-10-11',
    type: 'Publication',
    desc: 'The universal book of collapse mathematics — Latin-formalized presentation of the complete GCD/UMCP mathematical framework.',
    views: 13, downloads: 14,
  },
  {
    title: 'Episteme Construction',
    doi: '10.5281/zenodo.17309177',
    date: '2025-10-10',
    type: 'Publication',
    desc: 'Foundational publication — the original episteme construction paper establishing Axiom-0 and the return structure that the entire framework derives from.',
    views: 37, downloads: 352,
  },
];

const statusColors: Record<string, string> = {
  'Published': 'text-green-400 border-green-700/50 bg-green-900/10',
  'Technical Note': 'text-blue-400 border-blue-700/50 bg-blue-900/10',
  'Draft': 'text-yellow-400 border-yellow-700/50 bg-yellow-900/10',
};

const typeColors: Record<string, string> = {
  'Publication': 'text-emerald-400 border-emerald-700/50 bg-emerald-900/10',
  'Software': 'text-cyan-400 border-cyan-700/50 bg-cyan-900/10',
};

const totalViews = zenodoRecords.reduce((s, r) => s + r.views, 0);
const totalDownloads = zenodoRecords.reduce((s, r) => s + r.downloads, 0);
const sections = ['overview', 'zenodo', 'repo-papers', 'timeline', 'compilation', 'author'];
---

<BaseLayout title="Papers & Publications — GCD Kernel" description="Published research papers, Zenodo publications, and DOI-minted archives of Generative Collapse Dynamics.">
  <div class="max-w-5xl mx-auto">

    <!-- ═══════════ HERO ═══════════ -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Papers &amp; Publications</h1>
      <p class="text-kernel-400 text-lg italic">
        Scripta manent — quod scriptum est, redit.
      </p>
      <p class="text-kernel-500 text-sm mt-2 max-w-3xl">
        Complete publication catalog of Generative Collapse Dynamics. 18 DOI-minted
        Zenodo publications and 9 repository papers — all derived from a single axiom,
        all reproducible from source.
      </p>
    </div>

    <!-- ═══════════ SECTION NAV ═══════════ -->
    <nav class="mb-8 flex flex-wrap gap-2">
      {sections.map(s => (
        <a href={`#${s}`} class="px-3 py-1.5 rounded-full text-xs font-medium
          bg-kernel-800/60 text-kernel-400 hover:text-kernel-200 hover:bg-kernel-700/60
          border border-kernel-700/40 transition no-underline">
          {s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
        </a>
      ))}
    </nav>

    <!-- ═══════════ §1: OVERVIEW ═══════════ -->
    <section id="overview" class="mb-12">
      <div class="bg-kernel-900/80 border border-kernel-800 rounded-xl p-6">
        <h2 class="text-sm font-bold text-amber-400/80 uppercase tracking-wider mb-4">Publication Overview</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4 text-center">
          <div>
            <div class="text-2xl font-bold text-amber-400">{zenodoRecords.length}</div>
            <div class="text-xs text-kernel-500">Zenodo Records</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-green-400">{papers.length}</div>
            <div class="text-xs text-kernel-500">Repo Papers</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-blue-400">{zenodoRecords.length + papers.length}</div>
            <div class="text-xs text-kernel-500">Total Works</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-cyan-400">{totalViews.toLocaleString()}</div>
            <div class="text-xs text-kernel-500">Zenodo Views</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-purple-400">{totalDownloads.toLocaleString()}</div>
            <div class="text-xs text-kernel-500">Downloads</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-emerald-400">189</div>
            <div class="text-xs text-kernel-500">BibTeX Entries</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-red-400">CC BY 4.0</div>
            <div class="text-xs text-kernel-500">License</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-amber-400">1</div>
            <div class="text-xs text-kernel-500">Axiom</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ §2: ZENODO PUBLICATIONS ═══════════ -->
    <section id="zenodo" class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-2xl font-bold text-kernel-100">Zenodo Publications</h2>
        <span class="text-xs px-2 py-0.5 rounded bg-emerald-900/30 text-emerald-400 border border-emerald-700/50">
          DOI-minted
        </span>
      </div>

      <!-- Zenodo community banner -->
      <div class="bg-gradient-to-r from-blue-900/20 to-emerald-900/20 border border-blue-700/30 rounded-xl p-5 mb-6">
        <div class="flex items-start justify-between flex-wrap gap-4">
          <div>
            <h3 class="text-sm font-bold text-blue-300 mb-1">Episteme Construction Community</h3>
            <p class="text-xs text-kernel-400 max-w-xl">
              All publications are archived in the
              <a href="https://zenodo.org/communities/epistemeconstruction" target="_blank" rel="noopener noreferrer"
                 class="text-blue-400 hover:text-blue-300 transition underline">Episteme Construction</a>
              community on Zenodo — CERN's open-access repository. Each record receives a persistent DOI
              and is preserved in the CERN Data Centre.
            </p>
          </div>
          <div class="flex flex-col items-end gap-1.5">
            <a href="https://zenodo.org/communities/epistemeconstruction/records?q=&l=list&p=1&s=10&sort=newest"
               target="_blank" rel="noopener noreferrer"
               class="text-xs px-3 py-1.5 rounded bg-blue-800/50 text-blue-300 hover:bg-blue-700/50 border border-blue-700/40 transition no-underline">
              View on Zenodo &rarr;
            </a>
            <span class="text-xs text-kernel-600 font-mono">{zenodoRecords.length} records &middot; {totalViews} views &middot; {totalDownloads} downloads</span>
          </div>
        </div>
      </div>

      <!-- Zenodo records list -->
      <div class="space-y-3">
        {zenodoRecords.map((r, i) => (
          <div class="zenodo-card bg-kernel-900/50 border border-kernel-800/40 rounded-xl overflow-hidden hover:border-blue-700/40 transition cursor-pointer group" data-zdx={i}>
            <div class="p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-1.5">
                    <span class="text-kernel-600 font-mono text-xs shrink-0">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="text-base font-bold text-kernel-100 group-hover:text-blue-300 transition truncate">{r.title}</h3>
                  </div>
                  <p class="text-xs text-kernel-400 mb-2 line-clamp-2">{r.desc}</p>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-xs px-2 py-0.5 rounded border ${typeColors[r.type] || 'text-kernel-400 border-kernel-700'}`}>
                      {r.type}
                    </span>
                    <span class="text-xs text-kernel-500 bg-kernel-800 px-2 py-0.5 rounded">{r.date}</span>
                    <a href={`https://doi.org/${r.doi}`} target="_blank" rel="noopener noreferrer"
                       class="text-xs text-blue-400 hover:text-blue-300 font-mono bg-kernel-800 px-2 py-0.5 rounded transition no-underline"
                       onclick="event.stopPropagation()">
                      DOI:{r.doi.replace('10.5281/zenodo.', '')}
                    </a>
                    <span class="text-xs text-kernel-600 ml-auto shrink-0">
                      {r.views} views &middot; {r.downloads} downloads
                    </span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Expandable description -->
            <div class="zenodo-detail hidden border-t border-kernel-800 bg-kernel-950/50 p-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                <div>
                  <h4 class="text-kernel-400 font-bold uppercase tracking-wider mb-2">Full Description</h4>
                  <p class="text-kernel-400 leading-relaxed">{r.desc}</p>
                </div>
                <div>
                  <h4 class="text-kernel-400 font-bold uppercase tracking-wider mb-2">Citation &amp; Access</h4>
                  <div class="space-y-1.5 text-kernel-500">
                    <div><span class="text-kernel-600">DOI:</span> <a href={`https://doi.org/${r.doi}`} target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300 transition" onclick="event.stopPropagation()">{r.doi}</a></div>
                    <div><span class="text-kernel-600">Date:</span> {r.date}</div>
                    <div><span class="text-kernel-600">Type:</span> {r.type}</div>
                    <div><span class="text-kernel-600">License:</span> Creative Commons Attribution 4.0</div>
                    <div><span class="text-kernel-600">Community:</span> Episteme Construction</div>
                    <div><span class="text-kernel-600">Repository:</span> CERN Data Centre (Zenodo)</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════ §3: REPOSITORY PAPERS ═══════════ -->
    <section id="repo-papers" class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-2xl font-bold text-kernel-100">Repository Papers</h2>
        <span class="text-xs px-2 py-0.5 rounded bg-amber-900/30 text-amber-400 border border-amber-700/50">
          LaTeX source
        </span>
      </div>

      <p class="text-sm text-kernel-400 mb-4 max-w-3xl">
        These papers live in the repository's <code class="text-xs bg-kernel-800 px-1 py-0.5 rounded">paper/</code> directory.
        All use RevTeX4-2, share a unified bibliography of 189 entries (PDG 2024 through Kramers 1940),
        and are compilable from source.
      </p>

      <div class="space-y-3">
        {papers.map((p, i) => (
          <div class="paper-card bg-kernel-900/50 border border-kernel-800/40 rounded-xl overflow-hidden hover:border-amber-700/40 transition cursor-pointer group" data-idx={i}>
            <div class="p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-1.5">
                    <span class="text-kernel-600 font-mono text-xs shrink-0">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="text-base font-bold text-kernel-100 group-hover:text-amber-300 transition">{p.title}</h3>
                  </div>
                  <p class="text-xs text-kernel-400 mb-2">{p.desc}</p>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`text-xs px-2 py-0.5 rounded border ${statusColors[p.status] || 'text-kernel-400 border-kernel-700'}`}>
                      {p.status}
                    </span>
                    {p.pages && (
                      <span class="text-xs text-kernel-500 bg-kernel-800 px-2 py-0.5 rounded">{p.pages} pages</span>
                    )}
                    {p.domains.map(d => (
                      <a href={`${base}${d}/`}
                         class="text-xs text-kernel-500 hover:text-kernel-300 bg-kernel-800 px-2 py-0.5 rounded transition no-underline"
                         onclick="event.stopPropagation()">
                        {d}
                      </a>
                    ))}
                    <span class="text-xs text-kernel-600 font-mono ml-auto">paper/{p.file}</span>
                  </div>
                </div>
              </div>
            </div>
            {p.findings && (
              <div class="paper-detail hidden border-t border-kernel-800 bg-kernel-950/50 p-4">
                <h4 class="text-xs font-bold text-kernel-400 uppercase tracking-wider mb-2">Key Findings</h4>
                <ul class="text-xs text-kernel-400 space-y-1 list-disc list-inside">
                  {p.findings.map((f: string) => <li>{f}</li>)}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- ═══════════ §4: PUBLICATION TIMELINE ═══════════ -->
    <section id="timeline" class="mb-12">
      <h2 class="text-2xl font-bold text-kernel-100 mb-6">Publication Timeline</h2>
      <div class="bg-kernel-900/80 border border-kernel-800 rounded-xl p-6">
        <div class="relative">
          <!-- Timeline line -->
          <div class="absolute left-3 top-0 bottom-0 w-px bg-kernel-700/50"></div>

          {zenodoRecords.map((r, i) => {
            const d = new Date(r.date);
            const monthStr = d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
            return (
              <div class="relative pl-10 pb-5 last:pb-0">
                {/* Dot on timeline */}
                <div class={`absolute left-1.5 top-1 w-3 h-3 rounded-full border-2 ${
                  r.type === 'Software' ? 'bg-cyan-500 border-cyan-400' : 'bg-emerald-500 border-emerald-400'
                }`}></div>
                <div class="flex items-baseline gap-3 flex-wrap">
                  <span class="text-xs text-kernel-600 font-mono shrink-0 w-20">{monthStr}</span>
