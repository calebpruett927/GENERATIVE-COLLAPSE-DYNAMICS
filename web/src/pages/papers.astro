<script>
  // Toggle paper detail panels on click
  document.querySelectorAll('.paper-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const detail = card.querySelector('.paper-detail');
      if (detail) {
        detail.classList.toggle('hidden');
        card.classList.toggle('border-amber-700/40');
      }
    });
  });

  // Toggle zenodo detail panels on click
  document.querySelectorAll('.zenodo-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) return;
      const detail = card.querySelector('.zenodo-detail');
      if (detail) {
        detail.classList.toggle('hidden');
        card.classList.toggle('border-blue-700/40');
      }
    });
  });
</script>
