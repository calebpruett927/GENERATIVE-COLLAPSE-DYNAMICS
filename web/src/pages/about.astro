        <div class="space-y-1.5">
          <div class="bg-kernel-950 rounded p-2"><span class="font-mono text-red-400 text-[10px]">L42</span> <span class="text-xs text-kernel-300">Phase boundary detection: IC/F ratio cliff at confinement transition</span></div>
          <div class="bg-kernel-950 rounded p-2"><span class="font-mono text-red-400 text-[10px]">L47</span> <span class="text-xs text-kernel-300">Geometric Slaughter — one dead channel kills IC regardless of other channels</span></div>
          <div class="text-[10px] text-kernel-600 mt-1">+ L35–L41, L43–L46 (return-collapse duality, generative flux, scale invariance, composition)</div>
        </div>`
    },
  ];

  const lemmaCardsContainer = document.getElementById('lemma-category-cards')!;
  const lemmaDetailPanel = document.getElementById('lemma-detail')!;

  function renderLemmaCategories() {
    lemmaCardsContainer.innerHTML = '';
    lemmaCategories.forEach((cat, i) => {
      const btn = document.createElement('button');
      btn.className = `lemma-card bg-kernel-900 border-2 ${cat.borderColor} rounded-xl p-3 text-center cursor-pointer transition group`;
      btn.dataset.index = String(i);
      btn.innerHTML = `
        <div class="text-xs font-mono text-kernel-500 mb-1">${cat.range}</div>
        <div class="text-sm font-bold ${cat.color}">${cat.name}</div>
        <div class="text-lg font-bold text-kernel-400 mt-1">${cat.count}</div>
        <div class="text-[10px] text-kernel-600 group-hover:text-kernel-400 transition mt-1">Click &rarr;</div>
      `;
      btn.addEventListener('click', () => showLemmaDetail(i));
      lemmaCardsContainer.appendChild(btn);
    });
  }

  function showLemmaDetail(index: number) {
    const cat = lemmaCategories[index];
    document.getElementById('lemma-detail-title')!.innerHTML = `<span class="${cat.color}">${cat.range}: ${cat.name}</span> — ${cat.count} lemmas`;
    document.getElementById('lemma-detail-body')!.innerHTML = `
      <p class="mb-3">${cat.description}</p>
      <h4 class="text-xs font-bold text-kernel-400 uppercase tracking-wider mb-2">Key Lemmas</h4>
      ${cat.keyLemmas}
    `;
    lemmaDetailPanel.classList.remove('hidden');

    document.querySelectorAll('.lemma-card').forEach((c, i) => {
      if (i === index) c.classList.add('ring-2', 'ring-kernel-500');
      else c.classList.remove('ring-2', 'ring-kernel-500');
    });

    lemmaDetailPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('lemma-detail-close')!.addEventListener('click', () => {
    lemmaDetailPanel.classList.add('hidden');
    document.querySelectorAll('.lemma-card').forEach(c => c.classList.remove('ring-2', 'ring-kernel-500'));
  });

  // ── Initialize everything ──────────────────────

  renderCards();
  renderRelationshipDiagram();
  renderSpine();
  renderFiveWords();
  renderTiers();
  renderTestTiers();
  renderIdentitySeries();
  renderClusters();
  renderLemmaCategories();
</script>
