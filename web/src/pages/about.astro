    // Reset to "what" tab
    activeTab = 'what';
    updateTabs();
    renderTabContent();

    // Highlight active card
    document.querySelectorAll('.inv-card').forEach((c, i) => {
      if (i === index) {
        c.classList.add('ring-2', isPrimitive ? 'ring-amber-500' : 'ring-blue-400');
      } else {
        c.classList.remove('ring-2', 'ring-amber-500', 'ring-blue-400');
      }
    });

    detailPanel.classList.remove('hidden');
    detailPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function updateTabs() {
