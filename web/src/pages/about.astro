<script>
  // ═══════════════════════════════════════════════════
  //  Interactive About Page — Client-Side Logic
  // ═══════════════════════════════════════════════════

  const BASE = (document.querySelector('link[rel="icon"]')?.getAttribute('href') || '/').replace('favicon.svg', '');

  // ── Invariant Data ───────────────────────────────

  interface InvariantData {
    symbol: string;
    name: string;
    latin: string;
    formula: string;
    kind: 'primitive' | 'derived';
    range: string;
    color: string;
    what: string;
    why: string;
    how: string;
    connections: string;
    derivedFrom?: string;
  }

  const invariants: InvariantData[] = [
    {
      symbol: 'F', name: 'Fidelity', latin: 'Fidelitas',
      formula: 'F = Σ wᵢcᵢ',
      kind: 'primitive', range: '[0, 1]', color: 'amber',
      what: `<p><strong>Fidelity</strong> measures <em>what survives collapse</em>. It is the weighted arithmetic mean of all channel values in the trace vector.</p>
             <p>When F = 1, everything is perfectly preserved. When F → 0, almost nothing survives. In particle physics, quark channels have F ≈ 0.55–0.65. In atomic physics, stable atoms push F above 0.90.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>fidelitas</em> — "faithfulness." <em>Quid supersit post collapsum</em> — what survives after collapse.</p>`,
      why: `<p>Fidelity is primitive because it is the <strong>most direct measurement</strong> of the axiom. Axiom-0 asks "what returns?" — F answers by measuring what fraction of the signal is retained across all channels.</p>
            <p>Its computation requires only the trace vector c and weights w — no other invariants. This makes it the <strong>anchor</strong> of the entire kernel.</p>
            <p>It also appears in two of the three core identities: <span class="font-mono text-amber-400">F + ω = 1</span> and <span class="font-mono text-amber-400">IC ≤ F</span>. No other symbol appears in more constraints.</p>`,
      how: `<p>Given n channels with values c₁, c₂, ..., cₙ and weights w₁, w₂, ..., wₙ (summing to 1):</p>
            <div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">F = w₁c₁ + w₂c₂ + ... + wₙcₙ</div>
            <p>This is a standard weighted arithmetic mean, but its meaning is fixed by Axiom-0: it measures the survival fraction across the collapse field.</p>
            <p class="text-xs text-kernel-500 mt-2">Implemented in: <code>kernel_optimized.py</code>, <code>kernel.c</code>, <code>kernel.ts</code></p>`,
      connections: `<p><strong>F → ω:</strong> Drift is defined as ω = 1 − F. Knowing F immediately gives ω.</p>
                    <p><strong>F ↔ IC:</strong> The integrity bound IC ≤ F always holds. F is the arithmetic mean; IC is the geometric mean. They are equal only when all channels are identical (homogeneous trace).</p>
                    <p><strong>F ↔ S:</strong> As n grows, entropy S becomes asymptotically determined by F and C. This reduces the kernel from 4 free variables to 3.</p>
                    <p><strong>F in Regime Gates:</strong> Stable regime requires F > 0.90.</p>`
    },
    {
      symbol: 'κ', name: 'Log-Integrity', latin: 'Log-Integritas',
      formula: 'κ = Σ wᵢ ln(cᵢ,ε)',
      kind: 'primitive', range: '(−∞, 0]', color: 'amber',
      what: `<p><strong>Log-integrity</strong> measures the <em>logarithmic sensitivity of coherence</em>. It's the weighted sum of log-channel values, using ε-clamped channels to avoid the pole at 0.</p>
             <p>κ is always ≤ 0. When κ = 0, all channels are maximal (cᵢ = 1). As any channel drops toward ε, κ plummets — logarithmically amplifying the weakness. This is why a single dead channel can destroy integrity even when F stays healthy.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>sensibilitas logarithmica</em> — logarithmic sensitivity of coherence.</p>`,
      why: `<p>κ is primitive because it provides a fundamentally different view from F. While F averages channels arithmetically, κ averages their <strong>logarithms</strong> — making it exquisitely sensitive to weak channels.</p>
            <p>This sensitivity is not a design choice. It emerges from Axiom-0's requirement that integrity be <strong>multiplicative</strong>: if one channel is dead, the whole system's integrity should collapse. The log transform converts this multiplicative requirement into additive computation.</p>
            <p>The ε guard band (ε = 10⁻⁸) prevents the pole at c = 0 from producing −∞, while keeping sensitivity to 8 decimal places.</p>`,
      how: `<div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">κ = w₁ ln(max(c₁, ε)) + w₂ ln(max(c₂, ε)) + ... + wₙ ln(max(cₙ, ε))</div>
            <p>The ε-clamp ensures numerical stability. With ε = 10⁻⁸, a fully dead channel contributes ln(10⁻⁸) ≈ −18.4 per unit weight — enough to dominate κ even when other channels are perfect.</p>
            <p class="text-xs text-kernel-500 mt-2">This is the "geometric slaughter" phenomenon: in an 8-channel system, 7 perfect channels (c = 1) and 1 dead channel (c → ε) gives IC/F ≈ 0.11.</p>`,
      connections: `<p><strong>κ → IC:</strong> Integrity composite IC = exp(κ). This is the defining link — IC is simply κ exponentiated.</p>
                    <p><strong>κ ↔ S:</strong> At the equator (c = 1/2), S + κ = 0 exactly. This four-way convergence is identity E4.</p>
                    <p><strong>κ ↔ F:</strong> IC ≤ F means κ ≤ ln(F). Log-integrity can never exceed the log of fidelity.</p>`
    },
    {
      symbol: 'S', name: 'Entropy', latin: 'Entropia',
      formula: 'S = −Σ wᵢ[cᵢ ln cᵢ + (1−cᵢ) ln(1−cᵢ)]',
      kind: 'primitive', range: '[0, ln 2]', color: 'amber',
      what: `<p><strong>Bernoulli field entropy</strong> measures the <em>uncertainty of the collapse field</em>. It is the weighted sum of binary entropy functions applied to each channel.</p>
             <p>When S = 0, every channel is at an extreme (0 or 1) — the outcome is certain. When S is maximal (at c = 1/2 for all channels), uncertainty peaks — the system is maximally ambiguous about its state.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>incertitudo campi collapsus</em> — uncertainty of the collapse field. Note: this is Bernoulli field entropy, not Shannon entropy. Shannon entropy is the degenerate limit when the collapse field is removed.</p>`,
      why: `<p>S is primitive because it captures information that neither F nor κ can: the <strong>uncertainty</strong> inherent in the channel configuration. Two systems can have the same F and κ but very different entropies.</p>
            <p>However, S has a special status: as the number of channels n grows, S becomes <strong>asymptotically determined</strong> by F and C (corr(C,S) → −1 as n → ∞). This means S is computed as a primitive but does not add a free degree of freedom — it is the reason the kernel has only 3 effective DOF, not 4.</p>`,
      how: `<p>For each channel cᵢ, compute the binary (Bernoulli) entropy:</p>
            <div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">h(c) = −[c ln(c) + (1−c) ln(1−c)]</div>
            <p>Then weight and sum: <span class="font-mono">S = Σ wᵢ · h(cᵢ)</span></p>
            <p>At the boundaries (c = 0 or c = 1), h(c) = 0 by convention (L'Hôpital). Maximum at c = 1/2: h(1/2) = ln 2.</p>`,
      connections: `<p><strong>S ↔ F, C:</strong> S ≈ f(F, C) asymptotically. This is the statistical constraint that reduces DOF from 4 to 3.</p>
                    <p><strong>S in Regime Gates:</strong> Stable regime requires S < 0.15.</p>
                    <p><strong>S + κ at equator:</strong> When all c = 1/2, S + κ = 0 exactly (identity E4). This four-way convergence is one of the deepest results.</p>`
    },
    {
      symbol: 'C', name: 'Curvature', latin: 'Curvatura',
      formula: 'C = stddev(cᵢ) / 0.5',
      kind: 'primitive', range: '[0, 1]', color: 'amber',
      what: `<p><strong>Curvature</strong> measures <em>coupling to uncontrolled degrees of freedom</em>. It normalizes the standard deviation of channel values to the [0, 1] range.</p>
             <p>When C = 0, all channels are identical (homogeneous trace). When C → 1, channels are maximally spread — some near 0, others near 1. High curvature means the system's coherence varies dramatically across its dimensions.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>coniunctio cum gradibus libertatis</em> — coupling to degrees of freedom.</p>`,
      why: `<p>C is primitive because it captures the <strong>spread</strong> of channel values — something that F (average) and κ (product-sensitivity) both miss. Two systems with F = 0.5 can have C = 0 (all channels at 0.5) or C = 1 (channels at 0 and 1).</p>
            <p>Curvature directly enters the seam budget as the curvature debit D_C = α·C, penalizing systems whose channels are heterogeneous. It also determines the heterogeneity gap Δ = F − IC: high C implies IC ≪ F (geometric slaughter).</p>
            <p>Together with F and κ, C forms the three independent degrees of freedom of the kernel.</p>`,
      how: `<div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">C = σ(c) / 0.5 where σ = √(Σ wᵢ(cᵢ − F)²)</div>
            <p>Division by 0.5 normalizes to [0, 1] since the maximum possible stddev of values in [0, 1] is 0.5 (attained when half the weight is at 0 and half at 1).</p>`,
      connections: `<p><strong>C ↔ S:</strong> corr(C, S) → −1 as n → ∞. This is why S doesn't add a free DOF.</p>
                    <p><strong>C → Δ:</strong> High curvature drives the heterogeneity gap Δ = F − IC. The correction is −C²/(8F²) to first order.</p>
                    <p><strong>C in Regime Gates:</strong> Stable regime requires C < 0.14.</p>
                    <p><strong>C in Seam Budget:</strong> Curvature debit D_C = α·C = 1.0 · C.</p>`
    },
    {
      symbol: 'ω', name: 'Drift', latin: 'Derivatio',
      formula: 'ω = 1 − F',
      kind: 'derived', range: '[0, 1]', color: 'blue',
      derivedFrom: 'F',
      what: `<p><strong>Drift</strong> measures <em>what is lost to collapse</em>. It is the complement of fidelity — the fraction of the signal that does not survive.</p>
             <p>When ω = 0, nothing is lost. When ω → 1, almost everything is lost. The primary regime boundary is at ω = 0.30: above this, the system is in Collapse regime.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>derivatio</em> — diversion from the channel. <em>Quantum collapsu deperdatur</em> — how much is lost to collapse.</p>`,
      why: `<p>ω is <strong>derived</strong>, not primitive, because it carries no independent information — it is completely determined by F through the duality identity <span class="font-mono text-amber-400">F + ω = 1</span>.</p>
            <p>Despite being derived, ω is deeply important: it is the primary variable for regime classification (the main gates are on ω), it drives the drift cost Γ(ω) = ω³/(1−ω+ε) in the seam budget, and it maps to the prose word "Drift" — one of the five words of the Canon.</p>
            <p>The duality identity F + ω = 1 is verified to <strong>exactly 0.0e+00</strong> residual across 10,000 random traces. It is algebraically forced, not approximately true.</p>`,
      how: `<div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">ω = 1 − F = 1 − Σ wᵢcᵢ</div>
            <p>No additional computation needed — just subtract F from 1. The identity F + ω = 1 is the <em>complementum perfectum</em>: there is no third possibility.</p>`,
      connections: `<p><strong>ω ← F:</strong> Derived directly. F + ω = 1 exactly (duality identity E1).</p>
                    <p><strong>ω → Γ:</strong> Drift cost Γ(ω) = ω³/(1−ω+ε). This enters the seam budget as the drift debit D_ω.</p>
                    <p><strong>ω in Regime Gates:</strong> Stable: ω < 0.038. Watch: 0.038 ≤ ω < 0.30. Collapse: ω ≥ 0.30.</p>
                    <p><strong>ω remains Tier-1:</strong> Even though derived, ω is a Tier-1 output — it appears in immutable identities, not a Tier-0 diagnostic.</p>`
    },
    {
      symbol: 'IC', name: 'Integrity', latin: 'Integritas Composita',
      formula: 'IC = exp(κ)',
      kind: 'derived', range: '(0, 1]', color: 'blue',
      derivedFrom: 'κ',
      what: `<p><strong>Integrity composite</strong> measures <em>multiplicative coherence</em>. It is the weighted geometric mean of all channel values — if any single channel is dead, IC crashes toward ε regardless of how healthy the others are.</p>
             <p>This is the "geometric slaughter" phenomenon. In an 8-channel system with 7 perfect channels and 1 dead channel, F stays at 0.875 but IC drops to 0.11. One rotten channel is enough.</p>
             <p class="text-xs text-kernel-500 mt-2">Latin: <em>cohaerentia multiplicativa</em> — multiplicative coherence. IC ≤ F is the <em>limbus integritatis</em> — the threshold where integrity approaches fidelity but cannot cross.</p>`,
      why: `<p>IC is <strong>derived</strong> from κ via IC = exp(κ), but it provides the most operationally important insight: <strong>the integrity bound IC ≤ F</strong>.</p>
            <p>This bound is the solvability condition: for n = 2 channels, the trace values c₁, c₂ = F ± √(F² − IC²). Real solutions require IC ≤ F. This is derived independently from Axiom-0 — it is NOT the classical AM-GM inequality (which is a degenerate limit when channel semantics are stripped away).</p>
            <p>IC also composes <strong>geometrically</strong>: IC₁₂ = √(IC₁ · IC₂), while F composes <strong>arithmetically</strong>: F₁₂ = (F₁ + F₂)/2. These composition laws have no classical analogue.</p>`,
      how: `<div class="bg-kernel-950 rounded-lg p-3 font-mono text-sm my-2">IC = exp(κ) = exp(Σ wᵢ ln(max(cᵢ, ε))) = ∏ max(cᵢ, ε)^wᵢ</div>
            <p>This is literally the weighted geometric mean of the ε-clamped channels. The exponential map converts additive log-coherence (κ) into multiplicative integrity (IC).</p>
            <p>The heterogeneity gap Δ = F − IC measures how much the geometric mean falls below the arithmetic mean due to channel heterogeneity.</p>`,
      connections: `<p><strong>IC ← κ:</strong> IC = exp(κ) by definition (identity E2).</p>
                    <p><strong>IC ≤ F:</strong> The integrity bound (identity E3 / solvability condition). Always holds. Equality iff all channels are identical.</p>
                    <p><strong>Δ = F − IC:</strong> The heterogeneity gap — central diagnostic. Large Δ means some channels are much weaker than others.</p>
                    <p><strong>IC < 0.30:</strong> Critical overlay — flags dangerous integrity loss regardless of regime.</p>
                    <p><strong>IC remains Tier-1:</strong> Appears in immutable identities (IC ≤ F). Not a diagnostic.</p>`
    },
  ];

  // ── Render invariant cards ────────────────────────

  const cardsContainer = document.getElementById('invariant-cards')!;
  const detailPanel = document.getElementById('invariant-detail')!;

  function renderCards() {
    cardsContainer.innerHTML = '';
    invariants.forEach((inv, i) => {
      const isPrimitive = inv.kind === 'primitive';
      const borderColor = isPrimitive ? 'border-amber-700 hover:border-amber-500' : 'border-blue-700 hover:border-blue-500';
      const dotColor = isPrimitive ? 'bg-amber-500' : 'bg-blue-400';
      const symColor = isPrimitive ? 'text-amber-400' : 'text-blue-400';

      const card = document.createElement('button');
      card.className = `inv-card bg-kernel-900 border-2 ${borderColor} rounded-xl p-4 text-left transition group cursor-pointer`;
      card.dataset.index = String(i);
      card.innerHTML = `
        <div class="flex items-center justify-between mb-1">
          <span class="text-2xl font-mono ${symColor}">${inv.symbol}</span>
          <span class="w-2.5 h-2.5 rounded-full ${dotColor}"></span>
        </div>
        <div class="text-sm font-bold text-kernel-200">${inv.name}</div>
        <div class="text-xs text-kernel-500 italic">${inv.latin}</div>
        <div class="text-[11px] text-kernel-600 font-mono mt-1">${inv.formula}</div>
        <div class="text-[10px] text-kernel-600 mt-2 group-hover:text-kernel-400 transition">Click to explore &rarr;</div>
      `;
      card.addEventListener('click', () => showInvariantDetail(i));
      cardsContainer.appendChild(card);
    });
  }

  // ── Show invariant detail ──────────────────────────

  let activeTab = 'what';
  let activeInvariantIndex = -1;

  function showInvariantDetail(index: number) {
    const inv = invariants[index];
    activeInvariantIndex = index;

    // Update header
    const symEl = document.getElementById('detail-symbol')!;
    const nameEl = document.getElementById('detail-name')!;
    const latinEl = document.getElementById('detail-latin')!;
    const badgeEl = document.getElementById('detail-badge')!;

