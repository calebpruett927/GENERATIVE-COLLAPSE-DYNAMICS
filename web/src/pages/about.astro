---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="About" description="What is Generative Collapse Dynamics? The axiom, the kernel, the spine — interactive onboarding.">
  <div class="max-w-5xl mx-auto">

    <!-- ═══ Hero ═══ -->
    <div class="text-center mb-16 relative">
      <div class="absolute inset-0 -z-10 opacity-20" id="hero-particles"></div>
      <p class="text-xs uppercase tracking-[0.3em] text-kernel-500 mb-4">Axiom-0</p>
      <h1 class="text-4xl md:text-5xl font-bold text-kernel-100 mb-5 leading-tight">
        Collapse is generative.<br/>
        <span class="text-amber-400">Only what returns is real.</span>
      </h1>
      <p class="text-sm text-kernel-500 italic mb-8">
        Collapsus generativus est; solum quod redit, reale est.
      </p>
      <div class="inline-flex gap-3">
        <a href="#kernel-section" class="bg-amber-600 hover:bg-amber-500 text-white px-5 py-2.5 rounded-lg text-sm font-bold transition">
          Explore the Kernel &darr;
        </a>
        <a href={`${base}calculator/`} class="border border-kernel-600 hover:border-kernel-400 text-kernel-300 hover:text-kernel-100 px-5 py-2.5 rounded-lg text-sm font-bold transition">
          Try the Calculator &rarr;
        </a>
      </div>
    </div>

    <!-- ═══ What is GCD? ═══ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-kernel-100 mb-6 border-b border-kernel-800 pb-2">What is GCD?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-4 text-kernel-300">
          <p>
            <strong class="text-kernel-100">Generative Collapse Dynamics</strong> is a
            mathematical framework that measures what survives collapse and what returns.
            It begins from a single axiom — <em class="text-amber-400">Axiom-0</em> — and derives a complete
            measurement protocol that works identically across 20 scientific domains,
            from particle physics to consciousness studies.
          </p>
          <p>
            The framework is implemented as <strong class="text-kernel-100">UMCP</strong>
            (Universal Measurement Contract Protocol), a reproducible validation system
            with frozen parameters that are <em>seam-derived</em> — discovered by the
            mathematics, not chosen by convention.
          </p>
        </div>
        <div class="bg-kernel-900 border border-kernel-800 rounded-xl p-5">
          <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-4">At a Glance</h3>
          <div class="grid grid-cols-2 gap-3">
            {[
              { n: '16,204', label: 'Tests', icon: '✓' },
              { n: '20', label: 'Domains', icon: '◈' },
              { n: '44', label: 'Identities', icon: '≡' },
              { n: '47', label: 'Lemmas', icon: '∴' },
              { n: '181', label: 'Closures', icon: '⊕' },
              { n: '3', label: 'Languages', icon: '⟨⟩' },
            ].map(s => (
              <div class="text-center py-2">
                <div class="text-2xl font-bold text-amber-400">{s.n}</div>
                <div class="text-xs text-kernel-500">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ The Kernel — Interactive ═══ -->
    <section class="mb-16" id="kernel-section">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">The Kernel</h2>
      <p class="text-kernel-400 text-sm mb-2">
        The kernel function <span class="font-mono text-kernel-300">K: [0,1]ⁿ × Δⁿ → (F, ω, S, C, κ, IC)</span> maps
        any trace vector to six invariants — but only <strong class="text-kernel-200">3 effective degrees of freedom</strong>.
      </p>
      <p class="text-kernel-500 text-xs italic mb-6">
        Click any invariant to learn what it measures, why it exists, and how it connects to the others.
      </p>

      <!-- Primitive vs Derived legend -->
      <div class="flex flex-wrap gap-4 mb-6 text-xs">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-amber-500 inline-block"></span>
          <span class="text-kernel-400">Primitive — computed directly from the trace vector</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-400 inline-block"></span>
          <span class="text-kernel-400">Derived — follows algebraically from a primitive</span>
        </div>
      </div>

      <!-- Invariant cards (clickable) -->
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4" id="invariant-cards">
        <!-- Populated by script -->
      </div>

      <!-- Expanded detail panel -->
      <div id="invariant-detail" class="hidden">
        <div class="bg-kernel-900 border border-kernel-700 rounded-xl overflow-hidden transition-all duration-300">
          <!-- Header -->
          <div class="p-5 border-b border-kernel-800" id="detail-header">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-3xl font-mono" id="detail-symbol"></span>
                <div>
                  <h3 class="text-lg font-bold text-kernel-100" id="detail-name"></h3>
                  <p class="text-xs italic text-kernel-500" id="detail-latin"></p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs px-2 py-1 rounded-full font-medium" id="detail-badge"></span>
                <button id="detail-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none">&times;</button>
              </div>
            </div>
          </div>
          <!-- Body tabs -->
          <div class="border-b border-kernel-800 flex text-xs" id="detail-tabs">
            <button data-tab="what" class="detail-tab px-4 py-2.5 text-amber-400 border-b-2 border-amber-400 font-medium">What</button>
            <button data-tab="why" class="detail-tab px-4 py-2.5 text-kernel-500 hover:text-kernel-300 transition">Why</button>
            <button data-tab="how" class="detail-tab px-4 py-2.5 text-kernel-500 hover:text-kernel-300 transition">How</button>
            <button data-tab="connections" class="detail-tab px-4 py-2.5 text-kernel-500 hover:text-kernel-300 transition">Connections</button>
          </div>
          <!-- Tab content -->
          <div class="p-5" id="detail-content"></div>
        </div>
      </div>

      <!-- Relationship diagram -->
      <div class="mt-6 bg-kernel-900 border border-kernel-800 rounded-xl p-5">
        <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-3">How the Six Invariants Relate</h3>
        <p class="text-xs text-kernel-500 mb-4">
          4 are <span class="text-amber-400 font-medium">primitive</span> (computed directly), 2 are <span class="text-blue-400 font-medium">derived</span> (follow algebraically).
          Together, they have only 3 effective degrees of freedom because S is asymptotically determined by F and C.
        </p>
        <div class="flex justify-center">
          <div class="relative w-full max-w-lg" id="relationship-diagram">
            <!-- SVG relationship diagram rendered by script -->
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ The Spine — Interactive ═══ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">The Spine</h2>
      <p class="text-kernel-300 mb-6">
        Every claim, validation, and discourse follows a fixed five-stop spine.
        <span class="text-kernel-500">Click each stop to see what happens there.</span>
      </p>

      <!-- Spine stops (clickable) -->
      <div class="flex flex-col md:flex-row items-stretch gap-2 mb-4" id="spine-stops">
        <!-- Populated by script -->
      </div>

      <!-- Spine detail -->
      <div id="spine-detail" class="hidden bg-kernel-900 border border-kernel-700 rounded-xl p-5 transition-all duration-300">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-bold text-kernel-100" id="spine-detail-title"></h3>
          <button id="spine-detail-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none">&times;</button>
        </div>
        <div id="spine-detail-body" class="text-sm text-kernel-300 space-y-3"></div>
      </div>
    </section>

    <!-- ═══ Three Regimes — Interactive ═══ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">Three Regimes</h2>
      <p class="text-kernel-300 mb-4">
        Regime classification is <em>derived</em> from gates on (ω, F, S, C) — never asserted.
        <span class="text-kernel-500">Click to explore each regime.</span>
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <button class="regime-card bg-kernel-900 border-2 border-green-800 hover:border-green-500 rounded-xl p-5 text-left transition group" data-regime="stable">
          <div class="flex items-center justify-between mb-2">
            <span class="text-lg font-bold text-green-400">Stable</span>
            <span class="text-2xl font-bold text-green-400/50 group-hover:text-green-400 transition">12.5%</span>
          </div>
          <div class="text-xs text-kernel-400">ω &lt; 0.038 ∧ F &gt; 0.90 ∧ S &lt; 0.15 ∧ C &lt; 0.14</div>
          <div class="text-xs text-kernel-600 mt-2">Click for details &rarr;</div>
        </button>
        <button class="regime-card bg-kernel-900 border-2 border-yellow-800 hover:border-yellow-500 rounded-xl p-5 text-left transition group" data-regime="watch">
          <div class="flex items-center justify-between mb-2">
            <span class="text-lg font-bold text-yellow-400">Watch</span>
            <span class="text-2xl font-bold text-yellow-400/50 group-hover:text-yellow-400 transition">24.4%</span>
          </div>
          <div class="text-xs text-kernel-400">0.038 ≤ ω &lt; 0.30 (or Stable gates not all met)</div>
          <div class="text-xs text-kernel-600 mt-2">Click for details &rarr;</div>
        </button>
        <button class="regime-card bg-kernel-900 border-2 border-red-800 hover:border-red-500 rounded-xl p-5 text-left transition group" data-regime="collapse">
          <div class="flex items-center justify-between mb-2">
            <span class="text-lg font-bold text-red-400">Collapse</span>
            <span class="text-2xl font-bold text-red-400/50 group-hover:text-red-400 transition">63.1%</span>
          </div>
          <div class="text-xs text-kernel-400">ω ≥ 0.30</div>
          <div class="text-xs text-kernel-600 mt-2">Click for details &rarr;</div>
        </button>
      </div>

      <div id="regime-detail" class="hidden bg-kernel-900 border border-kernel-700 rounded-xl p-5 transition-all duration-300">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-bold" id="regime-detail-title"></h3>
          <button id="regime-detail-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none">&times;</button>
        </div>
        <div id="regime-detail-body" class="text-sm text-kernel-300 space-y-3"></div>
      </div>

      <!-- Fisher space bar -->
      <div class="mt-4 bg-kernel-900 border border-kernel-800 rounded-xl p-4">
        <p class="text-xs text-kernel-500 mb-2">Fisher Space Partition</p>
        <div class="h-6 rounded-full overflow-hidden flex">
          <div class="bg-green-600 flex items-center justify-center text-[10px] text-white font-bold" style="width:12.5%">12.5%</div>
          <div class="bg-yellow-600 flex items-center justify-center text-[10px] text-white font-bold" style="width:24.4%">24.4%</div>
          <div class="bg-red-600 flex items-center justify-center text-[10px] text-white font-bold" style="width:63.1%">63.1%</div>
        </div>
        <p class="text-xs text-kernel-500 mt-2 italic">
          Stability is rare — 87.5% of the manifold lies outside it.
          Return from collapse to stability is what the axiom measures.
        </p>
      </div>
    </section>

    <!-- ═══ Five Words ═══ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">The Five Words</h2>
      <p class="text-kernel-300 mb-4">
        The minimal prose vocabulary for telling the story of any collapse-return cycle.
        <span class="text-kernel-500">Click a word to see its ledger role and operational definition.</span>
      </p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-4" id="five-words-grid">
        <!-- Populated by script -->
      </div>
      <div id="word-detail" class="hidden bg-kernel-900 border border-kernel-700 rounded-xl p-5 transition-all duration-300">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-bold text-kernel-100" id="word-detail-title"></h3>
          <button id="word-detail-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none">&times;</button>
        </div>
        <div id="word-detail-body" class="text-sm text-kernel-300 space-y-3"></div>
      </div>
    </section>

    <!-- ═══ Architecture — Interactive ═══ -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">Three-Tier Architecture</h2>
      <p class="text-kernel-300 mb-6">
        Every symbol, function, and artifact belongs to exactly one tier. <span class="text-kernel-500">Click to understand each layer.</span>
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4" id="tier-cards">
        <!-- Populated by script -->
      </div>
      <div id="tier-detail" class="hidden bg-kernel-900 border border-kernel-700 rounded-xl p-5 transition-all duration-300">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-lg font-bold text-kernel-100" id="tier-detail-title"></h3>
          <button id="tier-detail-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none">&times;</button>
        </div>
        <div id="tier-detail-body" class="text-sm text-kernel-300 space-y-3"></div>
      </div>
      <!-- Dependency arrow -->
      <div class="bg-kernel-900 border border-kernel-800 rounded-xl p-4 text-center">
        <p class="text-xs text-kernel-500 mb-2">One-Way Dependency (No Back-Edges)</p>
        <div class="flex items-center justify-center gap-2 text-kernel-400 font-mono text-sm">
          <span class="px-3 py-1 bg-kernel-800 rounded text-amber-400">Tier-1</span>
          <span>&rarr;</span>
          <span class="px-3 py-1 bg-kernel-800 rounded text-blue-400">Tier-0</span>
          <span>&rarr;</span>
          <span class="px-3 py-1 bg-kernel-800 rounded text-green-400">Tier-2</span>
        </div>
        <p class="text-[10px] text-kernel-600 mt-2">No feedback from Tier-2 to Tier-1 or Tier-0 within a frozen run.</p>
      </div>
    </section>

    <!-- ═══ Test Count — Compounding Structure ═══ -->
    <section class="mb-16" id="tests-section">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">16,204 Tests</h2>
      <p class="text-kernel-300 mb-6">
        Not 16,204 separate assertions — <strong class="text-kernel-100">compounding parametrized sweeps</strong> across 20 domains.
        <span class="text-kernel-500">~800 base test functions expand 18× through domain × entity × configuration parametrization.</span>
      </p>

      <!-- How compounding works -->
      <div class="bg-kernel-900 border border-kernel-800 rounded-xl p-5 mb-6">
        <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-4">How Test Compounding Works</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div class="text-center p-4 bg-kernel-950 rounded-lg">
            <div class="text-3xl font-bold text-amber-400 mb-1">~800</div>
            <div class="text-xs text-kernel-400">Base test functions</div>
            <div class="text-[10px] text-kernel-600 mt-1">Written once per pattern</div>
          </div>
          <div class="text-center p-4 bg-kernel-950 rounded-lg relative">
            <div class="absolute -left-3 top-1/2 -translate-y-1/2 text-kernel-600 hidden md:block">×</div>
            <div class="text-3xl font-bold text-blue-400 mb-1">~18×</div>
            <div class="text-xs text-kernel-400">Parametrization factor</div>
            <div class="text-[10px] text-kernel-600 mt-1">Domain × entity × config</div>
          </div>
          <div class="text-center p-4 bg-kernel-950 rounded-lg relative">
            <div class="absolute -left-3 top-1/2 -translate-y-1/2 text-kernel-600 hidden md:block">=</div>
            <div class="text-3xl font-bold text-green-400 mb-1">16,204</div>
            <div class="text-xs text-kernel-400">Collected test items</div>
            <div class="text-[10px] text-kernel-600 mt-1">Every invariant, every domain</div>
          </div>
        </div>

        <!-- Visual example -->
        <div class="bg-kernel-950 rounded-lg p-4">
          <p class="text-xs text-kernel-500 mb-3 font-medium uppercase tracking-wider">Example: One Tier-1 identity test compounds across 20 domains</p>
          <div class="font-mono text-xs space-y-1">
            <div class="text-kernel-500"># One parametrized test function:</div>
            <div class="text-amber-400">@pytest.mark.parametrize("domain", ALL_20_DOMAINS)</div>
            <div class="text-kernel-300">def test_duality_identity(domain):</div>
            <div class="text-kernel-400 pl-4">traces = domain.get_all_entities()  <span class="text-kernel-600"># 12–118 entities each</span></div>
            <div class="text-kernel-400 pl-4">for trace in traces:</div>
            <div class="text-kernel-400 pl-8">F, ω = kernel(trace)</div>
            <div class="text-green-400 pl-8">assert abs(F + ω - 1) == 0.0  <span class="text-kernel-600"># Exact to 0.0e+00</span></div>
          </div>
          <div class="mt-3 flex items-center gap-2 text-[10px]">
            <span class="text-kernel-500">→ 1 function</span>
            <span class="text-kernel-600">×</span>
            <span class="text-kernel-500">20 domains</span>
            <span class="text-kernel-600">×</span>
            <span class="text-kernel-500">12–118 entities</span>
            <span class="text-kernel-600">=</span>
            <span class="text-amber-400 font-bold">hundreds of assertions from one test</span>
          </div>
        </div>
      </div>

      <!-- Domain breakdown -->
      <div class="bg-kernel-900 border border-kernel-800 rounded-xl p-5">
        <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-4">Test Distribution by Domain</h3>
        <p class="text-kernel-500 text-xs mb-4">Click a tier to see its test domains.</p>
        <div class="flex gap-2 mb-4" id="test-tier-tabs">
          <button data-tier="protocol" class="test-tier-tab px-3 py-1.5 bg-blue-900/30 border border-blue-700 hover:border-blue-500 text-blue-400 rounded-lg text-xs font-medium transition cursor-pointer">Tier-0 Protocol</button>
          <button data-tier="core" class="test-tier-tab px-3 py-1.5 bg-amber-900/30 border border-amber-700 hover:border-amber-500 text-amber-400 rounded-lg text-xs font-medium transition cursor-pointer">Tier-1 Core</button>
          <button data-tier="domains" class="test-tier-tab px-3 py-1.5 bg-green-900/30 border border-green-700 hover:border-green-500 text-green-400 rounded-lg text-xs font-medium transition cursor-pointer">Tier-2 Domains</button>
        </div>
        <div id="test-tier-content" class="space-y-2"></div>
        <!-- Bar chart -->
        <div class="mt-4 pt-4 border-t border-kernel-800">
          <p class="text-xs text-kernel-500 mb-2">187 test files, numbered <span class="font-mono text-kernel-400">test_000</span> through <span class="font-mono text-kernel-400">test_293</span></p>
          <div class="h-4 rounded-full overflow-hidden flex">
            <div class="bg-blue-600 flex items-center justify-center text-[8px] text-white font-bold" style="width:15%">Proto</div>
            <div class="bg-amber-600 flex items-center justify-center text-[8px] text-white font-bold" style="width:25%">Core</div>
            <div class="bg-green-600 flex items-center justify-center text-[8px] text-white font-bold" style="width:60%">Domains</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ 44 Structural Identities ═══ -->
    <section class="mb-16" id="identities-section">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">44 Structural Identities</h2>
      <p class="text-kernel-300 mb-6">
        All derived from Axiom-0 and verified to <strong class="text-amber-400">machine precision</strong>.
        They fall into four series. <span class="text-kernel-500">Click a series to see its identities and what they prove.</span>
      </p>

      <!-- Series cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4" id="identity-series-cards">
        <!-- Populated by script -->
      </div>

      <!-- Identity detail panel -->
      <div id="identity-series-detail" class="hidden bg-kernel-900 border border-kernel-700 rounded-xl overflow-hidden transition-all duration-300">
        <div class="p-5 border-b border-kernel-800">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-kernel-100" id="identity-series-title"></h3>
            <button id="identity-series-close" class="text-kernel-500 hover:text-kernel-300 transition text-xl leading-none cursor-pointer">&times;</button>
          </div>
        </div>
        <div class="p-5" id="identity-series-body"></div>
      </div>

      <!-- Connection Clusters -->
      <div class="mt-6 bg-kernel-900 border border-kernel-800 rounded-xl p-5">
        <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-4">6 Connection Clusters</h3>
        <p class="text-xs text-kernel-500 mb-4">The 44 identities form a connected network. These clusters reveal the deep structure.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="cluster-grid">
          <!-- Populated by script -->
        </div>
      </div>

      <!-- Link to full page -->
      <div class="mt-4 text-center">
        <a href={`${base}identities/`} class="text-sm text-amber-400 hover:text-amber-300 transition font-medium">
          Explore all 44 identities in detail &rarr;
        </a>
      </div>
    </section>

    <!-- ═══ Three Languages ═══ -->
    <section class="mb-16" id="languages-section">
      <h2 class="text-2xl font-bold text-kernel-100 mb-2 border-b border-kernel-800 pb-2">Three Languages, One Kernel</h2>
      <p class="text-kernel-300 mb-6">
        The same kernel function <span class="font-mono text-kernel-400">K: [0,1]ⁿ × Δⁿ → (F, ω, S, C, κ, IC)</span> is implemented in three languages —
        each serving a distinct architectural role. <span class="text-kernel-500">Click to explore each layer.</span>
      </p>

      <!-- Language cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <button class="lang-card bg-kernel-900 border-2 border-yellow-700 hover:border-yellow-500 rounded-xl p-5 text-left transition group cursor-pointer" data-lang="c">
          <div class="flex items-center justify-between mb-3">
            <span class="text-2xl font-bold text-yellow-400 font-mono">C99</span>
            <span class="text-xs px-2 py-1 bg-yellow-900/50 text-yellow-400 rounded-full">Foundation</span>
          </div>
          <div class="text-sm text-kernel-300 mb-2">The spine in portable C99</div>
          <div class="grid grid-cols-2 gap-2 text-center">
            <div><div class="text-lg font-bold text-kernel-200">~1,900</div><div class="text-[10px] text-kernel-500">Lines</div></div>
            <div><div class="text-lg font-bold text-kernel-200">326</div><div class="text-[10px] text-kernel-500">Assertions</div></div>
          </div>
          <div class="text-[10px] text-kernel-600 mt-3 group-hover:text-kernel-400 transition">Click for details &rarr;</div>
        </button>
        <button class="lang-card bg-kernel-900 border-2 border-cyan-700 hover:border-cyan-500 rounded-xl p-5 text-left transition group cursor-pointer" data-lang="cpp">
          <div class="flex items-center justify-between mb-3">
