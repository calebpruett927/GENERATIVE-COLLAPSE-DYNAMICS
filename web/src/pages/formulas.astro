    <!-- ═══════════ §11: EXAMPLE EXPRESSIONS ═══════════ -->
    <section id="expressions" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Example Expressions</h2>
      <p class="text-xs text-kernel-500 mb-4 italic">Try these in the builder above. Organized by category.</p>

      <!-- Core Identities -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Core Identities</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-green-400">F + omega</code>
              <span class="text-kernel-500 block mt-1">Duality identity (AI-1) &mdash; always exactly 1</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-green-400">exp(kappa) - IC</code>
              <span class="text-kernel-500 block mt-1">Log-integrity relation (AI-3) &mdash; always 0</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-green-400">F - IC</code>
              <span class="text-kernel-500 block mt-1">Heterogeneity gap &Delta; (AI-2) &mdash; always &ge; 0</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-green-400">1 - F - omega</code>
              <span class="text-kernel-500 block mt-1">Residual check &mdash; should be exactly 0</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Coherence & Gap -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Coherence &amp; Gap Analysis</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-cyan-400">IC / F</code>
              <span class="text-kernel-500 block mt-1">Coherence ratio &mdash; 1.0 = homogeneous, low = geometric slaughter</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-cyan-400">1 - IC / F</code>
              <span class="text-kernel-500 block mt-1">Fractional IC deficit (I-E3) &mdash; = Var(c)/(2F&sup2;)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-cyan-400">C**2 / (8 * F)</code>
              <span class="text-kernel-500 block mt-1">Gap Taylor approximation (I-B9) &mdash; compare with F &minus; IC</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-cyan-400">sqrt(F**2 - C**2/4)</code>
              <span class="text-kernel-500 block mt-1">Rank-2 IC closed form (I-A6) &mdash; exact for 2-channel systems</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Entropy & Coupling -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Entropy &amp; Coupling</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-amber-400">S + kappa</code>
              <span class="text-kernel-500 block mt-1">Coupling function &mdash; zero at equator (c = &frac12;)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-amber-400">-F * log(F) - (1-F) * log(1-F)</code>
              <span class="text-kernel-500 block mt-1">Homogeneous entropy h(F) &mdash; upper bound for S (I-B4)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-amber-400">log(F) - C**2 / (8 * F**2)</code>
              <span class="text-kernel-500 block mt-1">&kappa; Taylor approximation (I-B3) &mdash; compare with kappa</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-amber-400">S - (-F*log(F) - (1-F)*log(1-F))</code>
              <span class="text-kernel-500 block mt-1">Entropy deficit &mdash; always &le; 0 (Jensen bound I-B4)</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Drift Cost & Budget -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Drift Cost &amp; Seam Budget</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-red-400">omega**3 / (1 - omega + 1e-8)</code>
              <span class="text-kernel-500 block mt-1">&Gamma;(&omega;) &mdash; drift cost with Cardano exponent p = 3</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-red-400">omega * (3 - 2*omega) / (1 - omega)</code>
              <span class="text-kernel-500 block mt-1">Cost elasticity &varepsilon;<sub>&Gamma;</sub> (I-C6) &mdash; approaches 4 near pole</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-red-400">omega**3/(1-omega+1e-8) + 1.0 * C</code>
              <span class="text-kernel-500 block mt-1">Total cost &Gamma;(&omega;) + D<sub>C</sub> &mdash; drift + curvature</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-red-400">omega**3/(1-omega+1e-8) * (1-omega)**3/((omega)+1e-8)</code>
              <span class="text-kernel-500 block mt-1">Cost cross-product (I-E1) &mdash; = [&omega;(1&minus;&omega;)]&sup2; for p=3</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Fisher Geometry -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Fisher Geometry</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-purple-400">1 / (F * (1 - F))</code>
              <span class="text-kernel-500 block mt-1">Fisher metric g<sub>F</sub>(F) = 1/[F(1&minus;F)] (I-A3)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-purple-400">-1 / (F * (1 - F)) - 1 / F**2</code>
              <span class="text-kernel-500 block mt-1">Coupling curvature f''(c) = &minus;g<sub>F</sub> &minus; 1/c&sup2; (I-B5)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-purple-400">2 * kappa</code>
              <span class="text-kernel-500 block mt-1">&kappa; as log-sine: 2&Sigma; w<sub>i</sub> ln|sin &theta;| (I-A5)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-purple-400">log(4 / (F * (1-F)))</code>
              <span class="text-kernel-500 block mt-1">Fisher volume proxy: ln(4&middot;g<sub>F</sub>) (I-B13)</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Regime Detection -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Regime Detection</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-blue-400">omega &lt; 0.038</code>
              <span class="text-kernel-500 block mt-1">Stable drift gate (1 if met)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-blue-400">omega &ge; 0.30</code>
              <span class="text-kernel-500 block mt-1">Collapse gate (1 if in collapse)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-blue-400">IC &lt; 0.30</code>
              <span class="text-kernel-500 block mt-1">Critical overlay (1 if critical)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-blue-400">omega**3/(1-omega+1e-8) &ge; 1.0</code>
              <span class="text-kernel-500 block mt-1">Trapped (1 if &Gamma; &ge; &alpha;, no single-step escape)</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Key Lemmas -->
      <div class="mb-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Key Lemma Expressions</h3>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-yellow-400">IC * (1/F)</code>
              <span class="text-kernel-500 block mt-1">L-6 sensitivity: &part;IC/&part;c<sub>k</sub> &prop; IC&middot;w<sub>k</sub>/c<sub>k</sub></span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-yellow-400">(1 - IC/F) * 2 * F**2</code>
              <span class="text-kernel-500 block mt-1">Computes Var(c) from departure formula (I-E3)</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-yellow-400">(F - IC) / F</code>
              <span class="text-kernel-500 block mt-1">Normalized heterogeneity &mdash; fraction of F lost to gap</span>
            </div>
            <div class="bg-kernel-800/50 rounded p-3">
              <code class="text-yellow-400">exp(log(F) - C**2/(8*F**2))</code>
              <span class="text-kernel-500 block mt-1">IC from &kappa; Taylor (I-B3): exp(ln F &minus; C&sup2;/(8F&sup2;))</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ §12: REFERENCE ═══════════ -->
    <section id="reference" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Variable Reference</h2>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5">
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-kernel-500 border-b border-kernel-700">
                <th class="text-left p-2">Variable</th>
                <th class="text-left p-2">Symbol</th>
                <th class="text-left p-2">Range</th>
                <th class="text-left p-2">Description</th>
                <th class="text-left p-2">Formula</th>
              </tr>
            </thead>
            <tbody class="text-kernel-400">
              <tr class="border-b border-kernel-800"><td class="p-2 font-mono text-green-400">F</td><td class="p-2">F</td><td class="p-2">[0, 1]</td><td class="p-2">Fidelity &mdash; what survives collapse</td><td class="p-2 font-mono text-kernel-500">&Sigma; w<sub>i</sub>c<sub>i</sub></td></tr>
              <tr class="border-b border-kernel-800"><td class="p-2 font-mono text-red-400">omega</td><td class="p-2">&omega;</td><td class="p-2">[0, 1]</td><td class="p-2">Drift &mdash; what is lost</td><td class="p-2 font-mono text-kernel-500">1 &minus; F</td></tr>
              <tr class="border-b border-kernel-800"><td class="p-2 font-mono text-amber-400">S</td><td class="p-2">S</td><td class="p-2">&ge; 0</td><td class="p-2">Bernoulli field entropy</td><td class="p-2 font-mono text-kernel-500">&minus;&Sigma; w<sub>i</sub>[c<sub>i</sub>ln c<sub>i</sub> + (1&minus;c<sub>i</sub>)ln(1&minus;c<sub>i</sub>)]</td></tr>
              <tr class="border-b border-kernel-800"><td class="p-2 font-mono text-purple-400">C</td><td class="p-2">C</td><td class="p-2">[0, 1]</td><td class="p-2">Curvature &mdash; coupling to DOF</td><td class="p-2 font-mono text-kernel-500">stddev(c<sub>i</sub>) / 0.5</td></tr>
              <tr class="border-b border-kernel-800"><td class="p-2 font-mono text-cyan-400">kappa</td><td class="p-2">&kappa;</td><td class="p-2">&le; 0</td><td class="p-2">Log-integrity</td><td class="p-2 font-mono text-kernel-500">&Sigma; w<sub>i</sub> ln(c<sub>i,&varepsilon;</sub>)</td></tr>
              <tr><td class="p-2 font-mono text-blue-400">IC</td><td class="p-2">IC</td><td class="p-2">(0, 1]</td><td class="p-2">Integrity composite</td><td class="p-2 font-mono text-kernel-500">exp(&kappa;)</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-kernel-600 mt-3 text-center italic">
          All variables are computed from the trace vector c &isin; [0,1]&#8319; with weights w &isin; &Delta;&#8319;.
          The kernel has 3 effective degrees of freedom: F, &kappa;, C.
        </p>
      </div>
    </section>

