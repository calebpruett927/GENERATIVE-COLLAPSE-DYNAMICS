---
import BaseLayout from '../layouts/BaseLayout.astro';
import LedgerViewer from '../components/LedgerViewer.astro';
const sections = ['purpose', 'domains', 'viewer', 'budget', 'identities', 'comparison', 'spine'];
---

<BaseLayout title="Integrity Ledger — GCD" description="Domain overview, kernel metrics, budget reconciliation, identity verification, and cross-domain integrity ledger for all 246 closure modules domains.">
  <div class="max-w-6xl mx-auto">

    <!-- ═══════════ HERO ═══════════ -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Integrity Ledger</h1>
      <p class="text-kernel-400 text-lg italic">Auditus praecedit responsum — hearing precedes response.</p>
      <p class="text-kernel-500 text-sm mt-2 max-w-3xl">
        The ledger is the fourth stop on the spine: it debits Drift and Roughness,
        credits Return, and derives the verdict. This page shows the kernel metrics
        for all 246 closure modules domains — where each domain stands, how they compare,
        and where the heterogeneity gap reveals structural insight.
      </p>
    </div>

    <!-- ═══════════ NAV ═══════════ -->
    <nav class="mb-8 flex flex-wrap gap-2">
      {sections.map(s => (
        <a href={`#${s}`} class="px-3 py-1.5 rounded-full text-xs font-medium
          bg-kernel-800/60 text-kernel-400 hover:text-kernel-200 hover:bg-kernel-700/60
          border border-kernel-700/40 transition no-underline">
          {s === 'viewer' ? 'Domain Ledger' : s === 'budget' ? 'Budget Simulator' : s === 'identities' ? 'Identity Check' : s === 'comparison' ? 'Cross-Domain' : s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
        </a>
      ))}
    </nav>

    <!-- ═══════════ §1: PURPOSE ═══════════ -->
    <section id="purpose" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">What the Ledger Does</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <h3 class="text-sm font-bold text-red-400 mb-2">Debit Side</h3>
          <ul class="text-xs text-kernel-400 space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-red-400 shrink-0 font-mono">D<sub>ω</sub></span>
              <span><strong class="text-kernel-300">Drift cost</strong> — Γ(ω) = ω<sup>3</sup>/(1 − ω + ε). How far the system departed from fidelity.</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-red-400 shrink-0 font-mono">D<sub>C</sub></span>
              <span><strong class="text-kernel-300">Curvature cost</strong> — α · C where α = 1.0. Friction from coupling to uncontrolled degrees of freedom.</span>
            </li>
          </ul>
        </div>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <h3 class="text-sm font-bold text-emerald-400 mb-2">Credit Side</h3>
          <ul class="text-xs text-kernel-400 space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-emerald-400 shrink-0 font-mono">R·τ<sub>R</sub></span>
              <span><strong class="text-kernel-300">Return credit</strong> — Credible re-entry, typed and timestamped. Exactly zero if τ<sub>R</sub> = ∞<sub>rec</sub>.</span>
            </li>
          </ul>
          <div class="mt-3 text-xs text-kernel-500 bg-kernel-800/50 rounded p-2 font-mono">
            Δκ = R·τ<sub>R</sub> − (D<sub>ω</sub> + D<sub>C</sub>)
          </div>
        </div>
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4">
          <h3 class="text-sm font-bold text-amber-400 mb-2">Reconciliation</h3>
          <ul class="text-xs text-kernel-400 space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-amber-400 shrink-0">▸</span>
              <span>If |Δκ| ≤ tol<sub>seam</sub> (0.005): the seam <strong class="text-emerald-400">closes</strong> → SUTURA</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-400 shrink-0">▸</span>
              <span>If |Δκ| > tol<sub>seam</sub>: the claim is a <strong class="text-red-400">gesture</strong> → GESTUS</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-amber-400 shrink-0">▸</span>
              <span>History is <strong class="text-kernel-200">append-only</strong> and welded, never rewritten</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-4 bg-kernel-900/50 border border-kernel-800 rounded-lg p-4">
        <h3 class="text-sm font-bold text-kernel-300 mb-2">Three-Valued Verdict</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-center">
          <div class="bg-green-900/20 border border-green-700/30 rounded p-2">
            <div class="text-green-400 font-bold">CONFORMANT</div>
            <div class="text-kernel-500 mt-1">Budget closes, all gates pass, identities hold</div>
          </div>
          <div class="bg-red-900/20 border border-red-700/30 rounded p-2">
            <div class="text-red-400 font-bold">NONCONFORMANT</div>
            <div class="text-kernel-500 mt-1">Budget fails, identity violated, or gate crossed</div>
          </div>
          <div class="bg-yellow-900/20 border border-yellow-700/30 rounded p-2">
            <div class="text-yellow-400 font-bold">NON_EVALUABLE</div>
            <div class="text-kernel-500 mt-1">Insufficient data — the third state, always available</div>
          </div>
        </div>
        <p class="text-xs text-kernel-600 italic text-center mt-2">
          Numquam binarius; tertia via semper patet. — Never boolean; the third way is always open.
        </p>
      </div>
    </section>

    <!-- ═══════════ §2: THE 23 DOMAINS ═══════════ -->
    <section id="domains" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">The 21 Closure Domains</h2>
      <p class="text-sm text-kernel-400 mb-4">
        Each domain selects which real-world quantities become trace vector channels.
        The kernel function is the same everywhere — Tier-246 closure modules choose the <em>input</em>;
        Tier-1 computes the <em>output</em>. The ledger records both.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-2">
        {[
          { id: 'gcd', label: 'GCD', cat: 'Core' },
          { id: 'rcft', label: 'RCFT', cat: 'Core' },
          { id: 'kinematics', label: 'Kinematics', cat: 'Physics' },
          { id: 'weyl', label: 'Weyl', cat: 'Physics' },
          { id: 'astronomy', label: 'Astronomy', cat: 'Physics' },
          { id: 'nuclear_physics', label: 'Nuclear', cat: 'Physics' },
          { id: 'quantum_mechanics', label: 'Quantum', cat: 'Physics' },
          { id: 'atomic_physics', label: 'Atomic', cat: 'Physics' },
          { id: 'everyday_physics', label: 'Everyday', cat: 'Physics' },
          { id: 'standard_model', label: 'Std Model', cat: 'Physics' },
          { id: 'spacetime_memory', label: 'Spacetime', cat: 'Physics' },
          { id: 'materials_science', label: 'Materials', cat: 'Material' },
          { id: 'finance', label: 'Finance', cat: 'Social' },
          { id: 'security', label: 'Security', cat: 'Social' },
          { id: 'evolution', label: 'Evolution', cat: 'Bio' },
          { id: 'consciousness_coherence', label: 'Consciousness', cat: 'Neuro' },
          { id: 'awareness_cognition', label: 'Awareness', cat: 'Neuro' },
          { id: 'clinical_neuroscience', label: 'Clinical', cat: 'Neuro' },
          { id: 'dynamic_semiotics', label: 'Semiotics', cat: 'Language' },
          { id: 'continuity_theory', label: 'Continuity', cat: 'Theory' },
          { id: 'immunology', label: 'Immunology', cat: 'Bio' },
        ].map(d => {
          const catColors = {
            Core: 'border-amber-700/40', Physics: 'border-blue-700/40',
            Material: 'border-cyan-700/40', Social: 'border-emerald-700/40',
            Bio: 'border-green-700/40', Neuro: 'border-purple-700/40',
            Language: 'border-orange-700/40', Theory: 'border-kernel-600/40'
          };
          const colorClass = (catColors as any)[d.cat] || 'border-kernel-700/30';
          return (
            <div class={`bg-kernel-800/50 border ${colorClass} rounded px-2 py-1.5 text-xs text-kernel-400`}>
              <span class="font-mono">{d.label}</span>
              <span class="text-kernel-600 ml-1 text-[10px]">{d.cat}</span>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ═══════════ §3: INTERACTIVE VIEWER ═══════════ -->
    <section id="viewer" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Domain Ledger</h2>
      <LedgerViewer />
    </section>

    <!-- ═══════════ §4: BUDGET SIMULATOR ═══════════ -->
    <section id="budget" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Budget Reconciliation Simulator</h2>
      <p class="text-sm text-kernel-400 mb-4">
        Simulate the seam budget for any custom scenario. Adjust drift cost, curvature cost,
        return magnitude, and return time to see whether the seam closes.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Budget inputs -->
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5 space-y-4">
          <div class="text-sm font-bold text-kernel-300 mb-2">Budget Parameters</div>
          <div>
            <label class="text-xs text-kernel-500 block mb-1">ω (Drift) — drives D<sub>ω</sub> = Γ(ω) = ω³/(1 − ω + ε)</label>
            <input id="sim-omega" type="range" min="0" max="0.99" step="0.01" value="0.15" class="w-full accent-red-400" />
            <div class="flex justify-between text-xs mt-1">
              <span id="sim-omega-val" class="text-red-400 font-mono">0.15</span>
              <span id="sim-dw-val" class="text-kernel-500 font-mono">D<sub>ω</sub> = 0.0040</span>
            </div>
          </div>
          <div>
            <label class="text-xs text-kernel-500 block mb-1">C (Curvature) — drives D<sub>C</sub> = α · C</label>
            <input id="sim-curv" type="range" min="0" max="1" step="0.01" value="0.10" class="w-full accent-orange-400" />
            <div class="flex justify-between text-xs mt-1">
              <span id="sim-curv-val" class="text-orange-400 font-mono">0.10</span>
              <span id="sim-dc-val" class="text-kernel-500 font-mono">D<sub>C</sub> = 0.1000</span>
            </div>
          </div>
          <div>
            <label class="text-xs text-kernel-500 block mb-1">R (Return magnitude)</label>
            <input id="sim-r" type="range" min="0" max="1" step="0.01" value="0.30" class="w-full accent-blue-400" />
            <span id="sim-r-val" class="text-xs text-blue-400 font-mono">0.30</span>
          </div>
          <div>
            <label class="text-xs text-kernel-500 block mb-1">τ<sub>R</sub> (Return time factor)</label>
            <div class="flex gap-2 items-center">
              <input id="sim-tau" type="range" min="0.1" max="5" step="0.1" value="1.0" class="flex-1 accent-emerald-400" />
              <label class="flex items-center gap-1 text-xs text-kernel-500">
                <input type="checkbox" id="sim-inf" class="accent-red-400" />
                ∞<sub>rec</sub>
              </label>
            </div>
            <span id="sim-tau-val" class="text-xs text-emerald-400 font-mono">1.0</span>
          </div>
        </div>
        <!-- Budget result -->
        <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5">
          <div class="text-sm font-bold text-kernel-300 mb-3">Reconciliation Result</div>
          <div id="sim-result" class="space-y-3">
            <!-- filled by script -->
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ §5: IDENTITY VERIFICATION ═══════════ -->
    <section id="identities" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Identity Verification</h2>
      <p class="text-sm text-kernel-400 mb-4">
        Enter a trace vector to verify all three algebraic identities in real-time.
        These identities must hold for <em>any</em> valid trace — they are provable from Axiom-0.
      </p>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5">
        <div class="mb-4">
          <label class="text-xs text-kernel-500 block mb-1">Trace vector (comma-separated values in [0, 1])</label>
          <input id="id-trace" type="text" value="0.95, 0.80, 0.60, 0.90, 0.75, 0.85"
            class="w-full bg-kernel-950 border border-kernel-700 rounded px-3 py-2 text-sm text-kernel-200 font-mono" />
          <p class="text-xs text-kernel-600 mt-1">Equal weights applied automatically. Edit to test any configuration.</p>
        </div>
        <div id="id-results" class="space-y-3">
          <!-- filled by script -->
        </div>
      </div>
    </section>

    <!-- ═══════════ §6: CROSS-DOMAIN COMPARISON ═══════════ -->
    <section id="comparison" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Cross-Domain Comparison</h2>
      <p class="text-sm text-kernel-400 mb-4">
        Select two domains to compare their kernel metrics side by side. The heterogeneity gap (Δ = F − IC)
        reveals where each domain's channels diverge — and what it costs multiplicative coherence.
      </p>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5">
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <label class="text-xs text-kernel-500 block mb-1">Domain A</label>
            <select id="cmp-a" class="w-full bg-kernel-950 border border-kernel-700 rounded px-3 py-2 text-sm text-kernel-200">
            </select>
          </div>
          <div>
            <label class="text-xs text-kernel-500 block mb-1">Domain B</label>
            <select id="cmp-b" class="w-full bg-kernel-950 border border-kernel-700 rounded px-3 py-2 text-sm text-kernel-200">
            </select>
          </div>
        </div>
        <div id="cmp-result" class="space-y-3">
          <!-- filled by script -->
        </div>
      </div>
    </section>

    <!-- ═══════════ §7: THE SPINE ═══════════ -->
    <section id="spine" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">The Ledger in the Spine</h2>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-5">
        <div class="flex flex-wrap justify-center gap-2 text-xs font-mono mb-4">
          <span class="px-3 py-1.5 bg-kernel-800 border border-kernel-700 rounded text-kernel-400">Contract</span>
          <span class="text-kernel-600">&rarr;</span>
          <span class="px-3 py-1.5 bg-kernel-800 border border-kernel-700 rounded text-kernel-400">Canon</span>
          <span class="text-kernel-600">&rarr;</span>
          <span class="px-3 py-1.5 bg-kernel-800 border border-kernel-700 rounded text-kernel-400">Closures</span>
          <span class="text-kernel-600">&rarr;</span>
          <span class="px-3 py-1.5 bg-amber-900/40 border border-amber-700/50 rounded text-amber-400 font-bold">Integrity Ledger</span>
          <span class="text-kernel-600">&rarr;</span>
          <span class="px-3 py-1.5 bg-kernel-800 border border-kernel-700 rounded text-kernel-400">Stance</span>
        </div>
        <p class="text-xs text-kernel-400 text-center max-w-xl mx-auto">
          The Integrity Ledger is the <strong class="text-kernel-300">fourth stop</strong> on the
          spine. Everything before it produces data (Contract freezes, Canon narrates, Closures gate).
          The Ledger <em>reconciles</em> — it is the proof that the sentence is well-formed.
          The Stance that follows is read from the reconciled ledger, never asserted independently.
        </p>
        <p class="text-xs text-kernel-600 italic text-center mt-3">
          Continuitas non narratur: mensuratur. — Continuity is not narrated: it is measured.
        </p>
      </div>
    </section>

    <!-- ═══════════ AGGREGATE STATS ═══════════ -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Aggregate Statistics</h2>
      <div id="agg-stats" class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <!-- filled by script -->
      </div>
    </section>

    <!-- Footer -->
    <div class="text-center text-kernel-600 text-xs italic pb-8">
      Historia numquam rescribitur; sutura tantum additur. — History is never rewritten; only a weld is added.
    </div>
  </div>
</BaseLayout>

<script>
  import { computeKernel, classifyRegime } from '../lib/kernel';

  const EPSILON = 1e-8;
  const TOL_SEAM = 0.005;

  // ── Domain data (shared with LedgerViewer) ─────────────────
  const domainTraces: Record<string, { name: string; c: number[]; desc: string }> = {
    gcd: { name: 'GCD', c: [0.95, 0.90, 0.88, 0.92, 0.85, 0.91], desc: 'Core framework' },
    rcft: { name: 'RCFT', c: [0.92, 0.88, 0.85, 0.90, 0.87, 0.86], desc: 'Recursive collapse' },
    kinematics: { name: 'Kinematics', c: [0.80, 0.85, 0.75, 0.90, 0.82, 0.78], desc: 'Motion analysis' },
    weyl: { name: 'Weyl', c: [0.70, 0.65, 0.60, 0.72, 0.68, 0.66], desc: 'Cosmology' },
    security: { name: 'Security', c: [0.95, 0.92, 0.98, 0.90, 0.96, 0.93], desc: 'Audit validation' },
    astronomy: { name: 'Astronomy', c: [0.75, 0.80, 0.70, 0.85, 0.72, 0.78], desc: 'Stellar classification' },
    nuclear_physics: { name: 'Nuclear', c: [0.60, 0.55, 0.70, 0.50, 0.65, 0.58], desc: 'Binding energy' },
    quantum_mechanics: { name: 'Quantum', c: [0.85, 0.80, 0.75, 0.90, 0.82, 0.78], desc: 'Wavefunction' },
    finance: { name: 'Finance', c: [0.72, 0.68, 0.65, 0.70, 0.75, 0.66], desc: 'Portfolio coherence' },
    atomic_physics: { name: 'Atomic', c: [0.88, 0.85, 0.82, 0.90, 0.86, 0.84], desc: '118 elements' },
    materials_science: { name: 'Materials', c: [0.82, 0.78, 0.80, 0.85, 0.76, 0.81], desc: 'Element database' },
    everyday_physics: { name: 'Everyday', c: [0.90, 0.88, 0.85, 0.92, 0.87, 0.89], desc: 'Thermo, optics' },
    evolution: { name: 'Evolution', c: [0.65, 0.70, 0.60, 0.75, 0.68, 0.62], desc: '40 organisms' },
    dynamic_semiotics: { name: 'Semiotics', c: [0.78, 0.75, 0.72, 0.80, 0.76, 0.74], desc: '30 sign systems' },
    consciousness_coherence: { name: 'Consciousness', c: [0.55, 0.60, 0.50, 0.65, 0.58, 0.52], desc: '20 systems' },
    continuity_theory: { name: 'Continuity', c: [0.85, 0.82, 0.88, 0.80, 0.84, 0.86], desc: 'Persistence' },
    awareness_cognition: { name: 'Awareness', c: [0.70, 0.65, 0.72, 0.68, 0.75, 0.66], desc: '10 theorems' },
    standard_model: { name: 'Standard Model', c: [0.50, 0.45, 0.40, 0.55, 0.48, 0.42, 0.52, 0.46], desc: '31 particles' },
    clinical_neuroscience: { name: 'Clinical Neuro', c: [0.75, 0.70, 0.68, 0.78, 0.72, 0.66], desc: 'Cortical kernel' },
    spacetime_memory: { name: 'Spacetime', c: [0.62, 0.58, 0.55, 0.65, 0.60, 0.56], desc: '40 entities' },
    immunology: { name: 'Immunology', c: [0.80, 0.75, 0.72, 0.82, 0.78, 0.70], desc: 'Adaptive immunity' },
  };

  // All domain results
  type DomainRes = { id: string; name: string; c: number[]; kernel: ReturnType<typeof computeKernel>; regime: string; isCritical: boolean };
  const allDomains: DomainRes[] = [];
  for (const [id, d] of Object.entries(domainTraces)) {
    const w = Array.from({length: d.c.length}, () => 1.0 / d.c.length);
    const k = computeKernel(d.c, w);
    const r = classifyRegime(k);
    allDomains.push({ id, name: d.name, c: d.c, kernel: k, regime: r.regime, isCritical: r.isCritical });
  }

  // ── Budget Simulator ───────────────────────────────────────
  function gammaFn(omega: number): number {
    return Math.pow(omega, 3) / (1 - omega + EPSILON);
  }

  function updateSim() {
    const omega = parseFloat((document.getElementById('sim-omega') as HTMLInputElement).value);
    const curv = parseFloat((document.getElementById('sim-curv') as HTMLInputElement).value);
    const r = parseFloat((document.getElementById('sim-r') as HTMLInputElement).value);
    const isInf = (document.getElementById('sim-inf') as HTMLInputElement).checked;
    const tau = isInf ? Infinity : parseFloat((document.getElementById('sim-tau') as HTMLInputElement).value);

    const dw = gammaFn(omega);
    const dc = 1.0 * curv;
    const credit = isInf ? 0 : r * tau;
    const debit = dw + dc;
    const delta = credit - debit;
    const closes = Math.abs(delta) <= TOL_SEAM;

    (document.getElementById('sim-omega-val') as HTMLElement).textContent = omega.toFixed(2);
    (document.getElementById('sim-curv-val') as HTMLElement).textContent = curv.toFixed(2);
    (document.getElementById('sim-r-val') as HTMLElement).textContent = r.toFixed(2);
    (document.getElementById('sim-tau-val') as HTMLElement).textContent = isInf ? '∞_rec' : tau.toFixed(1);
    (document.getElementById('sim-dw-val') as HTMLElement).innerHTML = `D<sub>ω</sub> = ${dw.toFixed(4)}`;
    (document.getElementById('sim-dc-val') as HTMLElement).innerHTML = `D<sub>C</sub> = ${dc.toFixed(4)}`;

    // Regime from omega
    const regime = omega >= 0.30 ? 'COLLAPSE' : omega >= 0.038 ? 'WATCH' : 'STABLE';
    const regimeColor: Record<string, string> = { STABLE: 'text-green-400', WATCH: 'text-amber-400', COLLAPSE: 'text-red-400' };

    const el = document.getElementById('sim-result')!;
    el.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-center">
        <div class="bg-kernel-800 rounded p-3">
          <div class="text-xs text-kernel-500">Debit Total</div>
          <div class="text-red-400 font-mono text-lg">${debit.toFixed(4)}</div>
          <div class="text-xs text-kernel-600">D<sub>ω</sub>=${dw.toFixed(4)} + D<sub>C</sub>=${dc.toFixed(4)}</div>
        </div>
        <div class="bg-kernel-800 rounded p-3">
          <div class="text-xs text-kernel-500">Credit</div>
          <div class="${isInf ? 'text-red-400' : 'text-emerald-400'} font-mono text-lg">${isInf ? '0 (∞_rec)' : credit.toFixed(4)}</div>
          <div class="text-xs text-kernel-600">R·τ<sub>R</sub> = ${r.toFixed(2)} × ${isInf ? '∞' : tau.toFixed(1)}</div>
        </div>
        <div class="bg-kernel-800 rounded p-3">
          <div class="text-xs text-kernel-500">Net Δκ</div>
          <div class="${closes ? 'text-emerald-400' : 'text-red-400'} font-mono text-lg">${delta >= 0 ? '+' : ''}${delta.toFixed(4)}</div>
          <div class="text-xs text-kernel-600">tol = ${TOL_SEAM}</div>
        </div>
      </div>
      <!-- Visual budget bar -->
      <div class="mt-3">
        <div class="flex h-6 rounded overflow-hidden bg-kernel-800">
          <div class="bg-red-600/80 flex items-center justify-center text-[10px] text-white" style="width:${Math.min(debit / Math.max(debit, credit, 0.01) * 50, 50)}%">Debit</div>
          <div class="bg-emerald-600/80 flex items-center justify-center text-[10px] text-white" style="width:${Math.min(credit / Math.max(debit, credit, 0.01) * 50, 50)}%">${isInf ? '—' : 'Credit'}</div>
        </div>
      </div>
      <div class="mt-3 p-3 rounded ${closes ? 'bg-emerald-900/20 border border-emerald-700/30' : 'bg-red-900/20 border border-red-700/30'}">
        <div class="flex items-center gap-3">
          <span class="${closes ? 'text-emerald-400' : 'text-red-400'} text-lg font-bold">${closes ? 'SUTURA' : 'GESTUS'}</span>
          <span class="text-xs text-kernel-400">${closes ? 'The seam closes — epistemic credit granted' : isInf ? 'τ_R = ∞_rec — permanent detention, no return credit' : '|Δκ| > tol_seam — residual does not reconcile'}</span>
        </div>
        <div class="text-xs text-kernel-500 mt-1">
          Regime: <span class="${regimeColor[regime]}">${regime}</span> · |Δκ| = ${Math.abs(delta).toFixed(4)} ${closes ? '≤' : '>'} ${TOL_SEAM}
        </div>
      </div>
      <div class="text-xs text-kernel-600 italic mt-2">
        ${closes ? 'Cum receptu, sutura est. — With a receipt, it is a weld.' : 'Sine receptu, gestus est. — Without a receipt, it is a gesture.'}
      </div>
    `;
  }

  ['sim-omega', 'sim-curv', 'sim-r', 'sim-tau'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updateSim);
  });
  document.getElementById('sim-inf')?.addEventListener('change', updateSim);
  updateSim();

  // ── Identity Verification ──────────────────────────────────
  function verifyIdentities() {
    const input = (document.getElementById('id-trace') as HTMLInputElement).value;
    const c = input.split(',').map(s => parseFloat(s.trim())).filter(v => !isNaN(v));

    if (c.length < 2) {
      document.getElementById('id-results')!.innerHTML = '<p class="text-xs text-red-400">Enter at least 2 values.</p>';
      return;
    }

    const w = Array.from({length: c.length}, () => 1.0 / c.length);
    const k = computeKernel(c, w);
    const regime = classifyRegime(k);

    // Identity 1: F + ω = 1
    const id1_res = Math.abs(k.F + k.omega - 1);
    const id1_pass = id1_res < 1e-10;

    // Identity 2: IC ≤ F
    const id2_pass = k.IC <= k.F + 1e-10;

    // Identity 3: IC = exp(κ)
    const id3_res = Math.abs(k.IC - Math.exp(k.kappa));
    const id3_pass = id3_res < 1e-10;

    const allPass = id1_pass && id2_pass && id3_pass;

    const el = document.getElementById('id-results')!;
    el.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4">
        <div class="bg-kernel-800 rounded p-3 border ${id1_pass ? 'border-emerald-700/40' : 'border-red-700/40'}">
          <div class="flex items-center gap-2 mb-1">
            <span class="${id1_pass ? 'text-emerald-400' : 'text-red-400'}">${id1_pass ? '✓' : '✕'}</span>
            <span class="text-sm font-bold text-kernel-200">F + ω = 1</span>
          </div>
          <div class="text-xs text-kernel-400 font-mono">
            F = ${k.F.toFixed(10)}<br>
            ω = ${k.omega.toFixed(10)}<br>
            |residual| = ${id1_res.toExponential(2)}
          </div>
        </div>
        <div class="bg-kernel-800 rounded p-3 border ${id2_pass ? 'border-emerald-700/40' : 'border-red-700/40'}">
          <div class="flex items-center gap-2 mb-1">
            <span class="${id2_pass ? 'text-emerald-400' : 'text-red-400'}">${id2_pass ? '✓' : '✕'}</span>
            <span class="text-sm font-bold text-kernel-200">IC ≤ F</span>
          </div>
          <div class="text-xs text-kernel-400 font-mono">
            IC = ${k.IC.toFixed(10)}<br>
            F = ${k.F.toFixed(10)}<br>
            Δ = F − IC = ${k.delta.toFixed(10)}
          </div>
        </div>
        <div class="bg-kernel-800 rounded p-3 border ${id3_pass ? 'border-emerald-700/40' : 'border-red-700/40'}">
          <div class="flex items-center gap-2 mb-1">
            <span class="${id3_pass ? 'text-emerald-400' : 'text-red-400'}">${id3_pass ? '✓' : '✕'}</span>
            <span class="text-sm font-bold text-kernel-200">IC = exp(κ)</span>
          </div>
          <div class="text-xs text-kernel-400 font-mono">
            IC = ${k.IC.toFixed(10)}<br>
            exp(κ) = ${Math.exp(k.kappa).toFixed(10)}<br>
            |residual| = ${id3_res.toExponential(2)}
          </div>
        </div>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mb-3">
        ${[
          { label: 'F', val: k.F },
          { label: 'ω', val: k.omega },
          { label: 'IC', val: k.IC },
          { label: 'Δ', val: k.delta },
          { label: 'S', val: k.S },
          { label: 'C', val: k.C },
        ].map(v => `
          <div class="bg-kernel-950 rounded p-2 text-center">
            <div class="text-[10px] text-kernel-500">${v.label}</div>
            <div class="font-mono text-xs text-kernel-200">${v.val.toFixed(4)}</div>
          </div>
        `).join('')}
      </div>
      <div class="flex items-center gap-3 p-3 rounded ${allPass ? 'bg-emerald-900/20 border border-emerald-700/30' : 'bg-red-900/20 border border-red-700/30'}">
        <span class="${allPass ? 'text-emerald-400' : 'text-red-400'} font-bold">${allPass ? 'ALL IDENTITIES HOLD' : 'IDENTITY VIOLATION'}</span>
        <span class="text-xs text-kernel-400">Regime: <span class="${regime.regime === 'STABLE' ? 'text-green-400' : regime.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400'}">${regime.regime}</span>${regime.isCritical ? ' <span class="text-red-400">⚠ CRITICAL</span>' : ''}</span>
        <span class="text-xs text-kernel-500">IC/F = ${(k.IC / k.F).toFixed(4)}</span>
      </div>
    `;
  }

  document.getElementById('id-trace')?.addEventListener('input', verifyIdentities);
  verifyIdentities();

  // ── Cross-Domain Comparison ────────────────────────────────
  function setupComparison() {
    const selA = document.getElementById('cmp-a') as HTMLSelectElement;
    const selB = document.getElementById('cmp-b') as HTMLSelectElement;

    allDomains.sort((a, b) => b.kernel.F - a.kernel.F);

    allDomains.forEach((d, i) => {
      const optA = document.createElement('option');
      optA.value = d.id;
      optA.textContent = `${d.name} (F=${d.kernel.F.toFixed(3)})`;
      selA.appendChild(optA);

      const optB = document.createElement('option');
      optB.value = d.id;
      optB.textContent = `${d.name} (F=${d.kernel.F.toFixed(3)})`;
      selB.appendChild(optB);
    });

    if (allDomains.length >= 2) {
      selA.value = allDomains[0].id;
      selB.value = allDomains[allDomains.length - 1].id;
    }

    function updateCmp() {
      const a = allDomains.find(d => d.id === selA.value)!;
      const b = allDomains.find(d => d.id === selB.value)!;

      const metrics = ['F', 'omega', 'IC', 'delta', 'S', 'C'] as const;
      const labels: Record<string, string> = { F: 'F', omega: 'ω', IC: 'IC', delta: 'Δ', S: 'S', C: 'C' };

      const regimeColor: Record<string, string> = { STABLE: 'text-green-400', WATCH: 'text-amber-400', COLLAPSE: 'text-red-400' };

      const el = document.getElementById('cmp-result')!;
      el.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-xs font-mono">
            <thead>
              <tr class="text-kernel-500 border-b border-kernel-700">
                <th class="text-left p-2">Metric</th>
                <th class="text-right p-2 text-blue-400">${a.name}</th>
                <th class="text-right p-2 text-amber-400">${b.name}</th>
                <th class="text-right p-2">Δ (A − B)</th>
                <th class="text-center p-2">Comparison</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-kernel-800">
              ${metrics.map(m => {
                const va = a.kernel[m];
                const vb = b.kernel[m];
                const diff = va - vb;
                const better = m === 'omega' || m === 'C' || m === 'S' ? (diff < 0 ? 'A' : diff > 0 ? 'B' : '=') : (diff > 0 ? 'A' : diff < 0 ? 'B' : '=');
                return `
                  <tr>
                    <td class="p-2 text-kernel-300">${labels[m]}</td>
                    <td class="text-right p-2">${va.toFixed(6)}</td>
                    <td class="text-right p-2">${vb.toFixed(6)}</td>
                    <td class="text-right p-2 ${diff > 0 ? 'text-emerald-400' : diff < 0 ? 'text-red-400' : ''}">${diff >= 0 ? '+' : ''}${diff.toFixed(6)}</td>
                    <td class="text-center p-2">${better === 'A' ? '<span class="text-blue-400">◀</span>' : better === 'B' ? '<span class="text-amber-400">▶</span>' : '<span class="text-kernel-500">=</span>'}</td>
                  </tr>
                `;
              }).join('')}
              <tr class="border-t-2 border-kernel-600">
                <td class="p-2 text-kernel-300">Regime</td>
                <td class="text-right p-2 ${regimeColor[a.regime]}">${a.regime}${a.isCritical ? ' ⚠' : ''}</td>
                <td class="text-right p-2 ${regimeColor[b.regime]}">${b.regime}${b.isCritical ? ' ⚠' : ''}</td>
                <td colspan="2"></td>
              </tr>
              <tr>
                <td class="p-2 text-kernel-300">IC/F</td>
                <td class="text-right p-2">${(a.kernel.IC / a.kernel.F).toFixed(4)}</td>
                <td class="text-right p-2">${(b.kernel.IC / b.kernel.F).toFixed(4)}</td>
                <td class="text-right p-2">${((a.kernel.IC / a.kernel.F) - (b.kernel.IC / b.kernel.F) >= 0 ? '+' : '')}${((a.kernel.IC / a.kernel.F) - (b.kernel.IC / b.kernel.F)).toFixed(4)}</td>
                <td></td>
              </tr>
            </tbody>
          </table>
        </div>
        <!-- Composition -->
        <div class="mt-3 bg-kernel-800 rounded p-3">
          <div class="text-xs text-kernel-500 mb-2">Composition (if domains were composed):</div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-center">
            <div>
              <div class="text-kernel-500">F<sub>12</sub> (arithmetic)</div>
              <div class="font-mono text-kernel-200">${((a.kernel.F + b.kernel.F) / 2).toFixed(6)}</div>
            </div>
            <div>
              <div class="text-kernel-500">IC<sub>12</sub> (geometric)</div>
              <div class="font-mono text-kernel-200">${Math.sqrt(a.kernel.IC * b.kernel.IC).toFixed(6)}</div>
            </div>
            <div>
              <div class="text-kernel-500">Δ<sub>12</sub></div>
              <div class="font-mono text-kernel-200">${(((a.kernel.F + b.kernel.F) / 2) - Math.sqrt(a.kernel.IC * b.kernel.IC)).toFixed(6)}</div>
            </div>
          </div>
        </div>
      `;
    }

    selA.addEventListener('change', updateCmp);
    selB.addEventListener('change', updateCmp);
    updateCmp();
  }

  setupComparison();

  // ── Aggregate Statistics ───────────────────────────────────
  function renderAggStats() {
    const Fs = allDomains.map(d => d.kernel.F);
    const ICs = allDomains.map(d => d.kernel.IC);
    const deltas = allDomains.map(d => d.kernel.delta);
    const regimes: Record<string, number> = { STABLE: 0, WATCH: 0, COLLAPSE: 0 };
    allDomains.forEach(d => regimes[d.regime]++);
    const critical = allDomains.filter(d => d.isCritical).length;

    const mean = (arr: number[]) => arr.reduce((a, b) => a + b, 0) / arr.length;
    const max = (arr: number[]) => Math.max(...arr);
    const min = (arr: number[]) => Math.min(...arr);

    const el = document.getElementById('agg-stats')!;
    el.innerHTML = `
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4 text-center">
        <div class="text-xs text-kernel-500 mb-1">Mean F</div>
        <div class="text-xl font-mono text-kernel-100">${mean(Fs).toFixed(4)}</div>
        <div class="text-xs text-kernel-600">[${min(Fs).toFixed(3)} – ${max(Fs).toFixed(3)}]</div>
      </div>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4 text-center">
        <div class="text-xs text-kernel-500 mb-1">Mean IC</div>
        <div class="text-xl font-mono text-kernel-100">${mean(ICs).toFixed(4)}</div>
        <div class="text-xs text-kernel-600">[${min(ICs).toFixed(3)} – ${max(ICs).toFixed(3)}]</div>
      </div>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4 text-center">
        <div class="text-xs text-kernel-500 mb-1">Mean Gap Δ</div>
        <div class="text-xl font-mono text-amber-400">${mean(deltas).toFixed(4)}</div>
        <div class="text-xs text-kernel-600">Max: ${max(deltas).toFixed(4)}</div>
      </div>
      <div class="bg-kernel-900/50 border border-kernel-800/40 rounded-xl p-4 text-center">
        <div class="text-xs text-kernel-500 mb-1">Regime Distribution</div>
        <div class="text-xs mt-1 space-y-1">
          <div class="text-green-400">Stable: ${regimes.STABLE} / ${allDomains.length}</div>
          <div class="text-amber-400">Watch: ${regimes.WATCH} / ${allDomains.length}</div>
          <div class="text-red-400">Collapse: ${regimes.COLLAPSE} / ${allDomains.length}</div>
          ${critical > 0 ? `<div class="text-red-400">⚠ Critical: ${critical}</div>` : ''}
        </div>
      </div>
    `;
  }

  renderAggStats();
</script>
