<script>
  import { computeKernel, classifyRegime } from '../lib/kernel';
  import { EPSILON } from '../lib/constants';

  // --- Absurd Calculator ---
  const aliveSlider = document.getElementById('alive-slider') as HTMLInputElement;
  const deadSlider = document.getElementById('dead-slider') as HTMLInputElement;
  const aliveVal = document.getElementById('alive-val')!;
  const deadVal = document.getElementById('dead-val')!;

  function updateAbsurd() {
    const alive = parseFloat(aliveSlider.value);
    const dead = parseFloat(deadSlider.value);
    aliveVal.textContent = alive.toFixed(2);
    deadVal.textContent = dead.toFixed(3);

    const channels = [alive, alive, alive, alive, alive, alive, alive, dead];
    const result = computeKernel(channels);
    const regime = classifyRegime(result);

    document.getElementById('abs-F')!.textContent = result.F.toFixed(4);
    document.getElementById('abs-IC')!.textContent = result.IC.toFixed(4);
    document.getElementById('abs-delta')!.textContent = result.delta.toFixed(4);
    document.getElementById('abs-ratio')!.textContent = (result.IC / result.F).toFixed(4);

    const rl = document.getElementById('abs-regime')!;
    rl.textContent = regime.regime;
    rl.className = regime.regime === 'STABLE' ? 'text-green-400 font-mono' :
                   regime.regime === 'WATCH' ? 'text-yellow-400 font-mono' :
                   'text-red-400 font-mono';
  }

  aliveSlider.addEventListener('input', updateAbsurd);
  deadSlider.addEventListener('input', updateAbsurd);
  updateAbsurd();

  // --- Shadow Calculator (reuses similar logic) ---
  const jungConscious = document.getElementById('jung-conscious') as HTMLInputElement;
  const jungShadow = document.getElementById('jung-shadow') as HTMLInputElement;

  function updateJung() {
    const conscious = parseFloat(jungConscious.value);
    const shadow = parseFloat(jungShadow.value);
    document.getElementById('jung-conscious-val')!.textContent = conscious.toFixed(2);
    document.getElementById('jung-shadow-val')!.textContent = shadow.toFixed(3);

    const channels = [conscious, conscious, conscious, conscious, conscious, conscious, conscious, shadow];
    const result = computeKernel(channels);

    // Reference: all channels at conscious (no shadow)
    const refResult = computeKernel([conscious, conscious, conscious, conscious, conscious, conscious, conscious, conscious]);

    document.getElementById('jung-F')!.textContent = result.F.toFixed(4);
    document.getElementById('jung-IC')!.textContent = result.IC.toFixed(4);
    document.getElementById('jung-delta')!.textContent = result.delta.toFixed(4);
    document.getElementById('jung-ratio')!.textContent = (result.IC / result.F).toFixed(4);

    const loss = ((refResult.IC - result.IC) / refResult.IC * 100);
    document.getElementById('jung-loss')!.textContent = loss.toFixed(1) + '%';
  }

  jungConscious.addEventListener('input', updateJung);
  jungShadow.addEventListener('input', updateJung);
  updateJung();
</script>
