---
/**
 * Brain Anatomy — The Deepest Page on Brain Structure, Function & Cognition
 *
 * Integrates data from:
 *   - HoliAtlas (Manjón et al. 2026): 0.125 mm³, 350 labels, 3 modalities
 *   - NextBrain (Iglesias et al. 2025): 100 μm, 333 regions, histological
 *   - Awareness-cognition kernel: 34 organisms, 10 channels
 *   - Attention mechanisms: 12 mechanisms, 8 channels
 *   - Neural correlates of consciousness: 12 NCCs, 8 channels
 *   - Clinical neuroscience: 35 neurocognitive states, 10 channels
 *
 * Live kernel computation in the browser via TypeScript kernel.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Brain Anatomy — GCD"
  description="Deep-dive into brain structure, function, and cognition. 52 anatomical structures analyzed through the GCD kernel with interactive 3D brain model, neural pathway mapping, and cognition theory."
>
<div class="max-w-6xl mx-auto space-y-14 pb-20">

  <!-- ═══════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════ -->
  <header class="border-b border-kernel-800 pb-8">
    <h1 class="text-4xl font-bold text-kernel-100 mb-3">Brain Anatomy</h1>
    <p class="text-kernel-400 text-lg max-w-3xl">
      52 brain structures mapped through the GCD kernel. Every region measured
      across 8 channels — volumetric fraction, segmentation accuracy, multimodal
      contrast, structural heterogeneity, bilateral symmetry, clinical sensitivity,
      connectivity degree, and resolution dependence. Computed live in your browser.
    </p>
    <p class="text-kernel-500 text-sm mt-2 italic">
      Quid supersit post collapsum cerebri? — What survives after the collapse of the brain?
    </p>
    <div class="flex flex-wrap gap-2 mt-4 text-xs">
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">HoliAtlas 2026</span>
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">NextBrain 2025</span>
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">52 Structures</span>
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">8 Channels</span>
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">7 Categories</span>
      <span class="px-2 py-1 rounded bg-kernel-800 text-kernel-400 border border-kernel-700">6 Theorems Proven</span>
    </div>

    <!-- Quick nav -->
    <nav class="flex flex-wrap gap-2 mt-5 text-xs text-kernel-500" aria-label="Page sections">
      <a href="#brain-model" class="hover:text-amber-400 transition">Brain Model</a>
      <span>·</span>
      <a href="#kernel-atlas" class="hover:text-amber-400 transition">Kernel Atlas</a>
      <span>·</span>
      <a href="#pathways" class="hover:text-amber-400 transition">Neural Pathways</a>
      <span>·</span>
      <a href="#cognition" class="hover:text-amber-400 transition">How Thought Works</a>
      <span>·</span>
      <a href="#awareness" class="hover:text-amber-400 transition">Awareness &amp; Consciousness</a>
      <span>·</span>
      <a href="#attention" class="hover:text-amber-400 transition">Attention</a>
      <span>·</span>
      <a href="#disease" class="hover:text-amber-400 transition">Disease Mapping</a>
      <span>·</span>
      <a href="#theorems" class="hover:text-amber-400 transition">Theorems</a>
      <span>·</span>
      <a href="#atlas-comparison" class="hover:text-amber-400 transition">Atlas Comparison</a>
    </nav>
  </header>

  <!-- ═══════════════════════════════════════════════════════════════
       §1  INTERACTIVE BRAIN MODEL
       ═══════════════════════════════════════════════════════════════ -->
  <section id="brain-model">
    <h2 class="text-2xl font-bold text-amber-400 mb-4">§1 — Interactive Brain Model</h2>
    <p class="text-kernel-400 text-sm mb-4">
      Click any brain region to see its GCD kernel analysis. The model shows a sagittal (side) view
      with major structures labeled and color-coded by category.
    </p>

    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
      <!-- View Toggle -->
      <div class="flex items-center justify-between mb-4">
        <div class="flex gap-2">
          <button id="btn-view-2d" class="px-3 py-1.5 text-xs rounded border border-amber-600 bg-amber-950/30 text-amber-400 font-bold transition">2D Sagittal</button>
          <button id="btn-view-3d" class="px-3 py-1.5 text-xs rounded border border-kernel-600 bg-kernel-800 text-kernel-400 font-bold transition hover:border-amber-600 hover:text-amber-400">3D Rotate</button>
        </div>
        <button id="btn-reset-view" class="px-2 py-1 text-[10px] rounded border border-kernel-700 text-kernel-500 hover:text-kernel-300 transition hidden">Reset View</button>
      </div>

      <div class="flex flex-col lg:flex-row gap-6">
        <!-- SVG Brain (2D view) -->
        <div id="brain-2d-container" class="flex-1 relative" style="min-height: 480px;">
          <svg id="brain-svg" viewBox="0 0 800 600" class="w-full h-full" style="max-height: 520px;">
            <!-- Brain Outline (sagittal view) -->
            <defs>
              <radialGradient id="brain-glow" cx="50%" cy="40%" r="50%">
                <stop offset="0%" style="stop-color:#1e293b;stop-opacity:0.3" />
                <stop offset="100%" style="stop-color:#020617;stop-opacity:0" />
              </radialGradient>
              <filter id="glow-filter">
                <feGaussianBlur stdDeviation="3" result="blur" />
                <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
              </filter>
            </defs>

            <!-- Brain outline — smooth cerebral cortex shape -->
            <path d="M400,80 C520,70 620,110 670,180 C720,250 720,340 690,400 C660,460 600,510 540,530 C480,550 420,540 380,530 C340,530 280,540 230,520 C180,500 140,460 120,400 C100,340 110,270 130,210 C150,150 220,100 300,85 C340,78 370,77 400,80 Z"
              fill="none" stroke="#475569" stroke-width="2" />

            <!-- Cerebral sulci (folds) -->
            <path d="M350,95 C370,130 380,180 375,220" fill="none" stroke="#334155" stroke-width="1.5" stroke-dasharray="4,3" />
            <path d="M430,90 C450,130 460,180 450,230" fill="none" stroke="#334155" stroke-width="1.5" stroke-dasharray="4,3" />
            <path d="M500,110 C530,160 540,210 530,260" fill="none" stroke="#334155" stroke-width="1.5" stroke-dasharray="4,3" />
            <path d="M280,120 C270,170 270,220 280,260" fill="none" stroke="#334155" stroke-width="1.5" stroke-dasharray="4,3" />

            <!-- Central sulcus (divides frontal/parietal) -->
            <path d="M420,82 C415,120 405,180 395,240" fill="none" stroke="#64748b" stroke-width="2" opacity="0.6" />

            <!-- Lateral sulcus (Sylvian fissure) -->
            <path d="M330,300 C380,280 430,275 480,280" fill="none" stroke="#64748b" stroke-width="2" opacity="0.6" />

            <!-- ── CORTICAL REGIONS ── -->
            <!-- Frontal Cortex -->
            <path id="r-frontal" class="brain-region" data-region="frontal_cortex" data-cat="cortical"
              d="M200,180 C230,120 330,90 400,85 C410,110 405,160 395,240 C350,260 300,250 250,230 C220,220 200,200 200,180 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Parietal Cortex -->
            <path id="r-parietal" class="brain-region" data-region="parietal_cortex" data-cat="cortical"
              d="M400,85 C450,82 510,100 560,140 C560,180 540,230 510,270 C470,260 430,255 395,240 C405,160 410,110 400,85 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Occipital Cortex -->
            <path id="r-occipital" class="brain-region" data-region="occipital_cortex" data-cat="cortical"
              d="M560,140 C620,170 670,220 690,300 C680,340 660,370 630,390 C600,370 570,340 540,300 C530,260 540,200 560,140 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Temporal Cortex -->
            <path id="r-temporal" class="brain-region" data-region="temporal_cortex" data-cat="cortical"
              d="M250,290 C280,280 340,285 400,290 C440,310 470,340 490,380 C460,420 400,450 340,460 C280,450 240,420 220,380 C210,340 220,310 250,290 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Insular Cortex (deep, small indicator) -->
            <ellipse id="r-insular" class="brain-region" data-region="insular_cortex" data-cat="cortical"
              cx="350" cy="300" rx="25" ry="15" fill="#3b82f640" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── SUBCORTICAL ── -->
            <!-- Thalamus (central relay) -->
            <ellipse id="r-thalamus" class="brain-region" data-region="thalamus" data-cat="subcortical"
              cx="410" cy="320" rx="40" ry="25" fill="#a855f720" stroke="#a855f7" stroke-width="2" style="cursor:pointer" />

            <!-- Caudate -->
            <path id="r-caudate" class="brain-region" data-region="caudate" data-cat="subcortical"
              d="M340,260 C345,275 350,290 345,310 C340,300 335,290 330,280 Z"
              fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- Putamen -->
            <ellipse id="r-putamen" class="brain-region" data-region="putamen" data-cat="subcortical"
              cx="325" cy="310" rx="18" ry="22" fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- Globus Pallidus -->
            <ellipse id="r-gp" class="brain-region" data-region="globus_pallidus" data-cat="subcortical"
              cx="310" cy="325" rx="12" ry="15" fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- Subthalamic Nucleus -->
            <circle id="r-stn" class="brain-region" data-region="subthalamic_nucleus" data-cat="subcortical"
              cx="380" cy="370" r="8" fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── LIMBIC ── -->
            <!-- Hippocampus (curved shape) -->
            <path id="r-hippo-ca1" class="brain-region" data-region="hippocampus_ca1" data-cat="limbic"
              d="M430,380 C445,370 460,375 470,390 C465,400 450,405 435,400 C425,395 425,388 430,380 Z"
              fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <path id="r-hippo-ca23" class="brain-region" data-region="hippocampus_ca23" data-cat="limbic"
              d="M470,390 C480,385 490,390 495,400 C490,410 480,412 470,405 C465,400 465,395 470,390 Z"
              fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <!-- Amygdala -->
            <ellipse id="r-amyg-lat" class="brain-region" data-region="amygdala_lateral" data-cat="limbic"
              cx="390" cy="400" rx="15" ry="12" fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <ellipse id="r-amyg-bas" class="brain-region" data-region="amygdala_basal" data-cat="limbic"
              cx="390" cy="418" rx="12" ry="10" fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <!-- Cingulate Cortex (arc above corpus callosum) -->
            <path id="r-cingulate" class="brain-region" data-region="cingulate_cortex" data-cat="limbic"
              d="M250,200 C300,180 370,175 430,180 C460,185 480,190 500,200 C480,210 430,210 370,210 C310,210 280,210 250,200 Z"
              fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── BRAINSTEM ── -->
            <!-- Midbrain -->
            <ellipse id="r-midbrain" class="brain-region" data-region="midbrain" data-cat="brainstem"
              cx="430" cy="430" rx="25" ry="18" fill="#f59e0b20" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- Pons -->
            <ellipse id="r-pons" class="brain-region" data-region="pons" data-cat="brainstem"
              cx="420" cy="465" rx="28" ry="20" fill="#f59e0b20" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- Medulla -->
            <ellipse id="r-medulla" class="brain-region" data-region="medulla" data-cat="brainstem"
              cx="400" cy="500" rx="20" ry="22" fill="#f59e0b20" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- Substantia Nigra -->
            <circle id="r-sn" class="brain-region" data-region="substantia_nigra" data-cat="brainstem"
              cx="445" cy="420" r="7" fill="#f59e0b40" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- Red Nucleus -->
            <circle id="r-rn" class="brain-region" data-region="red_nucleus" data-cat="brainstem"
              cx="418" cy="425" r="6" fill="#f59e0b40" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── CEREBELLAR ── -->
            <!-- Cerebellum (posterior fossa) -->
            <path id="r-cereb-ant" class="brain-region" data-region="cerebellum_anterior" data-cat="cerebellar"
              d="M500,430 C540,420 580,430 600,450 C580,460 550,460 520,455 C510,450 505,440 500,430 Z"
              fill="#06b6d420" stroke="#06b6d4" stroke-width="1.5" style="cursor:pointer" />

            <path id="r-cereb-post" class="brain-region" data-region="cerebellum_posterior" data-cat="cerebellar"
              d="M500,455 C530,460 570,465 600,455 C620,470 630,490 620,510 C600,530 550,540 500,530 C470,520 460,500 470,480 C480,465 490,458 500,455 Z"
              fill="#06b6d420" stroke="#06b6d4" stroke-width="1.5" style="cursor:pointer" />

            <!-- Vermis -->
            <ellipse id="r-vermis" class="brain-region" data-region="vermis" data-cat="cerebellar"
              cx="540" cy="485" rx="12" ry="20" fill="#06b6d420" stroke="#06b6d4" stroke-width="1.5" style="cursor:pointer" />

            <!-- Dentate Nucleus -->
            <circle id="r-dentate" class="brain-region" data-region="dentate_nucleus" data-cat="cerebellar"
              cx="560" cy="475" r="8" fill="#06b6d440" stroke="#06b6d4" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── WHITE MATTER ── -->
            <!-- Corpus Callosum (major arc) -->
            <path id="r-cc" class="brain-region" data-region="corpus_callosum" data-cat="white_matter"
              d="M230,230 C280,215 370,210 430,212 C480,215 510,220 530,230 C510,240 430,242 370,240 C310,240 260,240 230,230 Z"
              fill="#ec489920" stroke="#ec4899" stroke-width="1.5" style="cursor:pointer" />

            <!-- Fornix -->
            <path id="r-fornix" class="brain-region" data-region="fornix" data-cat="white_matter"
              d="M380,240 C370,260 365,290 370,320 C375,340 380,360 385,380"
              fill="none" stroke="#ec4899" stroke-width="2.5" stroke-linecap="round" style="cursor:pointer" />

            <!-- ── SPECIALIZED ── -->
            <!-- Hypothalamus -->
            <ellipse id="r-hypothalamus" class="brain-region" data-region="hypothalamus" data-cat="specialized"
              cx="380" cy="350" rx="20" ry="14" fill="#f4364720" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Thalamic Pulvinar -->
            <ellipse id="r-pulvinar" class="brain-region" data-region="thalamic_pulvinar" data-cat="specialized"
              cx="460" cy="315" rx="14" ry="10" fill="#f4364720" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Lateral Geniculate -->
            <circle id="r-lgn" class="brain-region" data-region="lateral_geniculate" data-cat="specialized"
              cx="470" cy="340" r="7" fill="#f4364720" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Medial Geniculate -->
            <circle id="r-mgn" class="brain-region" data-region="medial_geniculate" data-cat="specialized"
              cx="460" cy="355" r="6" fill="#f4364720" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Cortical ── -->
            <!-- Entorhinal Cortex (medial temporal) -->
            <ellipse id="r-entorhinal" class="brain-region" data-region="entorhinal_cortex" data-cat="cortical"
              cx="310" cy="410" rx="18" ry="12" fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Dorsolateral Prefrontal Cortex -->
            <path id="r-dlpfc" class="brain-region" data-region="prefrontal_dorsolateral" data-cat="cortical"
              d="M220,140 C250,120 310,105 350,100 C345,120 335,145 320,165 C290,160 255,155 220,140 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- Somatosensory Cortex -->
            <path id="r-somatosensory" class="brain-region" data-region="somatosensory_cortex" data-cat="cortical"
              d="M410,90 C420,95 435,110 440,130 C435,145 425,165 415,180 C405,165 400,140 400,120 C400,105 405,95 410,90 Z"
              fill="#3b82f620" stroke="#3b82f6" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Subcortical ── -->
            <!-- Nucleus Accumbens -->
            <circle id="r-nacc" class="brain-region" data-region="nucleus_accumbens" data-cat="subcortical"
              cx="310" cy="290" r="8" fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- Claustrum -->
            <path id="r-claustrum" class="brain-region" data-region="claustrum" data-cat="subcortical"
              d="M300,270 C303,280 305,295 303,310 C300,300 298,290 297,280 Z"
              fill="#a855f720" stroke="#a855f7" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Limbic ── -->
            <!-- Septal Nuclei -->
            <circle id="r-septal" class="brain-region" data-region="septal_nuclei" data-cat="limbic"
              cx="320" cy="265" r="7" fill="#22c55e20" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <!-- Mammillary Body -->
            <circle id="r-mammillary" class="brain-region" data-region="mammillary_body" data-cat="limbic"
              cx="395" cy="380" r="6" fill="#22c55e40" stroke="#22c55e" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Brainstem ── -->
            <!-- Locus Coeruleus (tiny but critical) -->
            <circle id="r-lc" class="brain-region" data-region="locus_coeruleus" data-cat="brainstem"
              cx="440" cy="455" r="5" fill="#f59e0b40" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- Raphe Nuclei (midline column) -->
            <path id="r-raphe" class="brain-region" data-region="raphe_nuclei" data-cat="brainstem"
              d="M410,440 C412,450 412,465 410,480 C408,465 408,450 410,440 Z"
              fill="#f59e0b40" stroke="#f59e0b" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Cerebellar ── -->
            <!-- Cerebellar Peduncles -->
            <ellipse id="r-cereb-ped" class="brain-region" data-region="cerebellar_peduncles" data-cat="cerebellar"
              cx="485" cy="450" rx="12" ry="8" fill="#06b6d420" stroke="#06b6d4" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional White Matter ── -->
            <!-- Internal Capsule -->
            <path id="r-intcap" class="brain-region" data-region="internal_capsule" data-cat="white_matter"
              d="M340,240 C345,260 348,280 345,310 C342,280 340,260 340,240 Z"
              fill="#ec489920" stroke="#ec4899" stroke-width="2" style="cursor:pointer" />

            <!-- Anterior Commissure -->
            <ellipse id="r-antcomm" class="brain-region" data-region="anterior_commissure" data-cat="white_matter"
              cx="350" cy="280" rx="18" ry="4" fill="#ec489920" stroke="#ec4899" stroke-width="1.5" style="cursor:pointer" />

            <!-- Cingulum Bundle (arc below cingulate) -->
            <path id="r-cingulum" class="brain-region" data-region="cingulum_bundle" data-cat="white_matter"
              d="M260,215 C310,205 370,202 420,205 C370,212 310,215 260,215 Z"
              fill="#ec489920" stroke="#ec4899" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── NEW: Additional Specialized ── -->
            <!-- Pineal Gland -->
            <circle id="r-pineal" class="brain-region" data-region="pineal_gland" data-cat="specialized"
              cx="480" cy="295" r="5" fill="#f4364740" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Choroid Plexus (within ventricle) -->
            <path id="r-choroid" class="brain-region" data-region="choroid_plexus" data-cat="specialized"
              d="M370,250 C380,248 395,250 405,255 C395,258 380,258 370,255 Z"
              fill="#f4364720" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Area Postrema (floor of 4th ventricle) -->
            <circle id="r-ap" class="brain-region" data-region="area_postrema" data-cat="specialized"
              cx="410" cy="490" r="4" fill="#f4364740" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- Suprachiasmatic Nucleus -->
            <circle id="r-scn" class="brain-region" data-region="suprachiasmatic_nucleus" data-cat="specialized"
              cx="365" cy="360" r="4" fill="#f4364740" stroke="#f43647" stroke-width="1.5" style="cursor:pointer" />

            <!-- ── LABELS ── -->
            <g class="text-[10px] fill-kernel-500 font-mono" style="pointer-events:none">
              <!-- Cortical labels -->
              <text x="280" y="155" text-anchor="middle" fill="#3b82f6">Frontal</text>
              <text x="500" y="155" text-anchor="middle" fill="#3b82f6">Parietal</text>
              <text x="650" y="260" text-anchor="middle" fill="#3b82f6">Occipital</text>
              <text x="300" y="390" text-anchor="middle" fill="#3b82f6">Temporal</text>
              <text x="350" y="315" text-anchor="middle" fill="#3b82f6" font-size="8">Insula</text>

              <!-- Subcortical labels -->
              <text x="410" y="305" text-anchor="middle" fill="#a855f7" font-weight="bold">Thalamus</text>
              <text x="330" y="255" text-anchor="middle" fill="#a855f7" font-size="8">Caudate</text>
              <text x="305" y="300" text-anchor="middle" fill="#a855f7" font-size="8">Put.</text>
              <text x="290" y="335" text-anchor="middle" fill="#a855f7" font-size="8">GP</text>
              <text x="380" y="385" text-anchor="middle" fill="#a855f7" font-size="8">STN</text>

              <!-- Limbic labels -->
              <text x="455" y="375" text-anchor="middle" fill="#22c55e" font-size="8">CA1</text>
              <text x="495" y="395" text-anchor="middle" fill="#22c55e" font-size="8">CA2/3</text>
              <text x="375" y="440" text-anchor="middle" fill="#22c55e" font-size="8">Amyg</text>
              <text x="380" y="195" text-anchor="middle" fill="#22c55e" font-size="9">Cingulate</text>

              <!-- Brainstem labels -->
