---
/**
 * Dynamic route for theorem catalog pages.
 * Route: /<domain>/theorems/
 */
import { getCollection, render } from 'astro:content';
import SubpageLayout from '../../layouts/SubpageLayout.astro';

export async function getStaticPaths() {
  const theorems = await getCollection('theorems');
  return theorems.map((entry) => {
    const domain = entry.id.split('/')[0];
    return {
      params: { domain },
      props: { entry, domain },
    };
  });
}

const { entry, domain } = Astro.props;
const { Content } = await render(entry);
---

<SubpageLayout frontmatter={{ ...entry.data, domain, pageType: 'theorems' }}>
  <Content />
</SubpageLayout>
