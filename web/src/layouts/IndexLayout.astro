    </div>

    <!-- Domain grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3" id="domain-grid">
      {domainCatalog.map(d => (
        <a href={`${base}${d.slug}/`}
           class={`domain-card bg-kernel-900 border rounded-lg p-4 hover:border-amber-600/60 hover:bg-kernel-800/60 transition group no-underline block ${categoryColors[d.category]?.split(' ').slice(1).join(' ') || 'border-kernel-700'}`}
           data-category={d.category} data-lens={d.lens}>
          <div class="flex items-start justify-between mb-2">
            <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition">{d.name}</div>
            <span class={`text-[10px] px-1.5 py-0.5 rounded border shrink-0 ml-2 ${categoryColors[d.category]?.split(' ')[0] || 'text-kernel-400'} border-kernel-700/50 bg-kernel-800/50`}>
              {d.category}
            </span>
          </div>
          <p class="text-xs text-kernel-400 mb-3">{d.desc}</p>
          <div class="flex items-center justify-between text-[10px]">
            <div class="flex gap-2">
              <span class="bg-kernel-800 px-1.5 py-0.5 rounded text-kernel-500">{d.modules} modules</span>
              <span class="bg-kernel-800 px-1.5 py-0.5 rounded text-kernel-500">{d.theorems} theorems</span>
              <span class="bg-kernel-800 px-1.5 py-0.5 rounded text-kernel-500">{d.channels} ch</span>
