    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-4">
      <button class="domain-cat-btn text-xs px-3 py-1.5 rounded-lg bg-kernel-700 text-kernel-200 transition cursor-pointer" data-cat="all">
        All ({domainCatalog.length})
      </button>
      {categories.map(cat => {
        const count = domainCatalog.filter(d => d.category === cat).length;
        return (
          <button class={`domain-cat-btn text-xs px-3 py-1.5 rounded-lg bg-kernel-800 hover:bg-kernel-700 transition cursor-pointer ${categoryColors[cat]?.split(' ')[0] || 'text-kernel-400'}`}
            data-cat={cat}>
            {cat} ({count})
