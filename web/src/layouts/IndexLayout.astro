  <!-- ═══════ §9  BY THE NUMBERS ═══════ -->
  <section class="mb-20">
    <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-6">
      <h2 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-6 text-center">By the Numbers</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-4 text-center">
        <div>
          <div class="text-2xl font-bold text-amber-400">1</div>
          <div class="text-xs text-kernel-500">Axiom</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-amber-400">6</div>
          <div class="text-xs text-kernel-500">Invariants</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-amber-400">3</div>
          <div class="text-xs text-kernel-500">DOF</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-blue-400">20</div>
          <div class="text-xs text-kernel-500">Domains</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-blue-400">{totalModules}</div>
          <div class="text-xs text-kernel-500">Modules</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-green-400">44</div>
          <div class="text-xs text-kernel-500">Identities</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-green-400">47</div>
          <div class="text-xs text-kernel-500">Lemmas</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-purple-400">14,565</div>
          <div class="text-xs text-kernel-500">Tests</div>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4 text-center text-xs text-kernel-500">
        <div>
          <span class="text-kernel-400 font-bold">{totalTheorems}+ theorems</span> proven across all domains
        </div>
        <div>
          <span class="text-kernel-400 font-bold">3 languages</span> — Python, C99, C++
        </div>
        <div>
          <span class="text-kernel-400 font-bold">9 papers</span> published (RevTeX4-2)
        </div>
