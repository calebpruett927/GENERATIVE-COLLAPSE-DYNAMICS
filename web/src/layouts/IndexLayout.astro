  <!-- ═══════ §10  PUBLISHED PAPERS ═══════ -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-bold text-kernel-200">Published Papers</h2>
      <a href={`${base}papers/`} class="text-xs text-amber-400 hover:text-amber-300 transition">View all →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <a href={`${base}papers/`} class="bg-kernel-900 border border-kernel-800 rounded-lg p-4 hover:border-amber-600/40 transition group no-underline block">
        <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition mb-1">Standard Model Kernel</div>
        <div class="text-xs text-kernel-500">31 particles, 10 theorems, 74/74 subtests</div>
      </a>
      <a href={`${base}papers/`} class="bg-kernel-900 border border-kernel-800 rounded-lg p-4 hover:border-amber-600/40 transition group no-underline block">
        <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition mb-1">RCFT Second Edition</div>
        <div class="text-xs text-kernel-500">Recursive collapse field theory foundations</div>
      </a>
      <a href={`${base}papers/`} class="bg-kernel-900 border border-kernel-800 rounded-lg p-4 hover:border-amber-600/40 transition group no-underline block">
        <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition mb-1">Cross-Scale Matter</div>
        <div class="text-xs text-kernel-500">Quarks to bulk via five phase boundaries</div>
      </a>
    </div>
  </section>


  <!-- ═══════ §11  RAW DATA FALLBACK ═══════ -->
  <details class="mb-8">
    <summary class="text-xs text-kernel-600 cursor-pointer hover:text-kernel-400 transition">
      Raw domain table (generated data)
    </summary>
    <article class="prose prose-invert prose-sm max-w-none mt-4
      prose-table:w-full
      prose-th:text-left prose-th:text-kernel-400 prose-th:font-normal prose-th:border-b prose-th:border-kernel-700 prose-th:py-2
      prose-td:py-2 prose-td:border-b prose-td:border-kernel-800
      prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline">
      <slot />
    </article>
  </details>
</BaseLayout>


<script>
  // ── "What is GCD?" expandable intro cards ──
  const introDetails = [
    {
      title: 'One Axiom — The Foundation',
      body: `<p><strong>"Collapse is generative; only what returns is real."</strong></p>
        <p>This is the single axiom from which everything in GCD derives. It is not a metaphor — it is a constraint on admissible claims. Every equation, identity, theorem, and domain closure traces back to this axiom through a verifiable derivation chain.</p>
        <p>Classical results — AM-GM inequality, Shannon entropy, the exponential map, probability conservation — emerge as <em>degenerate limits</em> when degrees of freedom are removed from the GCD kernel. The arrow of derivation runs <strong>from the axiom to the classical result</strong>, never the reverse.</p>
        <p class="text-kernel-500 text-xs italic mt-2">Collapsus generativus est; solum quod redit, reale est.</p>`,
    },
    {
      title: 'One Kernel — The Mathematical Engine',
      body: `<p>The kernel function K: [0,1]ⁿ × Δⁿ → (F, ω, S, C, κ, IC) takes a <strong>trace vector</strong> c (channel values in [0,1]) and <strong>weights</strong> w (summing to 1) and produces six invariants:</p>
        <div class="grid grid-cols-3 gap-2 my-3 text-xs">
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-amber-400">F</strong> — Fidelity (what survives)</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-red-400">ω</strong> — Drift (what is lost)</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-blue-400">S</strong> — Entropy (field uncertainty)</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-green-400">C</strong> — Curvature (channel coupling)</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-purple-400">κ</strong> — Log-integrity (log sensitivity)</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-cyan-400">IC</strong> — Integrity (multiplicative coherence)</div>
        </div>
        <p>Three algebraic identities always hold: <code>F + ω = 1</code> (exact to 0.0e+00), <code>IC ≤ F</code> (solvability condition), and <code>IC = exp(κ)</code>. One statistical constraint (S ≈ f(F,C)) reduces six outputs to <strong>3 effective degrees of freedom</strong>.</p>`,
    },
    {
      title: 'Three Tiers — Immutable Architecture',
      body: `<p>GCD has a strict three-tier architecture with <strong>no back-edges</strong>:</p>
        <div class="space-y-2 my-3 text-xs">
          <div class="bg-kernel-950 p-2 rounded border-l-2 border-amber-500"><strong class="text-amber-400">Tier-1 • The Kernel</strong> — The mathematical function, its identities, lemmas, and frozen constants. Never changes within a run.</div>
          <div class="bg-kernel-950 p-2 rounded border-l-2 border-blue-500"><strong class="text-blue-400">Tier-0 • The Protocol</strong> — Code that implements the kernel: embedding, regime gates, seam calculus, verification. Configuration frozen per run.</div>
          <div class="bg-kernel-950 p-2 rounded border-l-2 border-green-500"><strong class="text-green-400">Tier-2 • Domain Closures</strong> — Choose which real-world quantities become channels. Freely extensible; validated before trust. Cannot modify Tier-0 or Tier-1.</div>
        </div>
        <p>Within a frozen run: Tier-1 → Tier-0 → Tier-2. <strong>No feedback from Tier-2 to Tier-1.</strong> Diagnostics inform but cannot override gates.</p>`,
    },
    {
      title: '20 Domains — From Quarks to Consciousness',
      body: `<p>Each domain closure selects a <strong>trace vector</strong> — which measurable quantities become the channels c₁, c₂, ..., cₙ fed to the kernel. The kernel is always the same; only the question changes.</p>
        <div class="grid grid-cols-2 gap-2 my-3 text-xs">
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-amber-400">Core</strong>: GCD, RCFT</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-blue-400">Physics</strong>: Standard Model, Nuclear, Quantum, Atomic, Materials, Everyday, Kinematics, Weyl, Spacetime Memory</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-cyan-400">Science</strong>: Astronomy</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-green-400">Biology</strong>: Evolution & Neuroscience</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-purple-400">Cognition</strong>: Consciousness, Awareness, Clinical Neuro</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-emerald-400">Applied</strong>: Finance, Security</div>
          <div class="bg-kernel-950 p-2 rounded"><strong class="text-rose-400">Humanities</strong>: Semiotics, Continuity Theory</div>
        </div>
        <p>All domains produce three-valued verdicts: <span class="text-green-400">CONFORMANT</span> / <span class="text-red-400">NONCONFORMANT</span> / <span class="text-kernel-400">NON_EVALUABLE</span>. The same kernel, the same spine, the same gates — applied to different questions.</p>`,
    },
  ];

  // Wire up intro card clicks
  const introCards = document.querySelectorAll('.intro-card');
  const introDetail = document.getElementById('intro-detail')!;
  const introTitle = document.getElementById('intro-title')!;
  const introBody = document.getElementById('intro-body')!;
  const introClose = document.getElementById('intro-close')!;

  introCards.forEach(card => {
    card.addEventListener('click', () => {
      const idx = parseInt((card as HTMLElement).dataset.idx || '0');
      const d = introDetails[idx];
      introTitle.textContent = d.title;
      introBody.innerHTML = d.body;
      introDetail.classList.remove('hidden');

      // Highlight active card
      introCards.forEach((c, i) => {
        if (i === idx) {
          (c as HTMLElement).classList.add('ring-1', 'ring-amber-500/50');
        } else {
          (c as HTMLElement).classList.remove('ring-1', 'ring-amber-500/50');
        }
      });

      introDetail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  introClose.addEventListener('click', () => {
    introDetail.classList.add('hidden');
    introCards.forEach(c => (c as HTMLElement).classList.remove('ring-1', 'ring-amber-500/50'));
  });


  // ── Domain category filter ──
  document.querySelectorAll('.domain-cat-btn').forEach(btn =>
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.cat!;

      document.querySelectorAll('.domain-cat-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.cat === cat;
        if (isActive) {
          (b as HTMLElement).classList.remove('bg-kernel-800');
          (b as HTMLElement).classList.add('bg-kernel-700', 'text-kernel-200');
        } else {
          (b as HTMLElement).classList.remove('bg-kernel-700', 'text-kernel-200');
          (b as HTMLElement).classList.add('bg-kernel-800');
        }
      });

      document.querySelectorAll('.domain-card').forEach(card => {
        const cardCat = (card as HTMLElement).dataset.category;
        if (cat === 'all' || cardCat === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    })
  );


  // ── Hero canvas: subtle floating particles ──
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      const resize = () => {
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize);

      const particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
      for (let i = 0; i < 40; i++) {
        particles.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.3,
          r: Math.random() * 2 + 0.5,
        });
      }

      const draw = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgba(245, 158, 11, 0.4)';
        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
          if (p.y < 0 || p.y > canvas.height) p.vy *= -1;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
        }
        // Draw faint connections between nearby particles
        ctx.strokeStyle = 'rgba(245, 158, 11, 0.08)';
        ctx.lineWidth = 0.5;
        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 120) {
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(draw);
      };
      draw();
    }
  }
</script>
