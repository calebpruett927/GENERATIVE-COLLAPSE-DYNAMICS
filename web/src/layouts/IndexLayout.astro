---
/**
 * Root index layout — GCD front page and navigation hub.
 * Introduces newcomers, explains the architecture, and guides exploration.
 */
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title = 'Generative Collapse Dynamics', description = 'A single-axiom mathematical framework that measures what survives collapse and what returns — across 20 scientific domains.' } = frontmatter || {};
const base = import.meta.env.BASE_URL;

/* ── Tool categories ────────────────────────────────── */
const toolCategories = [
  {
    name: 'Compute',
    color: 'text-amber-400',
    border: 'border-amber-800/40',
    tools: [
      { name: 'Calculator', href: `${base}calculator/`, desc: 'Kernel invariants from any trace vector', icon: '⊕' },
      { name: 'Formulas', href: `${base}formulas/`, desc: 'Build & sweep mathematical expressions', icon: 'ƒ' },
      { name: 'Mapper', href: `${base}mapper/`, desc: 'Map kernel signatures to real physics', icon: '⚛' },
    ],
  },
  {
    name: 'Visualize',
    color: 'text-blue-400',
    border: 'border-blue-800/40',
    tools: [
      { name: 'Regime', href: `${base}regime/`, desc: 'Phase diagram: Stable / Watch / Collapse', icon: '◉' },
      { name: 'τ_R*', href: `${base}diagnostics/`, desc: 'Thermodynamic return diagnostic heatmap', icon: '∇' },
      { name: 'Seam Budget', href: `${base}seam-budget/`, desc: 'Explore Γ(ω), D_C, and Δκ budget', icon: '⊖' },
    ],
  },
  {
    name: 'Verify',
    color: 'text-green-400',
    border: 'border-green-800/40',
    tools: [
      { name: 'Precision', href: `${base}precision/`, desc: '15-decimal identity verification sweep', icon: '✓' },
      { name: 'Identities', href: `${base}identities/`, desc: '44 structural identities with proofs', icon: '≡' },
      { name: 'Scale Ladder', href: `${base}scale-ladder/`, desc: 'Cross-scale IC/F coherence oscillation', icon: '⇅' },
    ],
  },
  {
    name: 'Reference',
    color: 'text-purple-400',
    border: 'border-purple-800/40',
    tools: [
      { name: 'Mathematics', href: `${base}mathematics/`, desc: 'Full algebra, calculus, convergence', icon: '∫' },
      { name: 'Geometry', href: `${base}geometry/`, desc: 'Flat manifold, Fisher metric, proofs', icon: 'Σ' },
      { name: 'Rosetta', href: `${base}rosetta/`, desc: 'Cross-domain 6-lens translation', icon: '⟷' },
      { name: 'Ledger', href: `${base}ledger/`, desc: 'Domain overview with kernel metrics', icon: '☰' },
      { name: 'Index', href: `${base}reference/`, desc: 'Searchable cross-reference', icon: '⊞' },
    ],
  },
];

/* ── Corpus: deep reading pages ─────────────────────── */
const corpus = [
  { title: 'Grammar of Return', desc: 'Five words, one spine, discourse structure — how every claim is told, checked, and connected.', href: `${base}grammar/`, latin: 'Quinque Verba', icon: '§' },
  { title: 'Episteme of Return', desc: 'Observation cost (Theorem T9), positional illusion, cognitive equalizer, reproducibility.', href: `${base}epistemology/`, latin: 'Episteme Reditus', icon: '⊙' },
  { title: 'Philosophy of Collapse', desc: 'Camus, Nietzsche, Jung, Sartre — philosophical parallels computed through the kernel.', href: `${base}philosophy/`, latin: 'Philosophia Collapsus', icon: '∞' },
  { title: 'Mathematics', desc: 'Full algebra, calculus, 9 convergence moments, classical limits, seam calculus, rank theory.', href: `${base}mathematics/`, latin: 'Mathematica Collapsus', icon: '∫' },
  { title: 'Geometry', desc: 'The flat Bernoulli manifold, Fisher metric, composition algebra, geometric proofs.', href: `${base}geometry/`, latin: 'Geometria Manifoldum', icon: 'Σ' },
  { title: 'Orientation', desc: 'Ten computational re-derivations. Understanding is not read; it is computed.', href: `${base}orientation/`, latin: 'Intellectus Computatur', icon: '◈' },
];

/* ── Domain catalog: 20 closure domains ─────────────── */
const domainCatalog = [
  { slug: 'gcd', name: 'Generative Collapse Dynamics', lens: 'Epistemology', modules: 8, category: 'Core', desc: 'The axiom, the kernel, the spine.', channels: 6, theorems: 20 },
  { slug: 'rcft', name: 'Recursive Collapse Field Theory', lens: 'Epistemology', modules: 11, category: 'Core', desc: 'Recursive field-theoretic structure of collapse.', channels: 8, theorems: 12 },
  { slug: 'kinematics', name: 'Kinematics', lens: 'Ontology', modules: 8, category: 'Physics', desc: 'Motion, phase space, and trajectory analysis.', channels: 8, theorems: 10 },
  { slug: 'weyl', name: 'WEYL Cosmology', lens: 'Ontology', modules: 7, category: 'Physics', desc: 'Modified gravity and cosmological structure.', channels: 8, theorems: 8 },
  { slug: 'standard_model', name: 'Standard Model', lens: 'Ontology', modules: 13, category: 'Physics', desc: '31 particles → 8-channel trace. 27 proven theorems.', channels: 8, theorems: 27 },
  { slug: 'nuclear_physics', name: 'Nuclear Physics', lens: 'Ontology', modules: 12, category: 'Physics', desc: 'Binding energy, decay, QGP, confinement.', channels: 8, theorems: 10 },
  { slug: 'quantum_mechanics', name: 'Quantum Mechanics', lens: 'Phenomenology', modules: 14, category: 'Physics', desc: 'Wavefunction, entanglement, QDM, FQHE.', channels: 8, theorems: 15 },
  { slug: 'atomic_physics', name: 'Atomic Physics', lens: 'Ontology', modules: 10, category: 'Physics', desc: '118 elements — full periodic kernel.', channels: 8, theorems: 10 },
  { slug: 'materials_science', name: 'Materials Science', lens: 'Ontology', modules: 17, category: 'Physics', desc: '118 elements × 18 fields.', channels: 8, theorems: 6 },
  { slug: 'everyday_physics', name: 'Everyday Physics', lens: 'Phenomenology', modules: 8, category: 'Physics', desc: 'Thermo, optics, E&M, waves, fluids.', channels: 8, theorems: 6 },
  { slug: 'finance', name: 'Finance', lens: 'Policy', modules: 5, category: 'Applied', desc: 'Portfolio continuity and market coherence.', channels: 8, theorems: 6 },
  { slug: 'security', name: 'Security & Audit', lens: 'Policy', modules: 15, category: 'Applied', desc: 'Input validation, audit, integrity.', channels: 8, theorems: 6 },
  { slug: 'astronomy', name: 'Astronomy', lens: 'Ontology', modules: 11, category: 'Science', desc: 'Stellar classification, HR diagram, ages.', channels: 8, theorems: 8 },
  { slug: 'evolution', name: 'Evolution & Neuroscience', lens: 'History', modules: 8, category: 'Biology', desc: '40 organisms, 10-channel brain kernel.', channels: 10, theorems: 10 },
  { slug: 'consciousness_coherence', name: 'Consciousness Coherence', lens: 'Phenomenology', modules: 4, category: 'Cognition', desc: '20 systems, 7 theorems, altered states.', channels: 8, theorems: 7 },
  { slug: 'awareness_cognition', name: 'Awareness & Cognition', lens: 'Phenomenology', modules: 3, category: 'Cognition', desc: '5+5 channel awareness-aptitude kernel.', channels: 10, theorems: 10 },
  { slug: 'clinical_neuroscience', name: 'Clinical Neuroscience', lens: 'Phenomenology', modules: 5, category: 'Cognition', desc: '10-channel cortical kernel, neurotransmitters.', channels: 10, theorems: 6 },
  { slug: 'dynamic_semiotics', name: 'Dynamic Semiotics', lens: 'Semiotics', modules: 4, category: 'Humanities', desc: '30 sign systems, 8-channel semiotic kernel.', channels: 8, theorems: 6 },
  { slug: 'continuity_theory', name: 'Continuity Theory', lens: 'History', modules: 5, category: 'Humanities', desc: 'Continuity law, topological persistence.', channels: 8, theorems: 6 },
  { slug: 'spacetime_memory', name: 'Spacetime Memory', lens: 'Ontology', modules: 6, category: 'Physics', desc: '40 entities, gravitational memory.', channels: 8, theorems: 10 },
];

const categories = ['Core', 'Physics', 'Science', 'Biology', 'Cognition', 'Applied', 'Humanities'];

const categoryColors: Record<string, string> = {
  Core: 'text-amber-400 border-amber-600/40 bg-amber-900/10',
  Physics: 'text-blue-400 border-blue-600/40 bg-blue-900/10',
  Science: 'text-cyan-400 border-cyan-600/40 bg-cyan-900/10',
  Biology: 'text-green-400 border-green-600/40 bg-green-900/10',
  Cognition: 'text-purple-400 border-purple-600/40 bg-purple-900/10',
  Applied: 'text-emerald-400 border-emerald-600/40 bg-emerald-900/10',
  Humanities: 'text-rose-400 border-rose-600/40 bg-rose-900/10',
};

const lensColors: Record<string, string> = {
  Epistemology: 'text-amber-400',
  Ontology: 'text-blue-400',
  Phenomenology: 'text-purple-400',
  History: 'text-rose-400',
  Policy: 'text-emerald-400',
  Semiotics: 'text-cyan-400',
};

const totalTheorems = domainCatalog.reduce((s, d) => s + d.theorems, 0);
const totalModules = domainCatalog.reduce((s, d) => s + d.modules, 0);
---

<BaseLayout title={title} description={description}>

  <!-- ═══════ §1  HERO ═══════ -->
  <section class="text-center mb-20 mt-10 relative" id="hero">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <canvas id="hero-canvas" class="w-full h-full opacity-20"></canvas>
    </div>

    <p class="text-sm font-mono text-kernel-500 tracking-widest uppercase mb-4">Single-Axiom Mathematical Framework</p>

    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
      Generative Collapse<br class="hidden md:block" />
      <span class="text-amber-400">Dynamics</span>
    </h1>

    <blockquote class="text-xl text-kernel-300 italic mb-2 max-w-2xl mx-auto">
      "Collapse is generative; only what returns is real."
    </blockquote>
    <p class="text-sm text-kernel-500 font-mono italic mb-8">
      Collapsus generativus est; solum quod redit, reale est.
    </p>

    <p class="text-kernel-400 max-w-3xl mx-auto mb-8 leading-relaxed">
      A mathematical framework built from a single axiom that measures what survives collapse,
      what returns, and why — verified across <strong class="text-kernel-200">20 scientific domains</strong>,
      <strong class="text-kernel-200">{totalTheorems}+ theorems</strong>,
      and <strong class="text-kernel-200">44 structural identities</strong> to machine precision.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={`${base}calculator/`}
         class="px-6 py-3 bg-amber-600 hover:bg-amber-500 text-kernel-950 font-bold rounded-lg transition text-sm">
        Start Computing
      </a>
      <a href={`${base}mathematics/`}
         class="px-6 py-3 bg-kernel-800 hover:bg-kernel-700 text-kernel-200 font-bold rounded-lg border border-kernel-600 transition text-sm">
        Read the Mathematics
      </a>
      <a href={`${base}about/`}
         class="px-6 py-3 bg-kernel-800 hover:bg-kernel-700 text-kernel-200 font-bold rounded-lg border border-kernel-600 transition text-sm">
        What is GCD?
      </a>
    </div>
  </section>


  <!-- ═══════ §2  WHAT IS GCD? (expandable intro) ═══════ -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-kernel-200 mb-2">Understanding the Framework</h2>
    <p class="text-sm text-kernel-500 mb-6">Click any card to learn more.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="intro-cards">
      <!-- Card 1: One Axiom -->
      <button class="intro-card text-left bg-kernel-900 border border-kernel-800 rounded-lg p-5 hover:border-amber-700/60 transition cursor-pointer" data-idx="0">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">𝔸</span>
          <h3 class="text-lg font-bold text-amber-400">One Axiom</h3>
        </div>
        <p class="text-sm text-kernel-400">Everything derives from a single axiom — no external theories imported, no borrowed structures.</p>
      </button>

      <!-- Card 2: One Kernel -->
      <button class="intro-card text-left bg-kernel-900 border border-kernel-800 rounded-lg p-5 hover:border-blue-700/60 transition cursor-pointer" data-idx="1">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">𝕂</span>
          <h3 class="text-lg font-bold text-blue-400">One Kernel</h3>
        </div>
        <p class="text-sm text-kernel-400">Four equations produce six outputs with three effective degrees of freedom — the complete measurement.</p>
      </button>

      <!-- Card 3: Three Tiers -->
      <button class="intro-card text-left bg-kernel-900 border border-kernel-800 rounded-lg p-5 hover:border-green-700/60 transition cursor-pointer" data-idx="2">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">⊟</span>
          <h3 class="text-lg font-bold text-green-400">Three Tiers</h3>
        </div>
        <p class="text-sm text-kernel-400">Immutable mathematics (Tier-1) → operational protocol (Tier-0) → domain closures (Tier-2). No back-edges.</p>
      </button>

      <!-- Card 4: 20 Domains -->
      <button class="intro-card text-left bg-kernel-900 border border-kernel-800 rounded-lg p-5 hover:border-purple-700/60 transition cursor-pointer" data-idx="3">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">◎</span>
          <h3 class="text-lg font-bold text-purple-400">20 Domains</h3>
        </div>
        <p class="text-sm text-kernel-400">From quarks to consciousness — each domain maps real-world data through the same kernel.</p>
      </button>
    </div>

    <!-- Expandable detail panels -->
    <div id="intro-detail" class="hidden mt-4 bg-kernel-900/80 border border-kernel-700 rounded-lg p-6 relative">
      <button id="intro-close" class="absolute top-3 right-3 text-kernel-500 hover:text-kernel-300 text-lg cursor-pointer">✕</button>
      <h4 id="intro-title" class="text-lg font-bold text-kernel-200 mb-3"></h4>
      <div id="intro-body" class="text-sm text-kernel-400 leading-relaxed space-y-3"></div>
    </div>
  </section>


  <!-- ═══════ §3  START HERE — Choose Your Path ═══════ -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-kernel-200 mb-2">Start Here</h2>
    <p class="text-sm text-kernel-500 mb-6">Choose how you want to explore GCD.</p>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-3">
      <a href={`${base}mathematics/`}
         class="bg-kernel-900 border border-amber-800/40 rounded-lg p-4 hover:border-amber-500/60 transition group text-center no-underline block">
        <div class="text-3xl mb-2 opacity-70 group-hover:opacity-100 transition">∫</div>
        <div class="text-sm font-bold text-kernel-200 group-hover:text-amber-400 transition">Explore the Math</div>
        <div class="text-xs text-kernel-500 mt-1">Full algebra, calculus, identities</div>
      </a>

      <a href={`${base}calculator/`}
         class="bg-kernel-900 border border-blue-800/40 rounded-lg p-4 hover:border-blue-500/60 transition group text-center no-underline block">
        <div class="text-3xl mb-2 opacity-70 group-hover:opacity-100 transition">⊕</div>
        <div class="text-sm font-bold text-kernel-200 group-hover:text-blue-400 transition">Run the Calculator</div>
        <div class="text-xs text-kernel-500 mt-1">Compute invariants live</div>
      </a>

      <a href={`${base}grammar/`}
         class="bg-kernel-900 border border-purple-800/40 rounded-lg p-4 hover:border-purple-500/60 transition group text-center no-underline block">
        <div class="text-3xl mb-2 opacity-70 group-hover:opacity-100 transition">§</div>
        <div class="text-sm font-bold text-kernel-200 group-hover:text-purple-400 transition">Read the Theory</div>
        <div class="text-xs text-kernel-500 mt-1">Grammar, episteme, philosophy</div>
      </a>

      <a href="#domains"
         class="bg-kernel-900 border border-green-800/40 rounded-lg p-4 hover:border-green-500/60 transition group text-center no-underline block">
        <div class="text-3xl mb-2 opacity-70 group-hover:opacity-100 transition">◎</div>
        <div class="text-sm font-bold text-kernel-200 group-hover:text-green-400 transition">Browse Domains</div>
        <div class="text-xs text-kernel-500 mt-1">20 scientific domains</div>
      </a>

      <a href={`${base}precision/`}
         class="bg-kernel-900 border border-cyan-800/40 rounded-lg p-4 hover:border-cyan-500/60 transition group text-center no-underline block">
        <div class="text-3xl mb-2 opacity-70 group-hover:opacity-100 transition">✓</div>
        <div class="text-sm font-bold text-kernel-200 group-hover:text-cyan-400 transition">Verify the Claims</div>
        <div class="text-xs text-kernel-500 mt-1">15-decimal identity sweeps</div>
      </a>
    </div>
  </section>


  <!-- ═══════ §4  ARCHITECTURE: The Spine & Three Tiers ═══════ -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-kernel-200 mb-2">Architecture</h2>
    <p class="text-sm text-kernel-500 mb-6">Every claim in GCD passes through the same five-stop spine. No exceptions.</p>

    <!-- The Spine -->
    <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-6 mb-6">
      <h3 class="text-sm font-bold text-kernel-400 uppercase tracking-wider mb-4">The Spine</h3>
      <div class="flex flex-wrap items-center justify-center gap-1 md:gap-2 text-xs font-mono mb-6">
        <div class="px-3 py-2 bg-amber-900/30 text-amber-400 rounded border border-amber-700/40">CONTRACT</div>
        <span class="text-kernel-600">→</span>
        <div class="px-3 py-2 bg-blue-900/30 text-blue-400 rounded border border-blue-700/40">CANON</div>
        <span class="text-kernel-600">→</span>
        <div class="px-3 py-2 bg-green-900/30 text-green-400 rounded border border-green-700/40">CLOSURES</div>
        <span class="text-kernel-600">→</span>
        <div class="px-3 py-2 bg-purple-900/30 text-purple-400 rounded border border-purple-700/40">LEDGER</div>
        <span class="text-kernel-600">→</span>
        <div class="px-3 py-2 bg-cyan-900/30 text-cyan-400 rounded border border-cyan-700/40">STANCE</div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-3 text-xs text-kernel-500">
        <div><strong class="text-amber-400">Contract</strong> — Define rules <em>before</em> evidence. Freeze sources, norms, thresholds.</div>
        <div><strong class="text-blue-400">Canon</strong> — Tell the story using five words: Drift, Fidelity, Roughness, Return, Integrity.</div>
        <div><strong class="text-green-400">Closures</strong> — Publish threshold gates. Stance must change when gates are crossed.</div>
        <div><strong class="text-purple-400">Ledger</strong> — Debit Drift + Roughness, credit Return. The account must reconcile.</div>
        <div><strong class="text-cyan-400">Stance</strong> — Derived verdict: Stable / Watch / Collapse. Never asserted — always computed.</div>
      </div>
    </div>

    <!-- Three Tiers -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-kernel-900 border border-amber-700/30 rounded-lg p-5">
        <div class="text-xs font-mono text-amber-400 mb-1">TIER-1</div>
        <h3 class="text-lg font-bold text-kernel-200 mb-2">The Kernel</h3>
        <p class="text-sm text-kernel-400 mb-3">The mathematical function K: [0,1]ⁿ × Δⁿ → (F, ω, S, C, κ, IC). Four primitive equations, six outputs, three effective degrees of freedom. Immutable.</p>
        <div class="text-xs text-kernel-500 space-y-1">
          <div>• 3 algebraic identities: F+ω=1, IC≤F, IC=exp(κ)</div>
          <div>• 44 structural identities verified to 10⁻¹⁶</div>
          <div>• 47 lemmas, 5 frozen constants</div>
        </div>
      </div>
      <div class="bg-kernel-900 border border-blue-700/30 rounded-lg p-5">
        <div class="text-xs font-mono text-blue-400 mb-1">TIER-0</div>
        <h3 class="text-lg font-bold text-kernel-200 mb-2">The Protocol</h3>
        <p class="text-sm text-kernel-400 mb-3">Operational machinery: embedding data into [0,1]ⁿ, computing the kernel, regime gates, seam calculus, verification. The code is Tier-0; what it computes is Tier-1.</p>
        <div class="text-xs text-kernel-500 space-y-1">
          <div>• Python + C99 + C++ implementations</div>
          <div>• Three-valued verdicts, never boolean</div>
          <div>• Frozen parameters from the seam</div>
        </div>
      </div>
      <div class="bg-kernel-900 border border-green-700/30 rounded-lg p-5">
        <div class="text-xs font-mono text-green-400 mb-1">TIER-2</div>
        <h3 class="text-lg font-bold text-kernel-200 mb-2">Domain Closures</h3>
        <p class="text-sm text-kernel-400 mb-3">Tier-2 selects which real-world quantities become channels. Each domain maps data through the same kernel — different questions, same mathematics.</p>
        <div class="text-xs text-kernel-500 space-y-1">
          <div>• 20 domains from quarks to consciousness</div>
          <div>• {totalTheorems}+ domain-specific theorems</div>
          <div>• {totalModules} closure modules</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════ §5  THE KERNEL (6 invariants mini-overview) ═══════ -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-kernel-200 mb-2">The Kernel — Six Invariants</h2>
    <p class="text-sm text-kernel-500 mb-6">
      The kernel function takes a trace vector c ∈ [0,1]ⁿ with weights w ∈ Δⁿ and outputs six invariants.
      Three are primitive (F, κ, S, C); two are derived (ω = 1−F, IC = exp(κ)).
      Only three degrees of freedom remain: F, κ, C.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-amber-400 font-mono">F</div>
        <div class="text-xs text-kernel-400 mt-1">Fidelity</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">Σ wᵢcᵢ</div>
      </div>
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-red-400 font-mono">ω</div>
        <div class="text-xs text-kernel-400 mt-1">Drift</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">1 − F</div>
      </div>
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-blue-400 font-mono">S</div>
        <div class="text-xs text-kernel-400 mt-1">Entropy</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">Bernoulli</div>
      </div>
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-green-400 font-mono">C</div>
        <div class="text-xs text-kernel-400 mt-1">Curvature</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">σ(cᵢ)/0.5</div>
      </div>
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-purple-400 font-mono">κ</div>
        <div class="text-xs text-kernel-400 mt-1">Log-integrity</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">Σ wᵢ ln cᵢ</div>
      </div>
      <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-3 text-center">
        <div class="text-2xl font-bold text-cyan-400 font-mono">IC</div>
        <div class="text-xs text-kernel-400 mt-1">Integrity</div>
        <div class="text-[10px] text-kernel-600 font-mono mt-1">exp(κ)</div>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap gap-4 justify-center">
      <a href={`${base}mathematics/`} class="text-xs text-amber-400 hover:text-amber-300 transition">Full algebra →</a>
      <a href={`${base}geometry/`} class="text-xs text-blue-400 hover:text-blue-300 transition">Geometric structure →</a>
      <a href={`${base}calculator/`} class="text-xs text-green-400 hover:text-green-300 transition">Compute live →</a>
    </div>
  </section>


  <!-- ═══════ §6  THE CORPUS — Deep Reading ═══════ -->
  <section class="mb-20">
    <h2 class="text-2xl font-bold text-kernel-200 mb-2">The Corpus</h2>
    <p class="text-sm text-kernel-500 mb-6">
