  // ── Rendering ──

  const dpr = Math.min(window.devicePixelRatio || 1, 3);

  function initCanvas() {
    const canvas = document.getElementById('tl-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const rect = canvas.getBoundingClientRect();
    const w = rect.width;
    const h = 320;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = `${w}px`;
    canvas.style.height = `${h}px`;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.scale(dpr, dpr);
    drawTimeline(ctx, w, h);
    setupCanvasHover(canvas, ctx, w, h);
  }

  function parseDate(s: string): number {
    return new Date(s).getTime();
  }

  const T_MIN = parseDate('2025-05-01');
  const T_MAX = parseDate('2026-03-30');
  const T_RANGE = T_MAX - T_MIN;

  function mapT(t: number, w: number, margin: number): number {
    return margin + ((t - T_MIN) / T_RANGE) * (w - 2 * margin);
  }

  function mapY(v: number, h: number, margin: number, yMin: number, yMax: number): number {
    return h - margin - ((v - yMin) / (yMax - yMin)) * (h - 2 * margin);
  }

  function drawTimeline(ctx: CanvasRenderingContext2D, w: number, h: number) {
    const m = { l: 50, r: 20, t: 20, b: 40 };
    const font = "'JetBrains Mono', 'SF Mono', 'Fira Code', monospace";

    // Background
    ctx.fillStyle = '#0c0c14';
    ctx.fillRect(0, 0, w, h);

    // Grid
    ctx.strokeStyle = '#1e293b';
    ctx.lineWidth = 0.5;
    for (let y = 0; y <= 1; y += 0.2) {
      const py = mapY(y, h, m.t, 0, 1);
      if (py > m.t && py < h - m.b) {
        ctx.beginPath(); ctx.moveTo(m.l, py); ctx.lineTo(w - m.r, py); ctx.stroke();
        ctx.fillStyle = '#475569';
        ctx.font = `9px ${font}`;
        ctx.textAlign = 'right';
        ctx.fillText(y.toFixed(1), m.l - 5, py + 3);
      }
    }

    // Time axis: month labels
    const months = ['2025-05', '2025-07', '2025-09', '2025-11', '2026-01', '2026-02', '2026-03'];
    ctx.fillStyle = '#475569';
    ctx.font = `9px ${font}`;
    ctx.textAlign = 'center';
    for (const m_str of months) {
      const t = parseDate(m_str + '-01');
      const x = mapT(t, w, m.l);
      if (x > m.l && x < w - m.r) {
        ctx.beginPath(); ctx.moveTo(x, h - m.b); ctx.lineTo(x, h - m.b + 5); ctx.strokeStyle = '#475569'; ctx.stroke();
        ctx.fillText(m_str, x, h - m.b + 16);
      }
    }

    // Axes
    ctx.strokeStyle = '#64748b';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(m.l, m.t); ctx.lineTo(m.l, h - m.b); ctx.lineTo(w - m.r, h - m.b); ctx.stroke();

    // Y-axis label
    ctx.save();
    ctx.translate(12, h / 2);
    ctx.rotate(-Math.PI / 2);
    ctx.fillStyle = '#94a3b8';
    ctx.font = `10px ${font}`;
    ctx.textAlign = 'center';
    ctx.fillText('Value', 0, 0);
    ctx.restore();

    // ── Layer: Freeze points (vertical dashed lines) ──
    for (const fp of FREEZES) {
      const x = mapT(parseDate(fp.date), w, m.l);
      ctx.setLineDash([4, 4]);
      ctx.strokeStyle = '#22d3ee44';
      ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(x, m.t); ctx.lineTo(x, h - m.b); ctx.stroke();
      ctx.setLineDash([]);
      // Marker
      ctx.beginPath();
      ctx.arc(x, m.t + 8, 4, 0, Math.PI * 2);
      ctx.strokeStyle = '#22d3ee';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // ── Layer: Version milestones (vertical marks) ──
    for (const v of VERSIONS) {
      const x = mapT(parseDate(v.date), w, m.l);
      ctx.setLineDash([2, 3]);
      ctx.strokeStyle = v.kind === 'major' ? '#a855f766' : '#a855f733';
      ctx.lineWidth = v.kind === 'major' ? 1.5 : 0.8;
      ctx.beginPath(); ctx.moveTo(x, m.t); ctx.lineTo(x, h - m.b); ctx.stroke();
      ctx.setLineDash([]);
      // Version label (only for major + select minor)
      if (v.kind === 'major' || v.version === '2.3.0' || v.version === '2.1.3') {
        ctx.fillStyle = '#c084fc';
        ctx.font = `bold 8px ${font}`;
        ctx.textAlign = 'center';
        ctx.fillText(`v${v.version}`, x, m.t + 20);
      }
    }

    // ── Layer: Ledger stream (F, IC, ω curves) ──
    const drawCurve = (data: { t: number; v: number }[], color: string, lw: number) => {
      if (data.length < 2) return;
      ctx.strokeStyle = color;
      ctx.lineWidth = lw;
      ctx.beginPath();
      data.forEach((d, i) => {
        const x = mapT(d.t, w, m.l);
        const y = mapY(d.v, h, m.t, 0, 1);
        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
      });
      ctx.stroke();
    };

    const fData = LEDGER_SAMPLES.map(s => ({ t: parseDate(s.timestamp), v: s.F }));
    const icData = LEDGER_SAMPLES.map(s => ({ t: parseDate(s.timestamp), v: s.IC }));
    const omData = LEDGER_SAMPLES.map(s => ({ t: parseDate(s.timestamp), v: s.omega }));

    drawCurve(fData, '#fbbf24', 2);    // F: amber
    drawCurve(icData, '#34d399', 2);    // IC: green
    drawCurve(omData, '#f87171', 1.5);  // ω: red

    // Shade region between F and IC (heterogeneity gap)
    ctx.fillStyle = '#fbbf2410';
    ctx.beginPath();
    fData.forEach((d, i) => {
      const x = mapT(d.t, w, m.l);
      const y = mapY(d.v, h, m.t, 0, 1);
      if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    });
    for (let i = icData.length - 1; i >= 0; i--) {
      const x = mapT(icData[i].t, w, m.l);
      const y = mapY(icData[i].v, h, m.t, 0, 1);
      ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.fill();

    // ── Layer: Weld events (circles on timeline) ──
    for (const we of WELDS) {
      const x = mapT(parseDate(we.date), w, m.l);
      const yPre = mapY(we.IC_pre, h, m.t, 0, 1);
      const yPost = mapY(we.IC_post, h, m.t, 0, 1);

      // Arrow from pre to post
      ctx.strokeStyle = '#3b82f6';
      ctx.lineWidth = 1.5;
      ctx.setLineDash([3, 2]);
      ctx.beginPath(); ctx.moveTo(x, yPre); ctx.lineTo(x, yPost); ctx.stroke();
      ctx.setLineDash([]);

      // Pre marker
      ctx.beginPath();
      ctx.arc(x, yPre, 3, 0, Math.PI * 2);
      ctx.fillStyle = '#1e40af';
      ctx.fill();

      // Post marker
      ctx.beginPath();
      ctx.arc(x, yPost, 5, 0, Math.PI * 2);
      ctx.fillStyle = '#3b82f6';
      ctx.fill();
      ctx.strokeStyle = '#93c5fd';
      ctx.lineWidth = 1;
      ctx.stroke();
    }

    // ── Regime band at bottom ──
    const bandH = 6;
    const bandY = h - m.b - bandH - 2;
    for (let i = 0; i < LEDGER_SAMPLES.length - 1; i++) {
      const s = LEDGER_SAMPLES[i];
      const next = LEDGER_SAMPLES[i + 1];
      const x1 = mapT(parseDate(s.timestamp), w, m.l);
      const x2 = mapT(parseDate(next.timestamp), w, m.l);
      ctx.fillStyle = s.regime === 'STABLE' ? '#059669' : s.regime === 'WATCH' ? '#d97706' : '#dc2626';
      ctx.fillRect(x1, bandY, x2 - x1, bandH);
    }
  }

  function setupCanvasHover(canvas: HTMLCanvasElement, ctx: CanvasRenderingContext2D, w: number, h: number) {
    const tooltip = document.getElementById('tl-tooltip');
    if (!tooltip) return;

    const m = { l: 50, r: 20, t: 20, b: 40 };

    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;

      // Find nearest weld
      let nearestWeld: WeldEvent | null = null;
      let minDist = 30;
      for (const we of WELDS) {
        const x = mapT(parseDate(we.date), w, m.l);
        const yPost = mapY(we.IC_post, h, m.t, 0, 1);
        const d = Math.sqrt((mx - x) ** 2 + (my - yPost) ** 2);
        if (d < minDist) { minDist = d; nearestWeld = we; }
      }

      // Find nearest version
      let nearestVer: VersionMilestone | null = null;
      let minVerDist = 20;
      for (const v of VERSIONS) {
        const x = mapT(parseDate(v.date), w, m.l);
        const d = Math.abs(mx - x);
        if (d < minVerDist) { minVerDist = d; nearestVer = v; }
      }

      // Find nearest ledger point
      let nearestLedger: LedgerSample | null = null;
      let minLedgerDist = 20;
      for (const s of LEDGER_SAMPLES) {
        const x = mapT(parseDate(s.timestamp), w, m.l);
        const d = Math.abs(mx - x);
        if (d < minLedgerDist) { minLedgerDist = d; nearestLedger = s; }
      }

      if (nearestWeld && minDist < 30) {
        tooltip.classList.remove('hidden');
        tooltip.style.left = `${mx + 12}px`;
        tooltip.style.top = `${my - 20}px`;
        tooltip.innerHTML = `
          <div class="font-bold text-blue-400 mb-1">${nearestWeld.seam_id}</div>
          <div>IC: ${nearestWeld.IC_pre.toFixed(3)} → ${nearestWeld.IC_post.toFixed(3)}</div>
          <div>Ratio: ${nearestWeld.integrity_ratio.toFixed(3)}</div>
          <div>Residual: ${nearestWeld.seam_residual.toFixed(4)} (tol: ${TOL_SEAM})</div>
          <div class="text-kernel-500 mt-1">${nearestWeld.weld_type}</div>
        `;
      } else if (nearestVer && minVerDist < 15) {
        tooltip.classList.remove('hidden');
        tooltip.style.left = `${mx + 12}px`;
        tooltip.style.top = `${my - 20}px`;
        tooltip.innerHTML = `
          <div class="font-bold text-purple-400 mb-1">v${nearestVer.version}</div>
          <div>${nearestVer.title}</div>
          <div class="text-kernel-500">${nearestVer.date}</div>
          ${nearestVer.tests ? `<div>${nearestVer.tests.toLocaleString()} tests · ${nearestVer.domains} domains</div>` : ''}
        `;
      } else if (nearestLedger && minLedgerDist < 15) {
        tooltip.classList.remove('hidden');
        tooltip.style.left = `${mx + 12}px`;
        tooltip.style.top = `${my - 20}px`;
        tooltip.innerHTML = `
          <div class="font-bold text-amber-400 mb-1">${nearestLedger.timestamp}</div>
          <div>F = ${nearestLedger.F.toFixed(4)} · IC = ${nearestLedger.IC.toFixed(4)}</div>
          <div>ω = ${nearestLedger.omega.toFixed(4)} · ${nearestLedger.regime}</div>
          <div class="text-green-400">${nearestLedger.status}</div>
        `;
      } else {
        tooltip.classList.add('hidden');
      }
    });

    canvas.addEventListener('mouseleave', () => {
      tooltip.classList.add('hidden');
    });
  }

  // ── Render: Version Lineage ──
  function renderVersionTimeline() {
    const container = document.getElementById('tl-version-timeline');
    if (!container) return;

    // Draw the append-only timeline
    const majorColor = 'border-purple-500 bg-purple-900/30 text-purple-300';
    const minorColor = 'border-blue-700 bg-blue-900/20 text-blue-300';
    const patchColor = 'border-kernel-700 bg-kernel-900 text-kernel-400';

    let html = '<div class="relative pl-8">';
    // Vertical line
    html += '<div class="absolute left-3 top-0 bottom-0 w-0.5 bg-kernel-700"></div>';

    for (let i = VERSIONS.length - 1; i >= 0; i--) {
      const v = VERSIONS[i];
      const colorClass = v.kind === 'major' ? majorColor : v.kind === 'minor' ? minorColor : patchColor;
      const dotColor = v.kind === 'major' ? 'bg-purple-500' : v.kind === 'minor' ? 'bg-blue-500' : 'bg-kernel-500';

      html += `
        <div class="relative mb-3 group">
          <div class="absolute -left-5 top-2.5 w-3 h-3 rounded-full ${dotColor} border-2 border-kernel-950 z-10"></div>
          <div class="border rounded-lg p-3 ${colorClass} cursor-pointer hover:brightness-110 transition" data-version="${v.version}">
            <div class="flex items-center justify-between flex-wrap gap-2">
              <div class="flex items-center gap-2">
                <span class="font-bold text-sm">v${v.version}</span>
                <span class="text-xs opacity-60">${v.date}</span>
                ${v.kind === 'major' ? '<span class="text-[10px] px-1.5 py-0.5 bg-purple-500/30 rounded-full">MAJOR</span>' : ''}
              </div>
              <div class="text-xs opacity-70">
                ${v.tests ? `${v.tests.toLocaleString()} tests` : ''} ${v.domains ? `· ${v.domains} domains` : ''}
              </div>
            </div>
            <div class="text-xs mt-1 font-medium">${v.title}</div>
            <div class="text-[10px] mt-1 opacity-60 hidden group-hover:block">${v.highlight}</div>
          </div>
        </div>
      `;
    }

    html += '</div>';
    container.innerHTML = html;
  }

  // ── Render: Weld Registry ──
  function renderWeldRegistry() {
    const container = document.getElementById('tl-weld-registry');
    if (!container) return;

    let html = '';
    for (const we of WELDS) {
      const passStr = we.seam_residual <= TOL_SEAM;
      const ratio = we.integrity_ratio;
      const direction = ratio > 1 ? '↑' : ratio < 1 ? '↓' : '→';
      const dirColor = ratio > 1 ? 'text-green-400' : ratio < 1 ? 'text-red-400' : 'text-kernel-400';

      html += `
        <div class="border border-kernel-700 rounded-lg p-4 hover:border-blue-700 transition">
          <div class="flex items-start justify-between flex-wrap gap-2">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="font-bold text-sm text-blue-400 font-mono">${we.seam_id}</span>
                <span class="text-[10px] px-1.5 py-0.5 ${passStr ? 'bg-green-900/40 text-green-400 border border-green-800' : 'bg-red-900/40 text-red-400 border border-red-800'} rounded-full">
                  ${passStr ? '✓ PASS' : '✗ FAIL'}
                </span>
              </div>
              <div class="text-xs text-kernel-500">${we.date} · ${we.contract}</div>
            </div>
            <div class="text-right">
              <div class="flex items-center gap-2 text-sm font-mono">
                <span class="text-kernel-400">${we.IC_pre.toFixed(4)}</span>
                <span class="${dirColor} font-bold">${direction}</span>
                <span class="text-kernel-200">${we.IC_post.toFixed(4)}</span>
              </div>
              <div class="text-[10px] text-kernel-600">IC ratio: ${ratio.toFixed(3)}</div>
            </div>
          </div>
          <div class="mt-2 text-xs text-kernel-400">${we.description}</div>
          <div class="mt-2 flex flex-wrap gap-3 text-[10px] text-kernel-600">
            <span>|Δκ| = ${we.seam_residual.toFixed(4)}</span>
            <span>tol = ${TOL_SEAM}</span>
            <span>${we.weld_type}</span>
            <span>${we.result}</span>
          </div>
        </div>
      `;
    }
    container.innerHTML = html;
  }

  // ── Render: Epistemic Cards ──
  function renderEpistemicCards() {
    const container = document.getElementById('tl-epistemic-cards');
    if (!container) return;

    const trichotomy = [
      {
        verdict: 'RETURN',
        latin: 'Reditus',
        color: 'border-green-700 bg-green-900/20',
        textColor: 'text-green-400',
        icon: '↩',
        count: '10,023',
        description: 'Seam closed: τ_R finite, |s| ≤ tol_seam, identity holds. The system returns to legitimacy.',
        condition: 'τ_R < ∞ ∧ |Δκ| ≤ 0.005 ∧ F + ω = 1',
      },
      {
        verdict: 'GESTURE',
        latin: 'Gestus',
        color: 'border-kernel-600 bg-kernel-900',
        textColor: 'text-kernel-400',
        icon: '◌',
        count: '0',
        description: 'Emission exists but seam didn\'t close. Potentially valuable as Tier-2 exploration, but not yet real.',
        condition: 'τ_R = ∞_rec ∨ |Δκ| > 0.005 ∨ identity fails',
      },
      {
        verdict: 'DISSOLUTION',
        latin: 'Dissolutio',
        color: 'border-red-800 bg-red-900/20',
        textColor: 'text-red-400',
        icon: '⊗',
        count: '0',
        description: 'ω ≥ 0.30 — the regime boundary. Not failure, but the boundary that makes return meaningful.',
        condition: 'ω ≥ 0.30',
      },
    ];

    let html = '';
    for (const t of trichotomy) {
      html += `
        <div class="border rounded-xl p-4 ${t.color}">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <span class="text-lg">${t.icon}</span>
              <div>
                <span class="font-bold ${t.textColor}">${t.verdict}</span>
                <span class="text-[10px] text-kernel-600 ml-1 italic">${t.latin}</span>
              </div>
            </div>
            <span class="text-xl font-bold ${t.textColor}">${t.count}</span>
          </div>
          <p class="text-xs text-kernel-400 mb-2">${t.description}</p>
          <div class="text-[10px] font-mono text-kernel-600">${t.condition}</div>
        </div>
      `;
    }
    container.innerHTML = html;
  }

  // ── Render: Freeze Archive ──
  function renderFreezeArchive() {
    const container = document.getElementById('tl-freeze-archive');
    if (!container) return;

    let html = '';
    for (const fp of FREEZES) {
      html += `
        <div class="border border-kernel-700 rounded-lg p-4 hover:border-cyan-700 transition">
          <div class="flex items-start justify-between flex-wrap gap-2 mb-2">
            <div>
              <div class="flex items-center gap-2">
                <span class="text-cyan-400 font-bold font-mono text-sm">${fp.run_id}</span>
                <span class="text-xs text-kernel-500">${fp.date}</span>
              </div>
            </div>
            <div class="text-xs font-mono text-kernel-400">
              F=${fp.invariants.F.toFixed(4)} · IC=${fp.invariants.IC.toFixed(4)} · ω=${fp.invariants.omega.toFixed(4)}
            </div>
          </div>
          <div class="flex flex-wrap gap-1.5 mb-2">
            ${fp.files.map(f => `<span class="text-[10px] px-1.5 py-0.5 bg-kernel-800 rounded text-kernel-400 font-mono">${f}</span>`).join('')}
          </div>
          <div class="text-[10px] text-kernel-600 font-mono">
            ${Object.entries(fp.hashes).map(([k, v]) => `${k}: ${v}`).join(' · ')}
          </div>
        </div>
      `;
    }
    container.innerHTML = html;
  }

  // ── Layer toggles ──
  function setupLayerToggles() {
    document.querySelectorAll('.tl-layer-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('active');
        btn.classList.toggle('opacity-40');
        // Re-render canvas with active layers
        initCanvas();
      });
    });
  }

  // ── Init ──
  document.addEventListener('DOMContentLoaded', () => {
    initCanvas();
    renderVersionTimeline();
    renderWeldRegistry();
    renderEpistemicCards();
    renderFreezeArchive();
    setupLayerToggles();
  });

  // Resize handler
  window.addEventListener('resize', () => {
    initCanvas();
  });
</script>
