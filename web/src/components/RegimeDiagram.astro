---
/**
 * Interactive Regime Phase Diagram — High-Resolution Edition
 * Port of: dashboard/pages_core.py render_regime_page()
 *
 * Canvas-based 2D phase diagram showing regime boundaries with:
 *   - Per-pixel gradient coloring based on IC, Δ, and regime
 *   - Regime boundary contour detection
 *   - Crosshair tracking with floating data panel
 *   - Resolution up to 600×600
 */
---

<div id="regime-diagram" class="space-y-5">
  <!-- Header -->
  <div class="bg-gradient-to-r from-kernel-900 via-kernel-900 to-kernel-800 border border-kernel-700/60 rounded-xl p-6">
    <h2 class="text-2xl font-bold text-kernel-100 mb-1 tracking-tight">Regime Phase Diagram</h2>
    <p class="text-kernel-400 text-sm leading-relaxed">
      Two-channel phase space showing regime boundaries. Move the cursor to explore kernel invariants at every point.
    </p>
    <div class="flex gap-4 mt-3 text-xs font-semibold">
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: #10b981"></span><span class="text-emerald-400">Stable 12.5%</span></span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: #f59e0b"></span><span class="text-amber-400">Watch 24.4%</span></span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: #ef4444"></span><span class="text-red-400">Collapse 63.1%</span></span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: #7c3aed"></span><span class="text-violet-400">Critical</span></span>
    </div>
  </div>

  <!-- Controls -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-3">
      <label class="text-[10px] uppercase tracking-widest text-kernel-500 font-semibold">Channels</label>
      <input id="regime-n" type="number" min="2" max="64" value="8"
        class="w-full mt-1.5 px-2.5 py-1.5 bg-kernel-800 border border-kernel-600/50 rounded-lg text-kernel-200 text-sm focus:border-amber-600/60 focus:outline-none transition" />
    </div>
    <div class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-3">
      <label class="text-[10px] uppercase tracking-widest text-kernel-500 font-semibold">Resolution</label>
      <select id="regime-res"
        class="w-full mt-1.5 px-2.5 py-1.5 bg-kernel-800 border border-kernel-600/50 rounded-lg text-kernel-200 text-sm focus:border-amber-600/60 focus:outline-none transition">
        <option value="100">100 &times; 100</option>
        <option value="200">200 &times; 200</option>
        <option value="300">300 &times; 300</option>
        <option value="400" selected>400 &times; 400</option>
        <option value="600">600 &times; 600</option>
      </select>
    </div>
    <div class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-3">
      <label class="text-[10px] uppercase tracking-widest text-kernel-500 font-semibold">Color mode</label>
      <select id="regime-color"
        class="w-full mt-1.5 px-2.5 py-1.5 bg-kernel-800 border border-kernel-600/50 rounded-lg text-kernel-200 text-sm focus:border-amber-600/60 focus:outline-none transition">
        <option value="gradient" selected>Gradient (IC-weighted)</option>
        <option value="flat">Flat regime colors</option>
        <option value="heatmap">IC heatmap</option>
      </select>
    </div>
    <div class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-3">
      <label class="text-[10px] uppercase tracking-widest text-kernel-500 font-semibold">Boundaries</label>
      <select id="regime-boundary"
        class="w-full mt-1.5 px-2.5 py-1.5 bg-kernel-800 border border-kernel-600/50 rounded-lg text-kernel-200 text-sm focus:border-amber-600/60 focus:outline-none transition">
        <option value="on" selected>Show contours</option>
        <option value="off">Hide contours</option>
      </select>
    </div>
  </div>

  <!-- Canvas area -->
  <div class="bg-kernel-950 border border-kernel-700/40 rounded-xl p-5 shadow-2xl">
    <div class="relative mx-auto" style="max-width: 720px;">
      <canvas id="phase-canvas"
        class="w-full cursor-crosshair rounded-lg"
        style="aspect-ratio: 1 / 1;">
      </canvas>
      <!-- Crosshair tooltip -->
      <div id="phase-tooltip" class="absolute hidden pointer-events-none text-[11px] font-mono bg-kernel-900/95 backdrop-blur-sm border border-kernel-500/40 rounded-lg px-3 py-2 text-kernel-200 shadow-xl z-10 whitespace-nowrap"></div>
    </div>
    <!-- Rendering status -->
    <div id="render-status" class="text-center mt-3 text-[11px] text-kernel-500 font-mono"></div>
  </div>

  <!-- Hover detail panel -->
  <div id="hover-info" class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-4 text-sm text-kernel-300 hidden transition-all">
    <div class="grid grid-cols-4 md:grid-cols-8 gap-2" id="hover-values"></div>
  </div>

  <!-- Regime partition bar -->
  <div class="bg-kernel-900/80 border border-kernel-700/50 rounded-xl p-5">
    <h3 class="text-xs font-bold text-kernel-400 uppercase tracking-widest mb-3">Regime Partition — Fisher Space</h3>
    <div class="flex gap-2 items-center">
      <div class="flex-1">
        <div class="flex h-4 rounded-full overflow-hidden shadow-inner">
          <div class="transition-all" style="width: 12.5%; background: linear-gradient(135deg, #059669, #10b981)"></div>
          <div class="transition-all" style="width: 24.4%; background: linear-gradient(135deg, #d97706, #f59e0b)"></div>
          <div class="transition-all" style="width: 63.1%; background: linear-gradient(135deg, #dc2626, #ef4444)"></div>
        </div>
        <div class="flex justify-between text-[10px] text-kernel-500 mt-1.5 font-mono">
          <span>Stable 12.5%</span>
          <span>Watch 24.4%</span>
          <span>Collapse 63.1%</span>
        </div>
      </div>
    </div>
    <p class="text-[11px] text-kernel-500 mt-3 italic leading-relaxed">
      Stability is rare — 87.5% of the manifold lies outside it.
      Return from collapse to stability is what the axiom measures.
    </p>
  </div>
</div>

<script>
  import { computeKernel, classifyRegime } from '../lib/kernel';
  import type { KernelResult, RegimeLabel } from '../lib/kernel';

  const canvas = document.getElementById('phase-canvas') as HTMLCanvasElement;
  const hoverInfo = document.getElementById('hover-info')!;
  const hoverValues = document.getElementById('hover-values')!;
  const tooltip = document.getElementById('phase-tooltip')!;
  const statusEl = document.getElementById('render-status')!;

  /* ═══════ Color palettes ═══════ */

  // HSL-based regime palette with luminance variation based on IC
  function regimeGradientColor(regime: RegimeLabel, ic: number, delta: number, isCritical: boolean): [number, number, number] {
    // Base hues: Stable=160 (emerald), Watch=38 (amber), Collapse=4 (red)
    let h: number, sBase: number, lBase: number;
    if (regime === 'STABLE') {
      h = 160; sBase = 72; lBase = 38;
    } else if (regime === 'WATCH') {
      h = 38; sBase = 78; lBase = 40;
    } else {
      h = 4; sBase = 72; lBase = 36;
    }

    // Modulate lightness by IC (higher IC = brighter)
    const icFactor = Math.max(0, Math.min(1, ic));
    const l = lBase + icFactor * 18;

    // Modulate saturation by delta (higher gap = more vivid)
    const deltaFactor = Math.max(0, Math.min(1, delta * 3));
    const s = sBase - deltaFactor * 15;

    // Critical overlay shifts hue toward violet
    if (isCritical) {
      const ch = 270;
      const blendAmt = 0.35;
      return hslToRgb(
        h * (1 - blendAmt) + ch * blendAmt,
        s * 0.8,
        l * 0.85,
      );
    }

    return hslToRgb(h, s, l);
  }

  function flatRegimeColor(regime: RegimeLabel, isCritical: boolean): [number, number, number] {
    if (isCritical) return [124, 58, 237]; // violet-600
    if (regime === 'STABLE') return [16, 185, 129]; // emerald-500
    if (regime === 'WATCH') return [245, 158, 11]; // amber-500
    return [239, 68, 68]; // red-500
  }

  // IC heatmap: black → blue → cyan → green → yellow → white
  function icHeatmapColor(ic: number): [number, number, number] {
    const t = Math.max(0, Math.min(1, ic));
    // 5-stop gradient
    if (t < 0.2) {
      const u = t / 0.2;
      return lerpRgb([8, 8, 30], [30, 60, 180], u);
    } else if (t < 0.4) {
      const u = (t - 0.2) / 0.2;
      return lerpRgb([30, 60, 180], [20, 180, 180], u);
    } else if (t < 0.6) {
      const u = (t - 0.4) / 0.2;
      return lerpRgb([20, 180, 180], [40, 200, 60], u);
    } else if (t < 0.8) {
      const u = (t - 0.6) / 0.2;
      return lerpRgb([40, 200, 60], [250, 210, 40], u);
    } else {
      const u = (t - 0.8) / 0.2;
      return lerpRgb([250, 210, 40], [255, 255, 255], u);
    }
  }

  function lerpRgb(a: [number, number, number], b: [number, number, number], t: number): [number, number, number] {
    return [
      Math.round(a[0] + (b[0] - a[0]) * t),
      Math.round(a[1] + (b[1] - a[1]) * t),
      Math.round(a[2] + (b[2] - a[2]) * t),
    ];
  }

  function hslToRgb(h: number, s: number, l: number): [number, number, number] {
    h = h % 360;
    s = s / 100;
    l = l / 100;
    const c = (1 - Math.abs(2 * l - 1)) * s;
    const x = c * (1 - Math.abs((h / 60) % 2 - 1));
    const m = l - c / 2;
    let r1: number, g1: number, b1: number;
    if (h < 60)       { r1 = c; g1 = x; b1 = 0; }
    else if (h < 120) { r1 = x; g1 = c; b1 = 0; }
    else if (h < 180) { r1 = 0; g1 = c; b1 = x; }
    else if (h < 240) { r1 = 0; g1 = x; b1 = c; }
    else if (h < 300) { r1 = x; g1 = 0; b1 = c; }
    else              { r1 = c; g1 = 0; b1 = x; }
    return [
      Math.round((r1 + m) * 255),
      Math.round((g1 + m) * 255),
      Math.round((b1 + m) * 255),
    ];
  }

  /* ═══════ State ═══════ */

  let currentResults: (KernelResult | null)[][] = [];
  let regimeGrid: (RegimeLabel | null)[][] = [];
  let phaseArea: { m: { top: number; right: number; bottom: number; left: number }; plotW: number; plotH: number; cssW: number; cssH: number } | null = null;

  /* ═══════ Render ═══════ */

  function renderPhaseDiagram() {
    const res = parseInt((document.getElementById('regime-res') as HTMLSelectElement).value);
    const nChannels = parseInt((document.getElementById('regime-n') as HTMLInputElement).value);
    const colorMode = (document.getElementById('regime-color') as HTMLSelectElement).value;
    const showBoundary = (document.getElementById('regime-boundary') as HTMLSelectElement).value === 'on';

    statusEl.textContent = `Computing ${res}\u00d7${res} kernel grid\u2026`;

    // Use requestAnimationFrame so the status renders before heavy computation
    requestAnimationFrame(() => {
      const t0 = performance.now();

      const container = canvas.parentElement!;
      const cssW = Math.min(container.clientWidth, 720);
      const cssH = cssW; // square
      const dpr = Math.min(window.devicePixelRatio || 1, 3);

      canvas.width = Math.round(cssW * dpr);
      canvas.height = Math.round(cssH * dpr);
      canvas.style.width = cssW + 'px';
      canvas.style.height = cssH + 'px';

      const ctx = canvas.getContext('2d')!;
      ctx.scale(dpr, dpr);

      const m = { top: 28, right: 20, bottom: 56, left: 60 };
      const plotW = cssW - m.left - m.right;
      const plotH = cssH - m.top - m.bottom;
      phaseArea = { m, plotW, plotH, cssW, cssH };

      // Background
      ctx.fillStyle = '#030308';
      ctx.fillRect(0, 0, cssW, cssH);

      // Render heatmap into offscreen canvas
      const offscreen = new OffscreenCanvas(res, res);
      const octx = offscreen.getContext('2d')!;
      const imageData = octx.createImageData(res, res);
      currentResults = [];
      regimeGrid = [];

      for (let py = 0; py < res; py++) {
        const row: (KernelResult | null)[] = [];
        const regRow: (RegimeLabel | null)[] = [];
        const c2 = 1.0 - (py / (res - 1));
        for (let px = 0; px < res; px++) {
          const c1 = px / (res - 1);
          const c = Array(nChannels).fill(0.5);
          c[0] = c1;
          c[1] = c2;

          const result = computeKernel(c);
          const { regime, isCritical } = classifyRegime(result);
          row.push(result);
          regRow.push(regime);

          let color: [number, number, number];
          if (colorMode === 'gradient') {
            color = regimeGradientColor(regime, result.IC, result.delta, isCritical);
          } else if (colorMode === 'heatmap') {
            color = icHeatmapColor(result.IC);
          } else {
            color = flatRegimeColor(regime, isCritical);
          }

          const idx = (py * res + px) * 4;
          imageData.data[idx] = color[0];
          imageData.data[idx + 1] = color[1];
          imageData.data[idx + 2] = color[2];
          imageData.data[idx + 3] = 255;
        }
        currentResults.push(row);
        regimeGrid.push(regRow);
      }
      octx.putImageData(imageData, 0, 0);

      // Draw scaled into plot area — smooth for high-res
      ctx.imageSmoothingEnabled = res >= 200;
      ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(offscreen, m.left, m.top, plotW, plotH);

      // ─── Regime boundary contours ───
      if (showBoundary) {
        ctx.save();
        ctx.beginPath();
        ctx.rect(m.left, m.top, plotW, plotH);
        ctx.clip();

        ctx.strokeStyle = 'rgba(255, 255, 255, 0.55)';
        ctx.lineWidth = 1.2;
        ctx.setLineDash([]);

        for (let py = 0; py < res - 1; py++) {
          for (let px = 0; px < res - 1; px++) {
            const r0 = regimeGrid[py][px];
            const r1 = regimeGrid[py][px + 1];
            const r2 = regimeGrid[py + 1][px];
            if (r0 !== r1 || r0 !== r2) {
              const x = m.left + (px / (res - 1)) * plotW;
              const y = m.top + (py / (res - 1)) * plotH;
              const cellW = plotW / (res - 1);
              const cellH = plotH / (res - 1);
              ctx.fillStyle = 'rgba(255, 255, 255, 0.12)';
              ctx.fillRect(x, y, cellW, cellH);
            }
          }
        }
        ctx.restore();
      }

      // ─── Grid lines ───
      const ticks = 5;
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.06)';
      ctx.lineWidth = 0.5;

      for (let i = 1; i < ticks; i++) {
        const x = m.left + (i / ticks) * plotW;
        ctx.beginPath(); ctx.moveTo(x, m.top); ctx.lineTo(x, m.top + plotH); ctx.stroke();
        const y = m.top + (i / ticks) * plotH;
        ctx.beginPath(); ctx.moveTo(m.left, y); ctx.lineTo(m.left + plotW, y); ctx.stroke();
      }

      // ─── Axes ───
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.35)';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(m.left, m.top);
      ctx.lineTo(m.left, m.top + plotH);
      ctx.lineTo(m.left + plotW, m.top + plotH);
      ctx.stroke();

      // ─── Tick labels ───
      ctx.fillStyle = 'rgba(255, 255, 255, 0.55)';
      ctx.font = '11px ui-monospace, "JetBrains Mono", monospace';

      ctx.textAlign = 'center';
      for (let i = 0; i <= ticks; i++) {
        const val = i / ticks;
        const x = m.left + (i / ticks) * plotW;
        // Tick mark
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.35)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(x, m.top + plotH); ctx.lineTo(x, m.top + plotH + 5); ctx.stroke();
        ctx.fillText(val.toFixed(1), x, m.top + plotH + 19);
      }
      ctx.textAlign = 'right';
      for (let i = 0; i <= ticks; i++) {
        const val = 1 - i / ticks;
        const y = m.top + (i / ticks) * plotH;
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.35)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(m.left - 5, y); ctx.lineTo(m.left, y); ctx.stroke();
        ctx.fillText(val.toFixed(1), m.left - 9, y + 4);
      }

      // ─── Axis titles ───
      ctx.fillStyle = 'rgba(255, 255, 255, 0.65)';
      ctx.font = '600 13px ui-sans-serif, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('c\u2081  (channel 1)', m.left + plotW / 2, cssH - 10);
      ctx.save();
      ctx.translate(16, m.top + plotH / 2);
      ctx.rotate(-Math.PI / 2);
      ctx.fillText('c\u2082  (channel 2)', 0, 0);
      ctx.restore();

      // ─── Legend (top-right, semi-transparent glass) ───
      const legW = 150;
      const legH = colorMode === 'heatmap' ? 30 : 88;
      const legX = m.left + plotW - legW - 6;
      const legY = m.top + 8;

      ctx.fillStyle = 'rgba(3, 3, 8, 0.82)';
      ctx.beginPath();
      ctx.roundRect(legX, legY, legW, legH, 6);
      ctx.fill();
      ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.roundRect(legX, legY, legW, legH, 6);
      ctx.stroke();

      if (colorMode === 'heatmap') {
        // Draw IC gradient bar
        const barX = legX + 8;
        const barW = legW - 16;
        const barY = legY + 8;
        const barH = 14;
        for (let i = 0; i < barW; i++) {
          const t = i / barW;
          const [r, g, b] = icHeatmapColor(t);
          ctx.fillStyle = `rgb(${r},${g},${b})`;
          ctx.fillRect(barX + i, barY, 1, barH);
        }
        ctx.fillStyle = 'rgba(255,255,255,0.5)';
        ctx.font = '9px ui-monospace, monospace';
        ctx.textAlign = 'left';
        ctx.fillText('0', barX, barY + barH + 10);
        ctx.textAlign = 'center';
        ctx.fillText('IC', barX + barW / 2, barY + barH + 10);
        ctx.textAlign = 'right';
        ctx.fillText('1', barX + barW, barY + barH + 10);
      } else {
        const legends: [string, [number, number, number], string][] = [
          ['Stable  (12.5%)', colorMode === 'gradient' ? regimeGradientColor('STABLE', 0.9, 0.05, false) : flatRegimeColor('STABLE', false), '#34d399'],
          ['Watch   (24.4%)', colorMode === 'gradient' ? regimeGradientColor('WATCH', 0.6, 0.2, false) : flatRegimeColor('WATCH', false), '#fbbf24'],
          ['Collapse (63.1%)', colorMode === 'gradient' ? regimeGradientColor('COLLAPSE', 0.3, 0.4, false) : flatRegimeColor('COLLAPSE', false), '#f87171'],
          ['Critical overlay', colorMode === 'gradient' ? regimeGradientColor('COLLAPSE', 0.2, 0.5, true) : flatRegimeColor('COLLAPSE', true), '#a78bfa'],
        ];
        ctx.font = '10px ui-sans-serif, system-ui, sans-serif';
        legends.forEach(([label, swatch, textColor], i) => {
          const sy = legY + 8 + i * 19;
          // Swatch with rounded corners
          ctx.fillStyle = `rgb(${swatch[0]},${swatch[1]},${swatch[2]})`;
          ctx.beginPath();
          ctx.roundRect(legX + 8, sy, 14, 14, 3);
          ctx.fill();
          // Label
          ctx.fillStyle = textColor;
          ctx.textAlign = 'left';
          ctx.fillText(label, legX + 28, sy + 11);
        });
      }

      // ─── Info badge ───
      ctx.fillStyle = 'rgba(3, 3, 8, 0.7)';
      ctx.beginPath();
      ctx.roundRect(m.left + 6, m.top + 6, 170, 20, 4);
      ctx.fill();
      ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
      ctx.font = '10px ui-monospace, "JetBrains Mono", monospace';
      ctx.textAlign = 'left';
      ctx.fillText(`n=${nChannels} channels \u00b7 ${res}\u00d7${res} grid`, m.left + 12, m.top + 19);

      const elapsed = ((performance.now() - t0) / 1000).toFixed(2);
      statusEl.textContent = `${res}\u00d7${res} \u00b7 ${(res * res).toLocaleString()} kernel evaluations \u00b7 ${elapsed}s`;
    });
  }

  /* ═══════ Hover / crosshair ═══════ */

  let lastPx = -1;
  let lastPy = -1;

  canvas.addEventListener('mousemove', (e) => {
    if (!phaseArea) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const { m, plotW, plotH } = phaseArea;

    if (mx < m.left || mx > m.left + plotW || my < m.top || my > m.top + plotH) {
      hoverInfo.classList.add('hidden');
      tooltip.classList.add('hidden');
      return;
    }

    const res = currentResults.length;
    const px = Math.floor(((mx - m.left) / plotW) * (res - 1));
    const py = Math.floor(((my - m.top) / plotH) * (res - 1));
    if (px < 0 || px >= res || py < 0 || py >= res) return;
    if (px === lastPx && py === lastPy) return; // no change
    lastPx = px;
    lastPy = py;

    const result = currentResults[py]?.[px];
    if (!result) return;

    const { regime, isCritical } = classifyRegime(result);
    const c1 = (px / (res - 1)).toFixed(3);
    const c2 = (1 - py / (res - 1)).toFixed(3);

    hoverInfo.classList.remove('hidden');
    const items: { label: string; value: string; color?: string }[] = [
      { label: 'c\u2081', value: c1, color: 'text-kernel-300' },
      { label: 'c\u2082', value: c2, color: 'text-kernel-300' },
      { label: 'F', value: result.F.toFixed(4) },
      { label: '\u03c9', value: result.omega.toFixed(4) },
      { label: 'S', value: result.S.toFixed(4) },
      { label: 'C', value: result.C.toFixed(4) },
      { label: '\u03ba', value: result.kappa.toFixed(4) },
      { label: 'IC', value: result.IC.toFixed(4) },
    ];

    const regColor = regime === 'STABLE' ? 'text-emerald-400' : regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
    hoverValues.innerHTML = items.map(v => `
      <div class="bg-kernel-800/80 rounded-lg px-2 py-1.5 text-center">
        <div class="text-[10px] text-kernel-500 font-semibold">${v.label}</div>
        <div class="font-mono text-xs ${v.color ?? 'text-kernel-200'}">${v.value}</div>
      </div>
    `).join('') + `
      <div class="bg-kernel-800/80 rounded-lg px-2 py-1.5 text-center col-span-4 md:col-span-8">
        <span class="text-xs font-semibold ${regColor}">
          ${regime}${isCritical ? ' + CRITICAL' : ''}</span>
        <span class="text-[10px] text-kernel-500 ml-2">\u0394 = ${result.delta.toFixed(4)}</span>
      </div>
    `;

    // Floating tooltip near cursor
    const regHex = regime === 'STABLE' ? '#34d399' : regime === 'WATCH' ? '#fbbf24' : '#f87171';
    tooltip.innerHTML = `<span style="color:${regHex};font-weight:600">${regime}</span>`
      + `<span style="color:rgba(255,255,255,0.4);margin:0 4px">\u00b7</span>`
      + `F\u2009=\u2009${result.F.toFixed(3)}  \u03c9\u2009=\u2009${result.omega.toFixed(3)}  IC\u2009=\u2009${result.IC.toFixed(3)}`;
    // Position with smart edge detection
    const ttW = 320;
    const leftPos = mx + 16 + ttW > phaseArea.cssW ? mx - ttW - 8 : mx + 16;
    tooltip.style.left = leftPos + 'px';
    tooltip.style.top = (my - 14) + 'px';
    tooltip.classList.remove('hidden');
  });

  canvas.addEventListener('mouseleave', () => {
    hoverInfo.classList.add('hidden');
    tooltip.classList.add('hidden');
    lastPx = -1;
    lastPy = -1;
  });

  ['regime-res', 'regime-n', 'regime-color', 'regime-boundary'].forEach(id => {
    document.getElementById(id)!.addEventListener('change', renderPhaseDiagram);
  });

  renderPhaseDiagram();
</script>
